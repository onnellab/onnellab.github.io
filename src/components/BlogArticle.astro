---
import BaseLayout from '../layouts/BaseLayout.astro';
import { renderMarkdownBlocks, type BlogPost } from '../lib/blog';
import type { Locale } from '../lib/products';

type Props = {
  locale: Locale;
  post: BlogPost;
};

const { locale, post } = Astro.props;
const isKo = locale === 'ko';
const blocks = renderMarkdownBlocks(post.body);
const shortAnswerHeadings = new Set(['short answer', '짧은 답변', '요약']);
const faqHeadings = new Set(['faq', '자주 묻는 질문']);
const articleBlocks: typeof blocks = [];
let skippingShortAnswer = false;
for (const block of blocks) {
  if (block.type === 'h2' && shortAnswerHeadings.has(String(block.value).trim().toLowerCase())) {
    skippingShortAnswer = true;
    continue;
  }
  if (skippingShortAnswer && block.type === 'h2') {
    skippingShortAnswer = false;
  }
  if (!skippingShortAnswer) articleBlocks.push(block);
}
const faqBlocks = new Map<number, Array<{ question: string; answer: string }>>();
const skippedBlockIndexes = new Set<number>();
for (let index = 0; index < articleBlocks.length; index += 1) {
  const block = articleBlocks[index];
  if (block.type !== 'h2' || !faqHeadings.has(String(block.value).trim().toLowerCase())) continue;
  const items: Array<{ question: string; answer: string }> = [];
  let cursor = index + 1;
  while (cursor < articleBlocks.length && articleBlocks[cursor].type !== 'h2') {
    const questionBlock = articleBlocks[cursor];
    if (questionBlock.type !== 'h3') {
      cursor += 1;
      continue;
    }
    const answerParts: string[] = [];
    skippedBlockIndexes.add(cursor);
    cursor += 1;
    while (cursor < articleBlocks.length && articleBlocks[cursor].type !== 'h2' && articleBlocks[cursor].type !== 'h3') {
      const answerBlock = articleBlocks[cursor];
      skippedBlockIndexes.add(cursor);
      if (answerBlock.type === 'p' || answerBlock.type === 'blockquote') answerParts.push(String(answerBlock.value));
      if (answerBlock.type === 'ul' || answerBlock.type === 'ol') answerParts.push(answerBlock.value.join(' '));
      cursor += 1;
    }
    items.push({ question: String(questionBlock.value), answer: answerParts.join(' ').trim() });
  }
  if (items.length > 0) faqBlocks.set(index, items);
}
const articleImages = articleBlocks.filter((block) => block.type === 'image');
const homeHref = isKo ? '/ko/' : '/';
const blogHref = isKo ? '/blog/ko/' : '/blog/';
const appsHref = isKo ? '/apps/ko/' : '/apps/';
const copy = isKo
  ? {
      blog: 'Blog',
      apps: 'Apps',
      summary: '요약',
      relatedApps: '관련 앱',
      relatedArticles: '관련 글',
      relatedGuides: '관련 가이드',
      visualPlan: '이미지 계획',
      tags: '태그',
      published: '게시',
      updated: '수정'
    }
  : {
      blog: 'Blog',
      apps: 'Apps',
      summary: 'Summary',
      relatedApps: 'Related apps',
      relatedArticles: 'Related articles',
      relatedGuides: 'Related guides',
      visualPlan: 'Image plan',
      tags: 'Tags',
      published: 'Published',
      updated: 'Updated'
    };
const summaryText = post.meta.shortAnswer || post.meta.description;
const dateLabel = (value?: string) => {
  if (!value) return '';
  const localDate = value.match(/^\d{4}-\d{2}-\d{2}/);
  if (localDate) return localDate[0];
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return date.toISOString().slice(0, 10);
};
const appHref = (appName: string) => {
  const slug = appName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  return isKo ? `/apps/${slug}/ko/` : `/apps/${slug}/`;
};
const recommendation = (item: string) => {
  const markdown = item.match(/^\[([^\]]+)\]\(([^)]+)\)$/);
  const pair = item.match(/^(.+?)\s*=>\s*(\/\S+)$/);
  if (markdown) return { label: markdown[1], href: markdown[2] };
  if (pair) return { label: pair[1].trim(), href: pair[2] };
  return { label: item, href: '' };
};
const inlineParts = (value: string) => {
  const parts: Array<{ text: string; href?: string }> = [];
  const pattern = /\[([^\]]+)\]\(([^)]+)\)/g;
  let lastIndex = 0;
  for (const match of value.matchAll(pattern)) {
    if (match.index > lastIndex) parts.push({ text: value.slice(lastIndex, match.index) });
    parts.push({ text: match[1], href: match[2] });
    lastIndex = match.index + match[0].length;
  }
  if (lastIndex < value.length) parts.push({ text: value.slice(lastIndex) });
  return parts.length > 0 ? parts : [{ text: value }];
};
const hasMeta = post.meta.publishedAt || post.meta.updatedAt || post.meta.relatedApps.length || post.meta.tags.length;
const hasRecommendations =
  post.meta.relatedApps.length > 0 ||
  post.meta.relatedArticles.length > 0 ||
  post.meta.relatedGuides.length > 0 ||
  post.meta.tags.length > 0;
---

<BaseLayout
  title={`${post.meta.title} - ONNELLAB Blog`}
  description={post.meta.description}
  canonicalPath={post.href}
  lang={locale}
  alternates={isKo ? [{ lang: 'ko', path: post.href }] : [{ lang: 'en', path: post.href }, { lang: 'x-default', path: post.href }]}
>
  <main class="article-shell">
    <nav class="top-nav" aria-label="Article navigation">
      <a class="brand" href={homeHref}>ONNELLAB</a>
      <div class="nav-actions">
        <a href={appsHref}>{copy.apps}</a>
        <a href={blogHref}>{copy.blog}</a>
      </div>
    </nav>

    <article>
      <header class="article-header">
        <p class="category">{post.meta.category}</p>
        <h1>{post.meta.title}</h1>
        <p class="description">{post.meta.description}</p>
        {hasMeta && (
          <div class="meta-grid" aria-label="Article metadata">
            {post.meta.publishedAt && <span>{copy.published} {dateLabel(post.meta.publishedAt)}</span>}
            {post.meta.updatedAt && <span>{copy.updated} {dateLabel(post.meta.updatedAt)}</span>}
            {post.meta.relatedApps.map((app) => <a href={appHref(app)}>{app}</a>)}
            {post.meta.tags.map((tag) => <span>{tag}</span>)}
          </div>
        )}
      </header>

      <aside class="summary-box" aria-label={copy.summary}>
        <p>{copy.summary}</p>
        <span>{summaryText}</span>
      </aside>

      <div class="article-body">
        {articleBlocks.map((block, index) => {
          if (skippedBlockIndexes.has(index)) return null;
          if (block.type === 'h2' && faqBlocks.has(index)) {
            return (
              <section class="faq-section" aria-labelledby={`faq-${index}`}>
                <h2 id={`faq-${index}`}>{block.value}</h2>
                <div class="faq-list">
                  {faqBlocks.get(index)?.map((item) => (
                    <details>
                      <summary>{item.question}</summary>
                      <p>{item.answer}</p>
                    </details>
                  ))}
                </div>
              </section>
            );
          }
          if (block.type === 'h2') return <h2>{block.value}</h2>;
          if (block.type === 'h3') return <h3>{block.value}</h3>;
          if (block.type === 'ul') {
            return <ul>{(block.value as string[]).map((item) => <li>{inlineParts(item).map((part) => part.href ? <a href={part.href}>{part.text}</a> : part.text)}</li>)}</ul>;
          }
          if (block.type === 'ol') {
            return <ol>{(block.value as string[]).map((item) => <li>{inlineParts(item).map((part) => part.href ? <a href={part.href}>{part.text}</a> : part.text)}</li>)}</ol>;
          }
          if (block.type === 'blockquote') return <blockquote>{inlineParts(block.value).map((part) => part.href ? <a href={part.href}>{part.text}</a> : part.text)}</blockquote>;
          if (block.type === 'code') return <pre><code>{block.value}</code></pre>;
          if (block.type === 'image') {
            const imageIndex = articleImages.indexOf(block);
            return (
              <figure class="article-image">
                <button class="article-image-button" type="button" data-article-image-trigger data-image-index={imageIndex}>
                  <img src={block.src} alt={block.alt || ''} loading="lazy" decoding="async" />
                </button>
                {block.caption && <figcaption>{block.caption}</figcaption>}
              </figure>
            );
          }
          if (block.type === 'table') {
            return (
              <div class="table-scroll">
                <table>
                  <thead>
                    <tr>{block.value.headers.map((header) => <th>{header}</th>)}</tr>
                  </thead>
                  <tbody>
                    {block.value.rows.map((row) => (
                      <tr>{row.map((cell) => <td>{inlineParts(cell).map((part) => part.href ? <a href={part.href}>{part.text}</a> : part.text)}</td>)}</tr>
                    ))}
                  </tbody>
                </table>
              </div>
            );
          }
          return <p>{inlineParts(String(block.value)).map((part) => part.href ? <a href={part.href}>{part.text}</a> : part.text)}</p>;
        })}
      </div>

      {hasRecommendations && (
        <footer class="article-footer">
          {post.meta.relatedArticles.length > 0 && (
            <section aria-label={copy.relatedArticles}>
              <h2>{copy.relatedArticles}</h2>
              <div class="recommendation-list">
                {post.meta.relatedArticles.map((article) => {
                  const item = recommendation(article);
                  return item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>;
                })}
              </div>
            </section>
          )}
          {post.meta.relatedGuides.length > 0 && (
            <section aria-label={copy.relatedGuides}>
              <h2>{copy.relatedGuides}</h2>
              <div class="recommendation-list">
                {post.meta.relatedGuides.map((guide) => {
                  const item = recommendation(guide);
                  return item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>;
                })}
              </div>
            </section>
          )}
          {post.meta.relatedApps.length > 0 && (
            <section aria-label={copy.relatedApps}>
              <h2>{copy.relatedApps}</h2>
              <div class="chip-row">
                {post.meta.relatedApps.map((app) => <a href={appHref(app)}>{app}</a>)}
              </div>
            </section>
          )}
          {post.meta.tags.length > 0 && (
            <section aria-label={copy.tags}>
              <h2>{copy.tags}</h2>
              <div class="chip-row">
                {post.meta.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </section>
          )}
        </footer>
      )}
    </article>

    {articleImages.length > 0 && (
      <dialog class="article-image-viewer" aria-label="Article image">
        <div class="article-image-viewer-panel">
          <button class="article-image-close" type="button" data-article-image-close aria-label="Close">×</button>
          <img
            src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw=="
            alt=""
            data-article-image-viewer-img
            hidden
          />
          <p data-article-image-viewer-caption></p>
        </div>
      </dialog>
    )}
  </main>
  <script is:inline>
    (() => {
      const triggers = Array.from(document.querySelectorAll('[data-article-image-trigger]'));
      const viewer = document.querySelector('.article-image-viewer');
      const viewerImage = document.querySelector('[data-article-image-viewer-img]');
      const viewerCaption = document.querySelector('[data-article-image-viewer-caption]');
      const closeButton = document.querySelector('[data-article-image-close]');
      if (!triggers.length || !(viewer instanceof HTMLDialogElement) || !(viewerImage instanceof HTMLImageElement)) return;

      const openViewer = (trigger) => {
        const image = trigger.querySelector('img');
        const figure = trigger.closest('figure');
        if (!(image instanceof HTMLImageElement)) return;
        viewerImage.src = image.currentSrc || image.src;
        viewerImage.alt = image.alt || '';
        viewerImage.hidden = false;
        if (viewerCaption instanceof HTMLElement) viewerCaption.textContent = figure?.querySelector('figcaption')?.textContent || '';
        viewer.showModal();
        closeButton?.focus({ preventScroll: true });
      };

      triggers.forEach((trigger) => {
        trigger.addEventListener('click', () => openViewer(trigger));
      });
      closeButton?.addEventListener('click', () => viewer.close());
      viewer.addEventListener('click', (event) => {
        if (event.target === viewer) viewer.close();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && viewer.open) viewer.close();
      });
    })();
  </script>
</BaseLayout>

<style>
  .article-shell {
    width: min(840px, calc(100% - 40px));
    margin: 0 auto;
    padding: 22px 0 64px;
    line-height: 1.75;
  }
  .top-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 48px;
    font-size: 14px;
  }
  .top-nav a {
    color: #5f5a50;
    text-decoration: none;
    font-weight: 650;
  }
  .top-nav .brand {
    color: #737067;
    font-size: 14px;
    font-weight: 560;
  }
  .nav-actions {
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }
  .nav-actions a:hover,
  .nav-actions a:focus-visible,
  .article-body a:hover,
  .article-body a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .article-header {
    padding-bottom: 28px;
    border-bottom: 1px solid #e0d8cb;
  }
  .category {
    margin: 0 0 12px;
    color: #716a5f;
    font-size: 13px;
    font-weight: 720;
    text-transform: uppercase;
  }
  h1 {
    max-width: 780px;
    margin: 0;
    color: #2f2f2f;
    font-size: clamp(32px, 5vw, 54px);
    line-height: 1.12;
    letter-spacing: 0;
  }
  .description {
    max-width: 700px;
    margin: 18px 0 0;
    color: #5d5850;
    font-size: 18px;
    line-height: 1.62;
  }
  .meta-grid,
  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .meta-grid {
    margin-top: 20px;
  }
  .meta-grid span,
  .meta-grid a,
  .chip-row span,
  .chip-row a {
    border: 1px solid #ded6ca;
    border-radius: 999px;
    padding: 5px 10px;
    background: rgba(255, 253, 248, 0.78);
    color: #5d5850;
    font-size: 13px;
    font-weight: 650;
    line-height: 1.25;
    text-decoration: none;
  }
  .summary-box {
    margin-top: 24px;
    border: 1px solid #ded6ca;
    border-radius: 8px;
    padding: 18px 20px;
    background: #fffdf8;
  }
  .summary-box p {
    margin: 0 0 6px;
    color: #716a5f;
    font-size: 13px;
    font-weight: 720;
    text-transform: uppercase;
  }
  .summary-box span {
    color: #4f4b45;
    font-size: 16px;
    line-height: 1.62;
  }
  .visual-plan {
    display: grid;
    grid-template-columns: minmax(130px, 0.28fr) 1fr;
    gap: 18px;
    margin-top: 16px;
    border: 1px solid #ded6ca;
    border-radius: 8px;
    padding: 16px 18px;
    background: #f8f3ea;
  }
  .visual-plan div {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }
  .visual-plan p {
    margin: 0;
    color: #716a5f;
    font-size: 13px;
    font-weight: 720;
    text-transform: uppercase;
  }
  .visual-plan span {
    color: #756b5f;
    font-size: 13px;
    font-weight: 720;
  }
  .visual-plan ul {
    display: grid;
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .visual-plan li {
    min-height: 44px;
    border: 1px dashed #cfc5b7;
    border-radius: 8px;
    padding: 10px 12px;
    color: #4f4b45;
    font-size: 14px;
    line-height: 1.45;
    background: rgba(255, 253, 248, 0.72);
  }
  .article-body {
    padding-top: 18px;
  }
  .article-body h2 {
    margin: 38px 0 12px;
    color: #343331;
    font-size: 27px;
    line-height: 1.22;
    letter-spacing: 0;
  }
  .article-body h3 {
    margin: 28px 0 8px;
    color: #343331;
    font-size: 20px;
    line-height: 1.28;
  }
  .article-body p,
  .article-body li {
    color: #4f4b45;
    font-size: 17px;
  }
  .article-body p {
    margin: 0 0 18px;
  }
  .article-body ul,
  .article-body ol {
    margin: 0 0 22px;
    padding-left: 24px;
  }
  .article-body li + li {
    margin-top: 7px;
  }
  .article-body blockquote {
    margin: 26px 0;
    border-left: 3px solid #c4b9aa;
    padding: 12px 0 12px 18px;
    color: #4f4b45;
    font-size: 17px;
    line-height: 1.65;
    background: linear-gradient(90deg, rgba(248, 243, 234, 0.76), rgba(248, 243, 234, 0));
  }
  .article-body pre {
    overflow-x: auto;
    margin: 24px 0;
    border: 1px solid #ded6ca;
    border-radius: 8px;
    padding: 14px 16px;
    background: #2f2d29;
    color: #fffdf8;
    font-size: 14px;
    line-height: 1.55;
  }
  .article-body code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
  }
  .table-scroll {
    overflow-x: auto;
    margin: 24px 0;
    border: 1px solid #ded6ca;
    border-radius: 8px;
    background: #fffdf8;
  }
  .article-body table {
    width: 100%;
    min-width: 560px;
    border-collapse: collapse;
    font-size: 15px;
  }
  .article-body th,
  .article-body td {
    border-bottom: 1px solid #e7ded2;
    padding: 11px 13px;
    color: #4f4b45;
    text-align: left;
    vertical-align: top;
  }
  .article-body th {
    background: #f8f3ea;
    color: #343331;
    font-weight: 720;
  }
  .article-body tr:last-child td {
    border-bottom: 0;
  }
  .article-image {
    margin: 28px 0;
    border: 1px solid #ded6ca;
    border-radius: 8px;
    padding: 8px;
    background: #fffdf8;
  }
  .article-image-button {
    display: block;
    width: 100%;
    border: 0;
    border-radius: 6px;
    padding: 0;
    background: transparent;
    cursor: zoom-in;
  }
  .article-image img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 6px;
  }
  .article-image-button:focus-visible {
    outline: 2px solid #3f625a;
    outline-offset: 3px;
  }
  .article-image figcaption {
    margin-top: 8px;
    color: #716a5f;
    font-size: 13px;
    line-height: 1.45;
  }
  .faq-section {
    margin-top: 38px;
  }
  .faq-section h2 {
    margin-top: 0;
  }
  .faq-list {
    display: grid;
    gap: 10px;
    margin-top: 14px;
  }
  .faq-list details {
    border: 1px solid #ded6ca;
    border-radius: 8px;
    padding: 0;
    background: #fffdf8;
  }
  .faq-list summary {
    cursor: pointer;
    padding: 14px 16px;
    color: #343331;
    font-size: 16px;
    font-weight: 700;
    line-height: 1.45;
  }
  .faq-list summary::marker {
    color: #716a5f;
  }
  .faq-list p {
    margin: 0;
    border-top: 1px solid #e7ded2;
    padding: 13px 16px 15px;
    color: #4f4b45;
    font-size: 16px;
    line-height: 1.62;
  }
  .article-image-viewer {
    width: min(960px, calc(100vw - 36px));
    max-height: calc(100vh - 32px);
    border: 1px solid rgba(210, 201, 188, 0.62);
    border-radius: 18px;
    padding: 0;
    background: #f2eee7;
    color: #37342f;
    box-shadow: 0 28px 86px rgba(39, 34, 29, 0.26);
  }
  .article-image-viewer[open] {
    display: block;
  }
  .article-image-viewer::backdrop {
    background: rgba(34, 30, 26, 0.78);
  }
  .article-image-viewer-panel {
    display: grid;
    gap: 10px;
    padding: 12px;
  }
  .article-image-close {
    width: 34px;
    height: 34px;
    justify-self: end;
    border: 1px solid rgba(196, 185, 169, 0.5);
    border-radius: 999px;
    background: #fffdf8;
    color: #37342f;
    font: inherit;
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
  }
  .article-image-viewer img {
    display: block;
    width: auto;
    max-width: 100%;
    max-height: calc(100vh - 150px);
    margin: 0 auto;
    border: 1px solid rgba(210, 201, 188, 0.82);
    border-radius: 12px;
    background: #fffdf8;
  }
  .article-image-viewer p {
    margin: 0;
    color: #716a5f;
    font-size: 13px;
    line-height: 1.45;
    text-align: center;
  }
  .article-body a {
    color: #3f625a;
    font-weight: 650;
    text-decoration: underline;
    text-decoration-color: #c4b9aa;
    text-underline-offset: 3px;
  }
  .article-footer {
    display: grid;
    gap: 18px;
    margin-top: 42px;
    padding-top: 24px;
    border-top: 1px solid #e0d8cb;
  }
  .article-footer h2 {
    margin: 0 0 10px;
    color: #343331;
    font-size: 18px;
    line-height: 1.25;
  }
  .recommendation-list {
    display: grid;
    gap: 8px;
  }
  .recommendation-list span,
  .recommendation-list a {
    display: block;
    border-left: 3px solid #c4b9aa;
    padding: 8px 0 8px 12px;
    color: #4f4b45;
    font-size: 15px;
    line-height: 1.45;
    text-decoration: none;
  }
  .recommendation-list a:hover,
  .recommendation-list a:focus-visible {
    border-left-color: #3f625a;
    color: #3f625a;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  @media (max-width: 640px) {
    .article-shell {
      width: min(100% - 32px, 840px);
      padding-top: 18px;
    }
    .top-nav {
      margin-bottom: 38px;
    }
    .description,
    .article-body p,
    .article-body li,
    .article-body blockquote {
      font-size: 16px;
    }
    .visual-plan {
      grid-template-columns: 1fr;
    }
  }
</style>
