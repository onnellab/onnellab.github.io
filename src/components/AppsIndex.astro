---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProductIndexItems, type Locale } from '../lib/products';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const apps = getProductIndexItems(locale).sort(
  (a, b) => a.title.localeCompare(b.title)
);
const appCardStyle = (app: (typeof apps)[number]) =>
  `--accent-border: ${app.accent.border}; --accent-bg: ${app.accent.background}; --accent-text: ${app.accent.text};`;
const appCategory = (title: string) => {
  if (['TagWeaver', 'Melivra'].includes(title)) return 'Music';
  if (['VaultXT'].includes(title)) return 'Text';
  if (['Aligna', 'Segra'].includes(title)) return 'Files';
  if (['Quivra', 'ClipNest'].includes(title)) return 'Workflow';
  return 'Utility';
};
const categoryLabels =
  locale === 'ko'
    ? {
        Music: '음악',
        Text: '텍스트',
        Files: '파일',
        Workflow: '작업 흐름',
        Utility: '유틸리티'
      }
    : {
        Music: 'Music',
        Text: 'Text',
        Files: 'Files',
        Workflow: 'Workflow',
        Utility: 'Utility'
      };
const text =
  locale === 'ko'
    ? {
        title: 'ONNELLAB 앱',
        description: 'ONNELLAB이 만든 조용하고 가벼운 앱을 한곳에서 살펴보세요.',
        heading: '앱',
        searchLabel: '앱 찾기',
        searchPlaceholder: '앱 이름 검색',
        empty: '일치하는 앱이 없습니다.',
        switchLabel: 'English',
        switchHref: '/apps/',
        homeHref: '/ko/'
      }
    : {
        title: 'ONNELLAB Apps',
        description: 'Calm, lightweight apps by ONNELLAB.',
        heading: 'Apps',
        searchLabel: 'Find app',
        searchPlaceholder: 'Search app name',
        empty: 'No matching apps.',
        switchLabel: '한국어',
        switchHref: '/apps/ko/',
        homeHref: '/'
      };
const canonicalPath = locale === 'ko' ? '/apps/ko/' : '/apps/';
const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': new URL(`${canonicalPath}#collection`, Astro.site).toString(),
  name: text.title,
  description: text.description,
  url: new URL(canonicalPath, Astro.site).toString(),
  inLanguage: locale,
  isPartOf: {
    '@id': new URL('/#website', Astro.site).toString()
  },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: apps.map((app, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: app.title,
      url: new URL(app.href, Astro.site).toString()
    }))
  }
};
---

<BaseLayout
  title={text.title}
  description={text.description}
  canonicalPath={canonicalPath}
  lang={locale}
  jsonLd={collectionJsonLd}
  alternates={[
    { lang: 'en', path: '/apps/' },
    { lang: 'ko', path: '/apps/ko/' },
    { lang: 'x-default', path: '/apps/' }
  ]}
>
  <main class="page-shell">
    <nav aria-label="Navigation">
      <a class="brand" href={text.homeHref}>ONNELLAB</a>
      <a class="language" href={text.switchHref} data-locale-choice={locale === 'ko' ? 'en' : 'ko'}>{text.switchLabel}</a>
    </nav>

    <header>
      <h1>{text.heading}</h1>
      <p>{text.description}</p>
    </header>

    <label class="app-search">
      <span>{text.searchLabel}</span>
      <input type="search" placeholder={text.searchPlaceholder} data-app-search />
    </label>

    <p class="empty-state" data-app-empty hidden>{text.empty}</p>

    <section class="grid" aria-label={text.heading}>
      {apps.map((app) => (
        <a class="app-card" href={app.href} style={appCardStyle(app)} data-app-row data-app-title={app.title.toLowerCase()}>
          <img src={app.iconPath} alt={`${app.title} icon`} width="64" height="64" />
          <div>
            <h2>{app.title}</h2>
            <p>{app.description}</p>
            <div class="meta-row">
              <div class="meta-text">
                <span>{categoryLabels[appCategory(app.title)]}</span>
              </div>
              <div class="platform-badges" aria-label="Platforms">
                {app.platforms.map((platform) => <span>{platform}</span>)}
              </div>
            </div>
          </div>
        </a>
      ))}
    </section>
    <script is:inline>
      (() => {
        const appSearch = document.querySelector('[data-app-search]');
        const appRows = Array.from(document.querySelectorAll('[data-app-row]'));
        if (!(appSearch instanceof HTMLInputElement)) return;

        appSearch.addEventListener('input', () => {
          const query = appSearch.value.trim().toLowerCase();
          let visibleCount = 0;
          appRows.forEach((row) => {
            const title = row.getAttribute('data-app-title') ?? '';
            const isHidden = query.length > 0 && !title.includes(query);
            row.hidden = isHidden;
            if (!isHidden) visibleCount += 1;
          });
          const emptyState = document.querySelector('[data-app-empty]');
          if (emptyState instanceof HTMLElement) emptyState.hidden = visibleCount > 0;
        });
      })();
    </script>
  </main>
</BaseLayout>

<style>
  .page-shell {
    width: min(980px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 36px;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .brand,
  .language {
    text-decoration: none;
  }

  .brand {
    color: #737067;
    font-size: 14px;
    font-weight: 560;
  }

  .language {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    border: 1px solid #ded6ca;
    border-radius: 999px;
    padding: 6px 12px;
    background: rgba(255, 253, 248, 0.72);
    color: #5f5a50;
    font-size: 13px;
    font-weight: 650;
    line-height: 1.35;
  }

  .language:hover,
  .language:focus-visible {
    border-color: #cfc5b7;
    background: #fffdf8;
  }

  .language:focus-visible {
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }

  header {
    padding-top: 28px;
    position: relative;
  }

  header::after {
    content: "";
    display: block;
    width: 68px;
    height: 2px;
    margin-top: 18px;
    background: linear-gradient(90deg, #b9ad9d, rgba(207, 197, 183, 0));
  }

  h1 {
    margin: 12px 0 10px;
    font-size: clamp(38px, 6vw, 62px);
    line-height: 1;
    letter-spacing: 0;
  }

  header p {
    max-width: 560px;
    color: #5b574f;
    font-size: 18px;
    line-height: 1.6;
  }

  .app-search {
    display: grid;
    gap: 8px;
    max-width: 320px;
    margin-top: 28px;
    color: #6f695f;
    font-size: 13px;
    font-weight: 620;
  }

  .app-search input {
    min-height: 42px;
    border: 1px solid #ded6ca;
    border-radius: 8px;
    padding: 9px 12px;
    background: rgba(255, 253, 248, 0.74);
    color: #3f3b35;
    font: inherit;
    font-weight: 500;
  }

  .app-search input:focus {
    border-color: #cfc5b7;
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }

  .empty-state {
    border-top: 1px solid #e0d8cb;
    border-bottom: 1px solid #e0d8cb;
    margin: 18px 0 0;
    padding: 18px 0;
    color: #827d72;
    font-size: 14px;
    line-height: 1.5;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 18px;
  }

  .app-card {
    position: relative;
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr);
    align-items: start;
    gap: 16px;
    border: 1px solid var(--accent-border, #e0d8cb);
    border-radius: 8px;
    min-height: 100px;
    padding: 15px;
    background:
      linear-gradient(135deg, rgba(255, 253, 248, 0.94), var(--accent-bg, #fffdf8)),
      #fffdf8;
    color: inherit;
    text-decoration: none;
    transition: border-color 140ms ease, background 140ms ease, color 140ms ease;
  }

  .app-card::before {
    content: "";
    position: absolute;
    inset: 1px;
    border-radius: 7px;
    border-top: 1px solid rgba(255, 253, 248, 0.86);
    pointer-events: none;
  }

  .app-card::after {
    display: none;
  }

  .app-card[hidden] {
    display: none;
  }

  .app-card:hover,
  .app-card:focus-visible {
    border-color: var(--accent-border, #d8cec0);
    background:
      linear-gradient(135deg, #fffdf8, var(--accent-bg, #fffdf8)),
      #fffdf8;
  }

  .app-card:focus-visible {
    outline: 2px solid #b8ad9f;
    outline-offset: 3px;
  }

  img {
    width: 42px;
    height: 42px;
    border-radius: 11px;
    box-shadow: 0 0 0 1px var(--accent-border, #ddd5c8);
  }

  h2 {
    margin: 0 0 5px;
    font-size: 18px;
    line-height: 1.25;
    letter-spacing: 0;
    transition: color 140ms ease;
  }

  .app-card:hover h2,
  .app-card:focus-visible h2 {
    color: var(--accent-text, #5f5a50);
  }

  p {
    margin: 0;
    color: #4f4b43;
    font-size: 15px;
    line-height: 1.5;
  }

  .meta-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 8px 12px;
    margin-top: 11px;
  }

  .meta-text {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 7px;
  }

  .meta-text span {
    color: #5f5a50;
    font-size: 12px;
    font-weight: 560;
    line-height: 1.4;
  }

  .platform-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .platform-badges span {
    border: 1px solid var(--accent-border, #ddd5c8);
    border-radius: 999px;
    padding: 2px 7px;
    background: var(--accent-bg, #faf8f5);
    color: var(--accent-text, #827d72);
    font-size: 12px;
    line-height: 1.4;
  }

  @media (max-width: 680px) {
    .page-shell {
      width: min(100% - 28px, 980px);
      padding-top: 24px;
    }

    header {
      padding-top: 30px;
    }

    header::after {
      width: 56px;
      margin-top: 16px;
    }

    h1 {
      font-size: clamp(36px, 12vw, 50px);
      line-height: 1.04;
    }

    header p {
      font-size: 16px;
      line-height: 1.58;
    }

    .grid {
      grid-template-columns: 1fr;
      gap: 10px;
      margin-top: 18px;
    }

    .app-card {
      grid-template-columns: 46px minmax(0, 1fr);
      gap: 13px;
      min-height: auto;
      padding: 15px;
      background:
        linear-gradient(135deg, #fffdf8 24%, var(--accent-bg, #fffdf8)),
        #fffdf8;
    }

    img {
      width: 44px;
      height: 44px;
      border-radius: 12px;
    }
  }
</style>
