---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProductIndexItems, type Locale } from '../lib/products';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const apps = getProductIndexItems(locale);
const featuredApp = apps.find((app) => app.title === 'TagWeaver') ?? apps[0];
const listedApps = apps.filter((app) => app.slug !== featuredApp?.slug);
const appCardStyle = (app: (typeof apps)[number]) =>
  `--accent-border: ${app.accent.border}; --accent-bg: ${app.accent.background}; --accent-text: ${app.accent.text};`;
const text =
  locale === 'ko'
    ? {
        title: 'ONNELLAB 앱',
        description: 'ONNELLAB이 만든 조용하고 가벼운 앱을 한곳에서 살펴보세요.',
        heading: '앱',
        featured: '대표 앱',
        open: '열기',
        switchLabel: 'English',
        switchHref: '/apps/',
        homeHref: '/ko/'
      }
    : {
        title: 'ONNELLAB Apps',
        description: 'Calm, lightweight apps by ONNELLAB.',
        heading: 'Apps',
        featured: 'Featured App',
        open: 'Open',
        switchLabel: '한국어',
        switchHref: '/apps/ko/',
        homeHref: '/'
      };
---

<BaseLayout
  title={text.title}
  description={text.description}
  canonicalPath={locale === 'ko' ? '/apps/ko/' : '/apps/'}
  lang={locale}
  alternates={[
    { lang: 'en', path: '/apps/' },
    { lang: 'ko', path: '/apps/ko/' },
    { lang: 'x-default', path: '/apps/' }
  ]}
>
  <main class="page-shell">
    <nav aria-label="Navigation">
      <a class="brand" href={text.homeHref}>ONNELLAB</a>
      <a class="language" href={text.switchHref}>{text.switchLabel}</a>
    </nav>

    <header>
      <h1>{text.heading}</h1>
      <p>{text.description}</p>
    </header>

    {featuredApp && (
      <section class="featured-app" aria-label={text.featured} style={appCardStyle(featuredApp)}>
        <div class="featured-copy">
          <span>{text.featured}</span>
          <div class="featured-title">
            <img src={featuredApp.iconPath} alt={`${featuredApp.title} icon`} width="64" height="64" />
            <div>
              <h2>{featuredApp.title}</h2>
              <p>{featuredApp.description}</p>
            </div>
          </div>
          <div class="meta-row">
            <span>{featuredApp.status}</span>
            <div class="platform-badges" aria-label="Platforms">
              {featuredApp.platforms.map((platform) => <span>{platform}</span>)}
            </div>
          </div>
          <a href={featuredApp.href}>{text.open}</a>
        </div>
      </section>
    )}

    <section class="grid" aria-label={text.heading}>
      {listedApps.map((app) => (
        <article style={appCardStyle(app)}>
          <img src={app.iconPath} alt={`${app.title} icon`} width="64" height="64" />
          <div>
            <h2>{app.title}</h2>
            <p>{app.description}</p>
            <div class="meta-row">
              <span>{app.status}</span>
              <div class="platform-badges" aria-label="Platforms">
                {app.platforms.map((platform) => <span>{platform}</span>)}
              </div>
            </div>
          </div>
          <a href={app.href}>{text.open}</a>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  .page-shell {
    width: min(980px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 36px;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .brand,
  .language {
    text-decoration: none;
  }

  .brand {
    color: #737067;
    font-size: 14px;
    font-weight: 650;
  }

  .language {
    border: 1px solid #ddd5c8;
    border-radius: 8px;
    padding: 8px 12px;
    background: #fffdf8;
    font-size: 14px;
  }

  header {
    padding-top: 42px;
  }

  h1 {
    margin: 12px 0 10px;
    font-size: clamp(42px, 7vw, 72px);
    line-height: 1;
    letter-spacing: 0;
  }

  header p {
    max-width: 560px;
    color: #5b574f;
    font-size: 18px;
    line-height: 1.6;
  }

  .grid {
    display: grid;
    gap: 0;
    border-top: 1px solid #e0d8cb;
    border-bottom: 1px solid #e0d8cb;
    margin-top: 24px;
  }

  .featured-app {
    border: 1px solid var(--accent-border);
    border-radius: 8px;
    margin-top: 34px;
    padding: 22px;
    background: linear-gradient(90deg, var(--accent-bg), #fffdf8 74%);
  }

  .featured-copy > span {
    color: var(--accent-text);
    font-size: 13px;
    font-weight: 650;
  }

  .featured-title {
    display: grid;
    grid-template-columns: 64px minmax(0, 1fr);
    align-items: center;
    gap: 16px;
    margin-top: 12px;
  }

  article {
    display: grid;
    grid-template-columns: 54px 1fr auto;
    align-items: center;
    gap: 16px;
    border-bottom: 1px solid #e9e1d5;
    padding: 15px 0;
  }

  article a {
    justify-self: start;
  }

  img {
    border-radius: 16px;
    background: #eee8dd;
  }

  h2 {
    margin: 0 0 6px;
    font-size: 20px;
    letter-spacing: 0;
  }

  p {
    margin: 0;
    color: #4f4b43;
    font-size: 16px;
    line-height: 1.6;
  }

  .meta-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 8px;
  }

  .meta-row > span {
    color: #827d72;
    font-size: 13px;
  }

  .platform-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .platform-badges span {
    border: 1px solid var(--accent-border, #ddd5c8);
    border-radius: 999px;
    padding: 2px 7px;
    background: var(--accent-bg, #faf8f5);
    color: var(--accent-text, #827d72);
    font-size: 12px;
    line-height: 1.4;
  }

  article a {
    border: 1px solid var(--accent-border, #d6cec0);
    border-radius: 8px;
    padding: 9px 12px;
    background: #faf8f5;
    text-decoration: none;
    font-weight: 620;
  }

  article:last-child {
    border-bottom: 0;
  }

  @media (max-width: 680px) {
    .page-shell {
      width: min(100% - 24px, 980px);
    }

    .grid {
      grid-template-columns: 1fr;
    }

    article {
      grid-template-columns: 56px 1fr;
    }

    img {
      width: 56px;
      height: 56px;
      border-radius: 14px;
    }

    article a {
      grid-column: 1 / -1;
      text-align: center;
      justify-self: stretch;
    }
  }
</style>
