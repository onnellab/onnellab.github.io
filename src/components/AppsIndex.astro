---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProductIndexItems, type Locale } from '../lib/products';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const privacyUpdatedAtByTitle: Record<string, string> = {
  Quivra: '2026-02-10',
  TagWeaver: '2026-02-14',
  VaultXT: '2026-03-11',
  Segra: '2026-06-12',
  ClipNest: '2026-06-13',
  Aligna: '2026-06-24',
  Melivra: '2026-06-24'
};
const privacyDate = (title: string) => privacyUpdatedAtByTitle[title] ?? '9999-12-31';
const apps = getProductIndexItems(locale).sort(
  (a, b) => privacyDate(a.title).localeCompare(privacyDate(b.title)) || a.title.localeCompare(b.title)
);
const appCardStyle = (app: (typeof apps)[number]) =>
  `--accent-border: ${app.accent.border}; --accent-bg: ${app.accent.background}; --accent-text: ${app.accent.text};`;
const appCategory = (title: string) => {
  if (['TagWeaver', 'Melivra'].includes(title)) return 'Music';
  if (['VaultXT'].includes(title)) return 'Text';
  if (['Aligna', 'Segra'].includes(title)) return 'Files';
  if (['Quivra', 'ClipNest'].includes(title)) return 'Workflow';
  return 'Utility';
};
const categoryLabels =
  locale === 'ko'
    ? {
        Music: '음악',
        Text: '텍스트',
        Files: '파일',
        Workflow: '작업 흐름',
        Utility: '유틸리티'
      }
    : {
        Music: 'Music',
        Text: 'Text',
        Files: 'Files',
        Workflow: 'Workflow',
        Utility: 'Utility'
      };
const text =
  locale === 'ko'
    ? {
        title: 'ONNELLAB 앱',
        description: 'ONNELLAB이 만든 조용하고 가벼운 앱을 한곳에서 살펴보세요.',
        heading: 'ONNELLAB 앱',
        switchLabel: 'English',
        switchHref: '/apps/',
        homeHref: '/ko/'
      }
    : {
        title: 'ONNELLAB Apps',
        description: 'Calm, lightweight apps by ONNELLAB.',
        heading: 'Apps',
        switchLabel: '한국어',
        switchHref: '/apps/ko/',
        homeHref: '/'
      };
---

<BaseLayout
  title={text.title}
  description={text.description}
  canonicalPath={locale === 'ko' ? '/apps/ko/' : '/apps/'}
  lang={locale}
  alternates={[
    { lang: 'en', path: '/apps/' },
    { lang: 'ko', path: '/apps/ko/' },
    { lang: 'x-default', path: '/apps/' }
  ]}
>
  <main class="page-shell">
    <nav aria-label="Navigation">
      <a class="brand" href={text.homeHref}>ONNELLAB</a>
      <a class="language" href={text.switchHref}>{text.switchLabel}</a>
    </nav>

    <header>
      <h1>{text.heading}</h1>
      <p>{text.description}</p>
    </header>

    <section class="grid" aria-label={text.heading}>
      {apps.map((app) => (
        <a class="app-card" href={app.href} style={appCardStyle(app)}>
          <img src={app.iconPath} alt={`${app.title} icon`} width="64" height="64" />
          <div>
            <h2>{app.title}</h2>
            <p>{app.description}</p>
            <div class="meta-row">
              <div class="meta-text">
                <span>{categoryLabels[appCategory(app.title)]}</span>
                <span>{app.status}</span>
              </div>
              <div class="platform-badges" aria-label="Platforms">
                {app.platforms.map((platform) => <span>{platform}</span>)}
              </div>
            </div>
          </div>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  .page-shell {
    width: min(980px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 36px;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .brand,
  .language {
    text-decoration: none;
  }

  .brand {
    color: #737067;
    font-size: 14px;
    font-weight: 650;
  }

  .language {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    border: 1px solid #ded6ca;
    border-radius: 999px;
    padding: 6px 12px;
    background: rgba(255, 253, 248, 0.72);
    color: #5f5a50;
    font-size: 13px;
    font-weight: 650;
    line-height: 1.35;
  }

  .language:hover,
  .language:focus-visible {
    border-color: #cfc5b7;
    background: #fffdf8;
  }

  .language:focus-visible {
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }

  header {
    padding-top: 42px;
  }

  h1 {
    margin: 12px 0 10px;
    font-size: clamp(42px, 7vw, 72px);
    line-height: 1;
    letter-spacing: 0;
  }

  header p {
    max-width: 560px;
    color: #5b574f;
    font-size: 18px;
    line-height: 1.6;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 36px;
  }

  .app-card {
    display: grid;
    grid-template-columns: 64px 1fr;
    align-items: start;
    gap: 16px;
    border: 1px solid var(--accent-border, #e0d8cb);
    border-radius: 8px;
    padding: 16px;
    background: #fffdf8;
    color: inherit;
    text-decoration: none;
    transition: border-color 140ms ease, background 140ms ease;
  }

  .app-card:hover,
  .app-card:focus-visible {
    border-color: var(--accent-border);
    background: var(--accent-bg, #fffdf8);
  }

  .app-card:focus-visible {
    outline: 2px solid #b8ad9f;
    outline-offset: 3px;
  }

  img {
    border-radius: 16px;
    background: #eee8dd;
  }

  h2 {
    margin: 0 0 6px;
    font-size: 20px;
    letter-spacing: 0;
  }

  p {
    margin: 0;
    color: #4f4b43;
    font-size: 16px;
    line-height: 1.6;
  }

  .meta-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 8px 12px;
    margin-top: 11px;
  }

  .meta-text {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 7px;
  }

  .meta-text span {
    color: #827d72;
    font-size: 12px;
    line-height: 1.4;
  }

  .meta-text span + span::before {
    content: "";
    display: inline-block;
    width: 3px;
    height: 3px;
    margin: 0 7px 2px 0;
    border-radius: 50%;
    background: #c7beb1;
  }

  .platform-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .platform-badges span {
    border: 1px solid var(--accent-border, #ddd5c8);
    border-radius: 999px;
    padding: 2px 7px;
    background: var(--accent-bg, #faf8f5);
    color: var(--accent-text, #827d72);
    font-size: 12px;
    line-height: 1.4;
  }

  @media (max-width: 680px) {
    .page-shell {
      width: min(100% - 28px, 980px);
      padding-top: 24px;
    }

    header {
      padding-top: 36px;
    }

    h1 {
      font-size: clamp(40px, 14vw, 58px);
    }

    header p {
      font-size: 16px;
      line-height: 1.58;
    }

    .grid {
      grid-template-columns: 1fr;
      gap: 10px;
      margin-top: 28px;
    }

    .app-card {
      grid-template-columns: 56px 1fr;
      gap: 14px;
      padding: 15px;
    }

    img {
      width: 56px;
      height: 56px;
      border-radius: 14px;
    }
  }
</style>
