---
import BaseLayout from '../layouts/BaseLayout.astro';
import { landingSubtitle, pageBodyDescription, renderBlocks, type ProductPageData } from '../lib/products';

type Props = {
  data: ProductPageData;
};

const { data } = Astro.props;
const { meta, copy } = data;
const labels =
  data.locale === 'ko'
    ? {
        switchLabel: 'English',
        platforms: '지원 플랫폼',
        appStore: 'App Store',
        googlePlay: 'Google Play',
        privacy: 'Privacy Policy',
        support: 'Support',
        download: '다운로드',
        stores: '스토어',
        status: '상태'
      }
    : {
        switchLabel: '한국어',
        platforms: 'Platforms',
        appStore: 'App Store',
        googlePlay: 'Google Play',
        privacy: 'Privacy Policy',
        support: 'Support',
        download: 'Download',
        stores: 'Stores',
        status: 'Status'
      };

const bodyBlocks = renderBlocks(pageBodyDescription(copy));
const heroIntro = landingSubtitle(copy);
const heroSignals =
  (bodyBlocks.find((block) => block.type === 'ul')?.value as string[] | undefined)?.slice(0, 3) ?? [];
const homePath = data.locale === 'ko' ? '/ko/' : '/';
const pageStyle = `--accent-border: ${data.accent.border}; --accent-bg: ${data.accent.background}; --accent-text: ${data.accent.text};`;
const iconUrl = new URL(data.iconPath, Astro.site);
const canonicalUrl = new URL(data.canonicalPath, Astro.site);
const alternateUrl = new URL(data.alternatePath, Astro.site);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: meta.title,
  operatingSystem: meta.platforms.join(', '),
  applicationSubCategory: copy.android.name || copy.ios.name,
  description: data.seoDescription,
  image: iconUrl.toString(),
  downloadUrl: [meta.appstore, meta.googleplay].filter(Boolean),
  url: canonicalUrl.toString()
};
---

<BaseLayout
  title={data.seoTitle}
  description={data.seoDescription}
  canonicalPath={data.canonicalPath}
  lang={data.locale}
  image={data.iconPath}
  jsonLd={jsonLd}
>
  <link slot="head" rel="alternate" hreflang={data.locale === 'en' ? 'ko' : 'en'} href={alternateUrl} />

  <main class="page-shell" style={pageStyle}>
    <header class="topbar" aria-label="ONNELLAB">
      <a class="brand" href={homePath}>ONNELLAB</a>
      <a class="language" href={data.alternatePath}>{labels.switchLabel}</a>
    </header>

    <section class="hero" aria-labelledby="product-title">
      <div class="hero-grid">
        <div class="identity">
          <img src={data.iconPath} alt={`${meta.title} icon`} width="88" height="88" />
          <div>
            <p class="eyebrow">{labels.status}: {meta.status}</p>
            <h1 id="product-title">{meta.title}</h1>
            {heroIntro && <p class="intro">{heroIntro}</p>}
          </div>
        </div>

        {heroSignals.length > 0 && (
          <div class="task-preview" aria-hidden="true">
            {heroSignals.map((signal, index) => (
              <div class="task-row">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <strong>{signal}</strong>
              </div>
            ))}
          </div>
        )}
      </div>

      <div class="actions" aria-label={labels.stores}>
        <a class="button primary" href={meta.appstore}>{labels.appStore}</a>
        {meta.googleplay && <a class="button primary" href={meta.googleplay}>{labels.googlePlay}</a>}
        <a class="button" href={meta.privacy}>{labels.privacy}</a>
        <a class="button" href={`mailto:${meta.supportEmail}`}>{labels.support}</a>
      </div>

      <dl class="meta-list">
        <div class="meta-pill">
          <dt>{labels.platforms}</dt>
          <dd>
            {meta.platforms.map((platform) => <span>{platform}</span>)}
          </dd>
        </div>
      </dl>
    </section>

    <section class="content-band" aria-label={copy.android.name ?? copy.ios.name ?? meta.title}>
      <div class="copy-column">
        {bodyBlocks.map((block) => (
          block.type === 'h' ? (
            <h2>{block.value}</h2>
          ) : block.type === 'ul' ? (
            <ul>
              {(block.value as string[]).map((item) => <li>{item}</li>)}
            </ul>
          ) : (
            <p>{block.value}</p>
          )
        ))}
      </div>
    </section>

    <section class="download-band" aria-label={labels.download}>
      <div>
        <p class="eyebrow">{labels.download}</p>
        <h2>{meta.title}</h2>
      </div>
      <div class="actions compact" aria-label={labels.stores}>
        <a class="button primary" href={meta.appstore}>{labels.appStore}</a>
        {meta.googleplay && <a class="button primary" href={meta.googleplay}>{labels.googlePlay}</a>}
        <a class="button" href={meta.privacy}>{labels.privacy}</a>
      </div>
    </section>

    <footer>
      <span>{meta.title}</span>
      <a href={meta.privacy}>{labels.privacy}</a>
      <a href={`mailto:${meta.supportEmail}`}>{meta.supportEmail}</a>
    </footer>
  </main>
</BaseLayout>

<style>
  .page-shell {
    width: min(980px, calc(100% - 32px));
    margin: 0 auto;
    padding: 22px 0 28px;
  }

  .topbar,
  footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    color: #737067;
    font-size: 14px;
  }

  .brand,
  .language,
  footer a {
    text-decoration: none;
  }

  .brand {
    font-weight: 650;
    color: #37342f;
  }

  .language {
    border: 1px solid #ddd5c8;
    border-radius: 8px;
    padding: 8px 12px;
    background: #fffdf8;
  }

  .hero {
    min-height: calc(100vh - 64px);
    display: grid;
    align-content: center;
    gap: 24px;
    padding: 76px 0 58px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(220px, 300px);
    align-items: center;
    gap: 28px;
  }

  .identity {
    display: grid;
    grid-template-columns: 112px minmax(0, 1fr);
    align-items: start;
    gap: 28px;
  }

  .identity img {
    width: 112px;
    height: 112px;
    border-radius: 22px;
    background: #eee8dd;
    box-shadow: 0 0 0 1px var(--accent-border);
  }

  .eyebrow {
    margin: 0 0 8px;
    color: #827d72;
    font-size: 13px;
    font-weight: 600;
  }

  h1 {
    margin: 0;
    font-size: clamp(52px, 10vw, 96px);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .intro {
    max-width: 560px;
    margin: 18px 0 0;
    color: #5b574f;
    font-size: 19px;
    line-height: 1.55;
  }

  .task-preview {
    border-left: 1px solid var(--accent-border);
    padding-left: 22px;
  }

  .task-row {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr);
    gap: 12px;
    padding: 11px 0;
    border-bottom: 1px solid #e7dfd3;
  }

  .task-row:first-child {
    border-top: 1px solid #e7dfd3;
  }

  .task-row span {
    color: var(--accent-text);
    font-size: 12px;
    font-weight: 700;
  }

  .task-row strong {
    color: #464139;
    font-size: 15px;
    font-weight: 650;
    line-height: 1.45;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-left: 140px;
  }

  .button {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #d6cec0;
    border-radius: 8px;
    padding: 10px 15px;
    background: #fffdf8;
    color: #37342f;
    text-decoration: none;
    font-weight: 620;
  }

  .button.primary {
    background: #3a3630;
    border-color: var(--accent-text);
    color: #fffaf0;
  }

  .meta-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 2px 0 0 140px;
  }

  .meta-pill {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    border: 1px solid var(--accent-border);
    border-radius: 8px;
    padding: 8px 11px;
    background: var(--accent-bg);
  }

  dt {
    color: #827d72;
    font-size: 13px;
  }

  dd {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin: 0;
    color: #464139;
    font-weight: 600;
  }

  dd span {
    border: 1px solid var(--accent-border);
    border-radius: 999px;
    padding: 2px 7px;
    background: #fffdf8;
    color: var(--accent-text);
    font-size: 12px;
    line-height: 1.4;
  }

  .content-band,
  .download-band {
    border-top: 1px solid #e0d8cb;
    padding: 44px 0;
  }

  .download-band {
    display: grid;
    justify-items: center;
    gap: 18px;
    text-align: center;
  }

  .download-band h2 {
    margin: 0;
  }

  .actions.compact {
    justify-content: center;
    margin-left: 0;
  }

  .copy-column {
    max-width: 720px;
  }

  h2 {
    margin: 28px 0 12px;
    font-size: 22px;
    line-height: 1.25;
    letter-spacing: 0;
  }

  h3 {
    margin: 0 0 12px;
    font-size: 20px;
    line-height: 1.3;
    letter-spacing: 0;
  }

  p,
  li {
    color: #4f4b43;
    font-size: 17px;
    line-height: 1.7;
  }

  ul {
    margin: 14px 0 0;
    padding-left: 20px;
  }

  footer {
    border-top: 1px solid #e0d8cb;
    padding-top: 20px;
    flex-wrap: wrap;
  }

  @media (max-width: 680px) {
    .page-shell {
      width: min(100% - 24px, 980px);
    }

    .hero {
      min-height: auto;
      padding: 52px 0 36px;
    }

    .identity,
    .actions,
    .hero-grid {
      display: grid;
      grid-template-columns: 1fr;
    }

    .identity {
      gap: 18px;
    }

    .identity img {
      width: 88px;
      height: 88px;
    }

    .actions,
    .meta-list {
      margin-left: 0;
    }

    .task-preview {
      border-left: 0;
      padding-left: 0;
    }

    .actions.compact {
      justify-content: stretch;
    }

    .button {
      width: 100%;
    }
  }
</style>
