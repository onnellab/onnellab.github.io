---
import BaseLayout from '../layouts/BaseLayout.astro';
import { landingSubtitle, pageBodyDescription, renderBlocks, type ProductPageData } from '../lib/products';

type Props = {
  data: ProductPageData;
};

const { data } = Astro.props;
const { meta, copy } = data;
const labels =
  data.locale === 'ko'
    ? {
        switchLabel: 'English',
        platforms: '지원 플랫폼',
        appStore: 'App Store',
        googlePlay: 'Google Play',
        privacy: '개인정보 처리방침',
        footerPrivacy: '개인정보 처리방침',
        support: '문의하기',
        download: '다운로드',
        screens: '스크린샷',
        stores: '스토어'
      }
    : {
        switchLabel: '한국어',
        platforms: 'Platforms',
        appStore: 'App Store',
        googlePlay: 'Google Play',
        privacy: 'Privacy Policy',
        footerPrivacy: 'Privacy Policy',
        support: 'Contact',
        download: 'Download',
        screens: 'Screenshots',
        stores: 'Stores'
      };

const bodyBlocks = renderBlocks(pageBodyDescription(copy));
const heroIntro = landingSubtitle(copy);
const heroSignals =
  (bodyBlocks.find((block) => block.type === 'ul')?.value as string[] | undefined)?.slice(0, 3) ?? [];
const homePath = data.locale === 'ko' ? '/ko/' : '/';
const appsPath = data.locale === 'ko' ? '/apps/ko/' : '/apps/';
const pageStyle = `--accent-border: ${data.accent.border}; --accent-bg: ${data.accent.background}; --accent-text: ${data.accent.text};`;
const iconUrl = new URL(data.iconPath, Astro.site);
const canonicalUrl = new URL(data.canonicalPath, Astro.site);
const enPath = `/apps/${data.source.slug}/`;
const koPath = `/apps/${data.source.slug}/ko/`;
const offerPriceCurrency = meta.priceCurrency ?? (meta.price === 0 ? 'USD' : undefined);
const localizedAppStoreUrl = (url: string, locale: ProductPageData['locale']) => {
  const storeCountry = locale === 'ko' ? 'kr' : 'us';
  const language = locale === 'ko' ? 'ko' : 'en-US';
  const appStoreUrl = new URL(url);
  appStoreUrl.pathname = appStoreUrl.pathname.replace(/^\/(?:[a-z]{2}\/)?app\//, `/${storeCountry}/app/`);
  appStoreUrl.searchParams.set('l', language);
  return appStoreUrl.toString();
};
const localizedGooglePlayUrl = (url: string | undefined, locale: ProductPageData['locale']) => {
  if (!url) return undefined;
  const playStoreUrl = new URL(url);
  playStoreUrl.searchParams.set('hl', locale === 'ko' ? 'ko' : 'en');
  playStoreUrl.searchParams.set('gl', locale === 'ko' ? 'KR' : 'US');
  return playStoreUrl.toString();
};
const localizedPrivacyUrl = (url: string, locale: ProductPageData['locale']) => {
  if (locale !== 'ko') return url;
  const privacyUrl = new URL(url);
  privacyUrl.pathname = privacyUrl.pathname.replace(/\/?$/, '/ko/');
  return privacyUrl.toString();
};
const appStoreUrl = localizedAppStoreUrl(meta.appstore, data.locale);
const googlePlayUrl = localizedGooglePlayUrl(meta.googleplay, data.locale);
const privacyUrl = localizedPrivacyUrl(meta.privacy, data.locale);
const storeUrls = [appStoreUrl, googlePlayUrl].filter(Boolean);
const landingScreenshotPaths = data.screenshotPaths;
const hasScreenshotCarousel = landingScreenshotPaths.length > 3;
const screenshotUrls = landingScreenshotPaths.map((screenshotPath) =>
  new URL(screenshotPath, Astro.site).toString()
);
const tagweaverUseCaseContent = data.locale === 'ko'
  ? {
      title: '이럴 때 사용해요',
      items: [
        '가지고 있는 파일의 제목, 아티스트, 앨범 정보를 직접 정리하고 싶을 때',
        '앨범 아트, 가사, 평점처럼 파일 안에 저장된 정보를 확인하고 수정하고 싶을 때',
        '자동 정리 없이 사용자가 확인한 변경사항만 저장하고 싶을 때'
      ]
    }
  : {
      title: 'Use cases',
      items: [
        'Clean up title, artist, and album metadata in files you already own',
        'Review and edit artwork, lyrics, and rating stored inside audio files',
        'Save only the fields you checked and changed, without automatic library changes'
      ]
    };
const useCaseContent = data.source.slug === 'tagweaver' ? tagweaverUseCaseContent : undefined;
const faqContent = copy.android.faq ?? copy.ios.faq;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  '@id': `${canonicalUrl.toString()}#softwareapplication`,
  name: meta.title,
  url: canonicalUrl.toString(),
  mainEntityOfPage: canonicalUrl.toString(),
  operatingSystem: meta.platforms.join(', '),
  applicationCategory: 'UtilitiesApplication',
  applicationSubCategory: copy.android.name || copy.ios.name,
  description: data.seoDescription,
  inLanguage: data.locale,
  image: iconUrl.toString(),
  isAccessibleForFree: meta.price === 0,
  ...(heroSignals.length > 0 ? { featureList: heroSignals } : {}),
  ...(screenshotUrls.length > 0 ? { screenshot: screenshotUrls } : {}),
  downloadUrl: storeUrls,
  installUrl: storeUrls,
  sameAs: storeUrls,
  softwareHelp: `mailto:${meta.supportEmail}`,
  publisher: {
    '@type': 'Organization',
    '@id': new URL('/#organization', Astro.site).toString(),
    name: 'ONNELLAB',
    url: new URL('/', Astro.site).toString()
  },
  ...(meta.price !== undefined
    ? {
        offers: {
          '@type': 'Offer',
          price: meta.price,
          ...(offerPriceCurrency ? { priceCurrency: offerPriceCurrency } : {}),
          ...(meta.pricing ? { description: meta.pricing } : {}),
          url: canonicalUrl.toString()
        }
      }
    : {}),
  privacyPolicy: privacyUrl
};
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${canonicalUrl.toString()}#breadcrumb`,
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'ONNELLAB',
      item: new URL(homePath, Astro.site).toString()
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: labels.download,
      item: new URL(appsPath, Astro.site).toString()
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: meta.title,
      item: canonicalUrl.toString()
    }
  ]
};
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${canonicalUrl.toString()}#faq`,
  mainEntity: (faqContent?.items ?? []).map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};
---

<BaseLayout
  title={data.seoTitle}
  description={data.seoDescription}
  canonicalPath={data.canonicalPath}
  lang={data.locale}
  image={data.iconPath}
  jsonLd={faqContent ? [jsonLd, breadcrumbJsonLd, faqJsonLd] : [jsonLd, breadcrumbJsonLd]}
  alternates={[
    { lang: 'en', path: enPath },
    { lang: 'ko', path: koPath },
    { lang: 'x-default', path: enPath }
  ]}
>
  <main class="page-shell" style={pageStyle} data-product-slug={data.source.slug} data-product-locale={data.locale}>
    <header class="topbar" aria-label="ONNELLAB">
      <a class="brand" href={homePath}>ONNELLAB</a>
      <a class="language" href={data.alternatePath} data-locale-choice={data.locale === 'ko' ? 'en' : 'ko'} aria-label={data.locale === 'ko' ? 'Switch to English' : '한국어로 보기'} title={data.locale === 'ko' ? 'English' : '한국어'}>{labels.switchLabel}</a>
    </header>

    <section class="hero" aria-labelledby="product-title" data-app={data.source.slug}>
      <div class="hero-grid">
        <div class="identity">
          <img src={data.iconPath} alt={`${meta.title} icon`} width="88" height="88" data-no-visual-search="true" />
          <div>
            <h1 id="product-title">{meta.title}</h1>
            {heroIntro && <p class="intro">{heroIntro}</p>}
          </div>
        </div>

        {heroSignals.length > 0 && (
          <div class="task-preview" aria-hidden="true">
            {heroSignals.map((signal, index) => (
              <div class="task-row">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <strong>{signal}</strong>
              </div>
            ))}
          </div>
        )}
      </div>

      <div class="hero-actions">
        <div class="actions store-actions" aria-label={labels.stores}>
          <a class="button primary" href={appStoreUrl} data-store-link data-store="app_store" data-store-position="hero">{labels.appStore}</a>
          {googlePlayUrl && <a class="button primary" href={googlePlayUrl} data-store-link data-store="google_play" data-store-position="hero">{labels.googlePlay}</a>}
        </div>
        <div class="support-links" aria-label="Contact links">
          <a href={privacyUrl}>{labels.privacy}</a>
          <a href={`mailto:${meta.supportEmail}`}>{labels.support}</a>
        </div>
      </div>

      <dl class="meta-list">
        <div class="meta-pill">
          <dt>{labels.platforms}</dt>
          <dd>
            {meta.platforms.map((platform) => <span>{platform}</span>)}
          </dd>
        </div>
      </dl>
    </section>

    <section class="content-band" aria-label={copy.android.name ?? copy.ios.name ?? meta.title}>
      <div class="copy-column">
        {bodyBlocks.map((block) => (
          block.type === 'h' ? (
            <h2>{block.value}</h2>
          ) : block.type === 'ul' ? (
            <ul>
              {(block.value as string[]).map((item) => <li>{item}</li>)}
            </ul>
          ) : (
            <p>{block.value}</p>
          )
        ))}
      </div>
    </section>

    {useCaseContent && (
      <section class="use-cases-band" aria-labelledby="use-cases-title">
        <h2 id="use-cases-title">{useCaseContent.title}</h2>
        <ul class="use-case-list">
          {useCaseContent.items.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    )}

    {faqContent && (
      <section class="faq-band" aria-labelledby="faq-title">
        <h2 id="faq-title">{faqContent.title}</h2>
        <div class="faq-list">
          {faqContent.items.map((item) => (
            <details>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    {landingScreenshotPaths.length > 0 && (
      <details class="screens-band" open>
        <summary>{labels.screens}</summary>
        <div class="screenshot-carousel" data-screenshot-carousel>
          {hasScreenshotCarousel && (
            <button class="screenshot-step screenshot-step-prev" type="button" data-screenshot-prev aria-label="Previous screenshot">‹</button>
          )}
          <div class="screenshot-row" data-screenshot-row>
          {landingScreenshotPaths.map((screenshotPath, index) => (
            <figure>
              <a
                class="screenshot-link"
                href={screenshotPath}
                data-screenshot-link
                data-screenshot-index={index}
                aria-label={`${meta.title} ${labels.screens} ${index + 1}`}
              >
                <img
                  src={screenshotPath}
                  alt={`${meta.title} ${labels.screens} ${index + 1}`}
                  width="1242"
                  height="2688"
                  loading="lazy"
                  decoding="async"
                  data-no-visual-search="true"
                />
              </a>
            </figure>
          ))}
          </div>
          {hasScreenshotCarousel && (
            <button class="screenshot-step screenshot-step-next" type="button" data-screenshot-next aria-label="Next screenshot">›</button>
          )}
          {hasScreenshotCarousel && (
            <div class="screenshot-progress" aria-label={labels.screens}>
              <span data-screenshot-count aria-live="polite">1 / {landingScreenshotPaths.length}</span>
            </div>
          )}
        </div>
        <dialog class="screenshot-viewer" aria-label={labels.screens}>
          <div class="viewer-panel">
            <div class="viewer-bar">
              <button class="viewer-close" type="button" data-viewer-close aria-label="Close">×</button>
            </div>
            <div class="viewer-frame">
              <button class="viewer-nav viewer-prev" type="button" data-viewer-prev aria-label="Previous">‹</button>
              <div class="viewer-image-stage" data-viewer-stage>
                <img
                  src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw=="
                  data-viewer-image
                  data-no-visual-search="true"
                  alt=""
                  hidden
                />
              </div>
              <button class="viewer-nav viewer-next" type="button" data-viewer-next aria-label="Next">›</button>
            </div>
            <div class="viewer-thumbs" aria-label={labels.screens}>
              {landingScreenshotPaths.map((screenshotPath, index) => (
                <button
                  class="viewer-thumb"
                  type="button"
                  data-viewer-thumb
                  data-screenshot-index={index}
                  aria-label={`${meta.title} ${labels.screens} ${index + 1}`}
                >
                  <img
                    src={screenshotPath}
                    alt=""
                    width="1242"
                    height="2688"
                    loading="lazy"
                    decoding="async"
                    data-no-visual-search="true"
                  />
                </button>
              ))}
            </div>
          </div>
        </dialog>
      </details>
    )}

    <section class="download-band" aria-label={labels.download}>
      <p class="eyebrow">{labels.download}</p>
      <div class="actions compact" aria-label={labels.stores}>
        <a class="button primary" href={appStoreUrl} data-store-link data-store="app_store" data-store-position="download">{labels.appStore}</a>
        {googlePlayUrl && <a class="button primary" href={googlePlayUrl} data-store-link data-store="google_play" data-store-position="download">{labels.googlePlay}</a>}
      </div>
    </section>

    <footer>
      <a href={privacyUrl}>{labels.footerPrivacy}</a>
      <a href={`mailto:${meta.supportEmail}`}>{meta.supportEmail}</a>
    </footer>
  </main>
</BaseLayout>

<style>
  .page-shell {
    width: min(1040px, calc(100% - 36px));
    margin: 0 auto;
    padding: 24px 0 30px;
  }

  .topbar,
  footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    color: #737067;
    font-size: 14px;
  }

  .brand,
  .language,
  footer a {
    text-decoration: none;
  }

  .brand {
    color: #737067;
    font-size: 14px;
    font-weight: 560;
  }

  .language {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    border: 1px solid #ded6ca;
    border-radius: 999px;
    padding: 6px 12px;
    background: rgba(255, 253, 248, 0.72);
    color: #5f5a50;
    font-size: 13px;
    font-weight: 650;
    line-height: 1.35;
    text-decoration: none;
  }

  .language:hover,
  .language:focus-visible {
    border-color: #cfc5b7;
    background: #fffdf8;
  }

  .language:focus-visible {
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }

  .hero {
    position: relative;
    min-height: 452px;
    display: grid;
    align-content: center;
    gap: 19px;
    border-bottom: 1px solid #e0d8cb;
    padding: 48px 0 40px;
    overflow: hidden;
  }

  .hero[data-app] {
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0), rgba(255, 253, 248, 0.34) 48%, rgba(255, 253, 248, 0));
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 78px 0;
    background:
      linear-gradient(90deg, rgba(255, 253, 248, 0), rgba(255, 253, 248, 0.72), rgba(255, 253, 248, 0));
    opacity: 0.58;
    pointer-events: none;
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 188px 0 124px auto;
    width: 118px;
    background: repeating-linear-gradient(
      0deg,
      rgba(255, 253, 248, 0),
      rgba(255, 253, 248, 0) 12px,
      var(--accent-border) 12px,
      var(--accent-border) 13px
    );
    opacity: 0.082;
    pointer-events: none;
  }

  .hero[data-app="tagweaver"]::after {
    inset: 176px 2px 118px auto;
    width: 138px;
    background:
      linear-gradient(90deg, var(--accent-border) 0 1px, transparent 1px),
      linear-gradient(0deg, var(--accent-border) 0 1px, transparent 1px);
    background-size: 22px 22px;
    opacity: 0.105;
  }

  .hero[data-app="aligna"]::after {
    inset: 184px 0 116px auto;
    width: 140px;
    background: var(--accent-border);
    -webkit-mask-image: url("data:image/svg+xml,%3Csvg width='132' height='48' viewBox='0 0 132 48' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M4 8H72M24 22H116M12 36H88' stroke='white' stroke-width='1' stroke-linecap='round'/%3E%3C/svg%3E");
    mask-image: url("data:image/svg+xml,%3Csvg width='132' height='48' viewBox='0 0 132 48' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M4 8H72M24 22H116M12 36H88' stroke='white' stroke-width='1' stroke-linecap='round'/%3E%3C/svg%3E");
    -webkit-mask-repeat: repeat-y;
    mask-repeat: repeat-y;
    opacity: 0.105;
  }

  .hero[data-app="vaultxt"]::after {
    inset: 182px 4px 114px auto;
    width: 142px;
    background: repeating-linear-gradient(
      0deg,
      var(--accent-border) 0 1px,
      transparent 1px 13px
    );
    opacity: 0.105;
  }

  .hero[data-app="clipnest"]::after {
    inset: 180px 0 116px auto;
    width: 136px;
    background: var(--accent-border);
    -webkit-mask-image: url("data:image/svg+xml,%3Csvg width='116' height='58' viewBox='0 0 116 58' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M18 18h42v22H18zM38 12h42v28H38zM58 20h42v20H58z' fill='none' stroke='white' stroke-width='1' stroke-linejoin='round'/%3E%3C/svg%3E");
    mask-image: url("data:image/svg+xml,%3Csvg width='116' height='58' viewBox='0 0 116 58' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M18 18h42v22H18zM38 12h42v28H38zM58 20h42v20H58z' fill='none' stroke='white' stroke-width='1' stroke-linejoin='round'/%3E%3C/svg%3E");
    -webkit-mask-repeat: repeat-y;
    mask-repeat: repeat-y;
    opacity: 0.105;
  }

  .hero[data-app="segra"]::after {
    inset: 178px 0 116px auto;
    width: 142px;
    background: var(--accent-border);
    -webkit-mask-image: url("data:image/svg+xml,%3Csvg width='132' height='56' viewBox='0 0 132 56' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 28C12 12 24 12 36 28S60 44 72 28s24-16 36 0 24 16 36 0' fill='none' stroke='white' stroke-width='1' stroke-linecap='round'/%3E%3Cpath d='M8 40h116M8 16h116' fill='none' stroke='white' stroke-width='1' stroke-linecap='round' opacity='.42'/%3E%3C/svg%3E");
    mask-image: url("data:image/svg+xml,%3Csvg width='132' height='56' viewBox='0 0 132 56' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 28C12 12 24 12 36 28S60 44 72 28s24-16 36 0 24 16 36 0' fill='none' stroke='white' stroke-width='1' stroke-linecap='round'/%3E%3Cpath d='M8 40h116M8 16h116' fill='none' stroke='white' stroke-width='1' stroke-linecap='round' opacity='.42'/%3E%3C/svg%3E");
    -webkit-mask-repeat: repeat-y;
    mask-repeat: repeat-y;
    opacity: 0.105;
  }

  .hero[data-app="quivra"]::after {
    inset: 180px 0 118px auto;
    width: 136px;
    background:
      radial-gradient(circle at 18px 18px, var(--accent-border) 0 1px, transparent 1.5px),
      linear-gradient(135deg, transparent 0 48%, var(--accent-border) 48% 49%, transparent 49%);
    background-size: 30px 30px;
    opacity: 0.1;
  }

  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(250px, 312px);
    align-items: center;
    gap: 46px;
    z-index: 1;
  }

  .identity {
    position: relative;
    display: grid;
    grid-template-columns: 124px minmax(0, 1fr);
    align-items: center;
    gap: 28px;
  }

  .identity::after {
    content: "";
    position: absolute;
    left: 152px;
    bottom: -20px;
    width: min(184px, 32vw);
    height: 1px;
    background: linear-gradient(90deg, var(--accent-border), rgba(255, 253, 248, 0));
    opacity: 0.72;
  }

  .identity img {
    width: 124px;
    height: 124px;
    border: 1px solid var(--accent-border);
    border-radius: 26px;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.96), var(--accent-bg)),
      #fffdf8;
  }

  .hero[data-app="tagweaver"] .identity img,
  .hero[data-app="melivra"] .identity img {
    background:
      linear-gradient(135deg, rgba(255, 253, 248, 0.98), var(--accent-bg)),
      #fffdf8;
  }

  .hero[data-app="vaultxt"] .identity img {
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.98), var(--accent-bg)),
      #fffdf8;
  }

  .hero[data-app="aligna"] .identity img,
  .hero[data-app="segra"] .identity img {
    background:
      linear-gradient(90deg, rgba(255, 253, 248, 0.98), var(--accent-bg)),
      #fffdf8;
  }

  .hero[data-app="clipnest"] .identity img,
  .hero[data-app="quivra"] .identity img {
    background:
      linear-gradient(160deg, rgba(255, 253, 248, 0.98), var(--accent-bg)),
      #fffdf8;
  }

  .identity img:hover {
    border-color: var(--accent-border);
  }

  .eyebrow {
    margin: 0 0 8px;
    color: #827d72;
    font-size: 13px;
    font-weight: 600;
  }

  h1 {
    margin: 0;
    color: #383631;
    font-size: clamp(50px, 8.6vw, 84px);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .intro {
    max-width: 560px;
    margin: 16px 0 0;
    color: #5b574f;
    font-size: 18px;
    line-height: 1.55;
  }

  .task-preview {
    display: grid;
    gap: 9px;
    border-left: 1px solid rgba(210, 199, 184, 0.18);
    padding: 5px 0 5px 20px;
    background: linear-gradient(90deg, rgba(255, 253, 248, 0.18), rgba(255, 253, 248, 0));
  }

  .task-row {
    position: relative;
    display: grid;
    grid-template-columns: 25px minmax(0, 1fr);
    gap: 11px;
    padding: 6px 0;
  }

  .task-row + .task-row {
    border-top: 1px solid rgba(210, 199, 184, 0.14);
  }

  .task-row span {
    width: 19px;
    height: 19px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--accent-border);
    border-radius: 999px;
    background: rgba(255, 253, 248, 0.58);
    color: var(--accent-text);
    font-size: 9px;
    font-weight: 650;
    line-height: 1;
  }

  .task-row strong {
    color: #504a41;
    font-size: 15px;
    font-weight: 600;
    line-height: 1.5;
  }

  .hero-actions {
    position: relative;
    display: grid;
    gap: 8px;
    margin-left: 152px;
    width: min(100%, 430px);
    z-index: 1;
  }

  .actions {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    z-index: 1;
  }

  .support-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 9px;
  }

  .support-links a {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #ded6ca;
    border-radius: 8px;
    padding: 9px 14px;
    background: #fffdf8;
    color: #5f5a50;
    text-decoration: none;
    font-weight: 600;
    white-space: nowrap;
    font-size: 14px;
  }

  .support-links a:hover,
  .support-links a:focus-visible {
    border-color: #cfc5b7;
    background: rgba(255, 253, 248, 0.76);
    color: #4f4b43;
  }

  .button {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #d8d0c3;
    border-radius: 8px;
    padding: 9px 14px;
    background: rgba(255, 253, 248, 0.78);
    color: #4a453d;
    text-decoration: none;
    font-weight: 600;
    white-space: nowrap;
    font-size: 14px;
  }

  .button.primary {
    background: #62574a;
    border-color: #a09483;
    color: #fffaf0;
  }

  .store-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .store-actions .button,
  .support-links a {
    width: 100%;
  }

  .meta-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 0 0 0 152px;
  }

  .meta-pill {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    border: 1px solid var(--accent-border);
    border-radius: 8px;
    padding: 7px 10px;
    background: var(--accent-bg);
  }

  dt {
    color: var(--accent-text);
    font-size: 13px;
  }

  dd {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin: 0;
    color: #464139;
    font-weight: 600;
  }

  dd span {
    border: 1px solid var(--accent-border);
    border-radius: 999px;
    padding: 2px 7px;
    background: var(--accent-bg);
    color: var(--accent-text);
    font-size: 12px;
    line-height: 1.4;
  }

  .content-band,
  .use-cases-band,
  .faq-band,
  .screens-band,
  .download-band {
    border-top: 1px solid #e3dbcf;
    padding: 42px 0;
  }

  .content-band {
    padding-top: 50px;
  }

  .copy-column {
    position: relative;
    padding-left: 18px;
    border-left: 1px solid rgba(224, 216, 203, 0.42);
  }

  .copy-column::before {
    content: "";
    position: absolute;
    left: -1px;
    top: 0;
    display: block;
    width: 1px;
    height: 58px;
    background: linear-gradient(180deg, rgba(185, 173, 157, 0.54), rgba(255, 253, 248, 0));
  }

  .use-cases-band h2,
  .faq-band h2 {
    margin-top: 0;
  }

  .use-case-list {
    margin-top: 12px;
  }

  .faq-list {
    display: grid;
    gap: 10px;
    margin-top: 16px;
  }

  .faq-list details {
    border-top: 1px solid rgba(224, 216, 203, 0.68);
    padding: 12px 0 10px;
  }

  .faq-list summary {
    cursor: pointer;
    color: #37342f;
    font-size: 16px;
    font-weight: 650;
    line-height: 1.55;
  }

  .faq-list summary::marker {
    color: var(--accent-text);
  }

  .faq-list p {
    margin: 8px 0 0;
    color: #5f5a50;
  }

  .screens-band summary {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    color: #37342f;
    font-size: 17px;
    font-weight: 620;
    list-style: none;
    border: 1px solid rgba(211, 200, 185, 0.88);
    border-radius: 999px;
    padding: 8px 13px;
    background: linear-gradient(180deg, rgba(255, 253, 248, 0.92), rgba(250, 248, 245, 0.64));
    transition: border-color 140ms ease, background 140ms ease, color 140ms ease;
  }

  .screens-band summary::-webkit-details-marker {
    display: none;
  }

  .screens-band summary::after {
    content: "";
    width: 7px;
    height: 7px;
    border-right: 1.5px solid var(--accent-text);
    border-bottom: 1.5px solid var(--accent-text);
    opacity: 0.72;
    transform: rotate(45deg) translateY(-1px);
    transition: transform 140ms ease;
  }

  .screens-band[open] summary::after {
    transform: rotate(225deg) translateY(-1px);
  }

  .screens-band summary:hover,
  .screens-band summary:focus-visible {
    border-color: var(--accent-border);
    background: #fffdf8;
    color: var(--accent-text);
  }

  .screenshot-carousel {
    position: relative;
    margin-top: 22px;
  }

  .screenshot-row {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc((100% - 36px) / 3);
    align-items: start;
    gap: 18px;
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .screenshot-row::-webkit-scrollbar {
    display: none;
  }

  .screenshot-step {
    position: absolute;
    top: 50%;
    z-index: 3;
    width: 44px;
    height: 56px;
    border: 1px solid rgba(196, 185, 169, 0.58);
    border-radius: 999px;
    padding: 0;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.86), rgba(244, 240, 233, 0.68)),
      rgba(255, 253, 248, 0.72);
    color: #37342f;
    font: inherit;
    font-size: 22px;
    font-weight: 560;
    line-height: 1;
    cursor: pointer;
    transform: translateY(-50%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.72),
      0 10px 24px rgba(39, 34, 29, 0.12);
  }

  .screenshot-step:disabled {
    border-color: rgba(196, 185, 169, 0.32);
    background: rgba(255, 253, 248, 0.52);
    color: rgba(55, 52, 47, 0.36);
    cursor: default;
    box-shadow: none;
  }

  .screenshot-step-prev {
    left: -14px;
  }

  .screenshot-step-next {
    right: -14px;
  }

  .screenshot-step:hover,
  .screenshot-step:focus-visible {
    border-color: var(--accent-border);
    background:
      linear-gradient(180deg, #fffdf8, rgba(245, 241, 234, 0.86)),
      #fffdf8;
    color: var(--accent-text);
  }

  .screenshot-step:focus-visible {
    outline: 2px solid var(--accent-text);
    outline-offset: 3px;
  }

  .screenshot-step:disabled:hover,
  .screenshot-step:disabled:focus-visible {
    border-color: rgba(196, 185, 169, 0.32);
    background: rgba(255, 253, 248, 0.52);
    color: rgba(55, 52, 47, 0.36);
    outline: 0;
  }

  .screenshot-progress {
    display: flex;
    justify-content: center;
    margin-top: 16px;
    color: rgba(108, 98, 86, 0.62);
    font-size: 13px;
    font-weight: 560;
    font-variant-numeric: tabular-nums;
  }

  figure {
    position: relative;
    margin: 0;
    border: 1px solid var(--accent-border);
    border-radius: 8px;
    padding: 5px;
    background: rgba(255, 253, 248, 0.78);
    scroll-snap-align: start;
  }

  figure img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 6px;
  }

  .screenshot-link {
    position: relative;
    display: block;
    border-radius: 6px;
    cursor: zoom-in;
  }

  .screenshot-link::before,
  .screenshot-link::after {
    content: "";
    position: absolute;
    pointer-events: none;
  }

  .screenshot-link::before {
    right: 10px;
    bottom: 10px;
    width: 31px;
    height: 31px;
    border: 1px solid rgba(196, 185, 169, 0.62);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.86), rgba(244, 240, 233, 0.72)),
      rgba(255, 253, 248, 0.72);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.78),
      0 8px 18px rgba(39, 34, 29, 0.1);
  }

  .screenshot-link::after {
    right: 19px;
    bottom: 19px;
    width: 8px;
    height: 8px;
    border: 1.5px solid var(--accent-text);
    border-radius: 999px;
    box-shadow: 5px 5px 0 -3.3px var(--accent-text);
    opacity: 0.86;
    transform: rotate(-45deg);
    transform-origin: center;
  }

  .screenshot-link:focus-visible {
    outline: 2px solid var(--accent-text);
    outline-offset: 3px;
  }

  .screenshot-link:hover img {
    box-shadow: 0 0 0 1px var(--accent-border);
  }

  .screenshot-link:hover::before,
  .screenshot-link:focus-visible::before {
    border-color: var(--accent-border);
    background:
      linear-gradient(180deg, #fffdf8, rgba(245, 241, 234, 0.86)),
      #fffdf8;
  }

  .screenshot-viewer {
    width: min(1080px, calc(100vw - 36px));
    max-height: calc(100vh - 32px);
    border: 1px solid rgba(210, 201, 188, 0.56);
    border-radius: 26px;
    padding: 0;
    background:
      linear-gradient(180deg, rgba(250, 249, 246, 0.98), rgba(238, 234, 227, 0.98)),
      #f2eee7;
    color: #37342f;
    box-shadow:
      0 28px 86px rgba(39, 34, 29, 0.26),
      0 0 0 1px rgba(255, 253, 248, 0.42),
      inset 0 1px 0 rgba(255, 255, 255, 0.78);
    overscroll-behavior: contain;
  }

  .screenshot-viewer[open] {
    display: block;
  }

  .screenshot-viewer::backdrop {
    background:
      radial-gradient(circle at 50% 40%, rgba(137, 123, 101, 0.24), transparent 36%),
      rgba(34, 30, 26, 0.8);
  }

  .viewer-panel {
    display: grid;
    gap: 11px;
    padding: 11px;
  }

  .viewer-bar {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    min-height: 34px;
  }

  .viewer-close,
  .viewer-nav {
    border: 1px solid rgba(196, 185, 169, 0.42);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.74), rgba(244, 240, 233, 0.58)),
      rgba(255, 253, 248, 0.56);
    color: #37342f;
    font: inherit;
    font-weight: 560;
    cursor: pointer;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.72),
      0 8px 20px rgba(39, 34, 29, 0.08);
  }

  .viewer-close:hover,
  .viewer-nav:hover,
  .viewer-close:active,
  .viewer-nav:active {
    border-color: var(--accent-border);
    background:
      linear-gradient(180deg, #fffdf8, rgba(245, 241, 234, 0.82)),
      #fffdf8;
    color: var(--accent-text);
  }

  .viewer-close {
    width: 34px;
    height: 34px;
    padding: 0;
    font-size: 18px;
    line-height: 1;
  }

  .viewer-frame {
    display: grid;
    grid-template-columns: 36px minmax(0, 1fr) 36px;
    align-items: center;
    gap: 9px;
  }

  .viewer-image-stage {
    position: relative;
    z-index: 1;
    max-width: 100%;
    max-height: calc(100vh - 194px);
    overflow: hidden;
    border-radius: 16px;
    cursor: zoom-in;
    touch-action: none;
    overscroll-behavior: contain;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.5), rgba(44, 39, 33, 0.035)),
      rgba(44, 39, 33, 0.045);
  }

  .viewer-image-stage img {
    display: block;
    width: auto;
    max-width: 100%;
    max-height: calc(100vh - 194px);
    margin: 0 auto;
    border: 1px solid rgba(210, 201, 188, 0.82);
    border-radius: 16px;
    background: #f7f4ee;
    box-shadow: 0 14px 36px rgba(55, 50, 43, 0.14);
    transform-origin: center;
    user-select: none;
    -webkit-user-drag: none;
    will-change: transform;
  }

  .viewer-image-stage img[data-zoomed="true"] {
    max-width: 100%;
    max-height: calc(100vh - 194px);
    cursor: grab;
  }

  .viewer-image-stage:has(img[data-zoomed="true"]) {
    cursor: grab;
  }

  .viewer-image-stage:has(img[data-dragging="true"]) {
    cursor: grabbing;
  }

  .viewer-image-stage img[data-dragging="true"] {
    cursor: grabbing;
  }

  .viewer-nav {
    position: relative;
    z-index: 2;
    width: 36px;
    height: 36px;
    justify-self: center;
    padding: 0;
    font-size: 23px;
    line-height: 1;
  }

  .viewer-thumbs {
    display: flex;
    justify-content: center;
    gap: 9px;
    overflow-x: auto;
    padding: 3px 2px 5px;
  }

  .viewer-thumb {
    width: 48px;
    height: 64px;
    flex: 0 0 auto;
    border: 1px solid rgba(196, 185, 169, 0.58);
    border-radius: 13px;
    padding: 4px;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.78), rgba(241, 237, 230, 0.52)),
      rgba(255, 253, 248, 0.58);
    cursor: pointer;
    transition: border-color 140ms ease, background 140ms ease, box-shadow 140ms ease, transform 140ms ease;
  }

  .viewer-thumb[aria-current="true"] {
    border-color: var(--accent-border);
    background:
      linear-gradient(180deg, #fffdf8, rgba(246, 242, 235, 0.84)),
      #fffdf8;
    box-shadow:
      0 0 0 1px rgba(255, 253, 248, 0.94),
      0 12px 26px rgba(55, 50, 43, 0.13),
      inset 0 0 0 1px var(--accent-border);
    transform: translateY(-1px);
  }

  .viewer-thumb img {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 4px;
    object-fit: cover;
  }

  .viewer-close:focus-visible,
  .viewer-nav:focus-visible,
  .viewer-thumb:focus-visible {
    outline: 2px solid var(--accent-text);
    outline-offset: 2px;
  }

  .download-band {
    display: grid;
    justify-items: center;
    gap: 12px;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0), rgba(255, 253, 248, 0.36), rgba(255, 253, 248, 0));
    text-align: center;
  }

  .download-band .eyebrow {
    margin: 0;
    color: #746d62;
  }

  .actions.compact {
    justify-content: center;
    margin-left: 0;
    width: min(100%, 264px);
  }

  .actions.compact .button {
    min-height: 38px;
    padding: 8px 12px;
    font-size: 14px;
  }

  .copy-column {
    max-width: none;
    word-break: keep-all;
    overflow-wrap: break-word;
  }

  h2 {
    margin: 34px 0 9px;
    font-size: 20px;
    line-height: 1.25;
    letter-spacing: 0;
  }

  h3 {
    margin: 0 0 12px;
    font-size: 20px;
    line-height: 1.3;
    letter-spacing: 0;
  }

  p,
  li {
    color: #4f4b43;
    font-size: 16px;
    line-height: 1.78;
  }

  .copy-column > p:first-child {
    color: #3f3b35;
    font-size: 17px;
    line-height: 1.72;
    max-width: none;
  }

  .copy-column p + p {
    margin-top: 16px;
  }

  ul {
    display: grid;
    gap: 7px;
    margin: 20px 0 0;
    padding: 0;
    list-style: none;
  }

  li {
    position: relative;
    padding: 7px 0 7px 18px;
    border-top: 1px solid rgba(224, 216, 203, 0.5);
  }

  li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 18px;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: var(--accent-border);
  }

  footer {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    justify-items: center;
    align-items: center;
    gap: 7px;
    border-top: 1px solid #e0d8cb;
    padding-top: 16px;
    text-align: center;
  }

  footer > * {
    justify-self: center;
    width: fit-content;
    max-width: 100%;
    text-align: center;
  }

  footer a:first-of-type {
    color: #5f5a50;
    font-weight: 620;
  }

  footer a:last-child {
    color: #827d72;
    font-size: 13px;
  }

  @media (max-width: 680px) {
    .page-shell {
      width: min(100% - 24px, 980px);
      padding-top: 20px;
    }

    .hero {
      min-height: auto;
      gap: 14px;
      padding: 28px 0 25px;
    }

    .hero::before {
      inset: 86px 0 auto 0;
      height: 188px;
      opacity: 0.36;
    }

    .hero::after {
      display: none;
    }

    .identity,
    .hero-actions,
    .actions,
    .hero-grid {
      display: grid;
      grid-template-columns: 1fr;
    }

    .identity {
      grid-template-columns: 82px minmax(0, 1fr);
      align-items: center;
      gap: 14px;
    }

    .identity::after {
      display: none;
    }

    .identity img {
      width: 82px;
      height: 82px;
      border-radius: 18px;
    }

    h1 {
      font-size: clamp(34px, 11vw, 54px);
      line-height: 1.02;
    }

    .intro {
      margin-top: 8px;
      font-size: 15.5px;
      line-height: 1.48;
    }

    .hero-actions,
    .actions,
    .meta-list {
      margin-left: 0;
    }

    .hero-actions {
      width: 100%;
      gap: 8px;
      margin-top: 1px;
    }

    .actions {
      gap: 8px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .store-actions:has(.button:only-child) {
      grid-template-columns: minmax(0, 1fr);
    }

    .support-links {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
      padding-top: 0;
    }

    .support-links a,
    .button {
      min-height: 40px;
      padding: 8px 9px;
      font-size: 13px;
      line-height: 1.2;
    }

    .meta-list {
      justify-content: center;
      margin-top: 4px;
      opacity: 0.82;
    }

    .meta-pill {
      border-color: var(--accent-border);
      background: var(--accent-bg);
      padding: 5px 8px;
    }

    dt {
      font-size: 12px;
    }

    dd span {
      font-size: 11px;
    }

    .task-preview {
      border-left: 0;
      border-top: 1px solid rgba(210, 199, 184, 0.24);
      background: linear-gradient(180deg, rgba(255, 253, 248, 0.34), rgba(255, 253, 248, 0));
      margin-top: 5px;
      padding: 8px 0 0;
    }

    .task-row {
      grid-template-columns: 25px minmax(0, 1fr);
      gap: 8px;
      padding: 6px 0;
    }

    .task-row strong {
      font-size: 14px;
      line-height: 1.42;
    }

    .task-row span {
      width: 18px;
      height: 18px;
      font-size: 9px;
    }

    .actions.compact {
      justify-content: stretch;
    }

    .actions.compact:has(.button:only-child) {
      grid-template-columns: minmax(0, min(220px, 100%));
      justify-content: center;
    }

    .content-band,
    .screens-band,
    .download-band {
      padding: 28px 0;
    }

    .screenshot-row {
      grid-auto-columns: min(78vw, 270px);
      gap: 12px;
      padding: 0 2px;
    }

    .screenshot-step {
      top: auto;
      bottom: 0;
      width: 44px;
      height: 48px;
      font-size: 18px;
      background: rgba(255, 253, 248, 0.74);
      transform: none;
    }

    .screenshot-step-prev {
      left: calc(50% - 92px);
    }

    .screenshot-step-next {
      right: calc(50% - 92px);
    }

    .screenshot-progress {
      min-height: 48px;
      align-items: center;
      margin-top: 18px;
    }

    .copy-column::before {
      position: static;
      width: 36px;
      height: 1px;
      margin-bottom: 20px;
      background: linear-gradient(90deg, rgba(185, 173, 157, 0.54), rgba(255, 253, 248, 0));
    }

    .copy-column {
      padding-left: 0;
      border-left: 0;
    }

    p,
    li {
      font-size: 16px;
      line-height: 1.68;
    }

    .screenshot-row {
      display: flex;
      gap: 12px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-padding-inline: 2px;
      padding: 1px 1px 5px;
    }

    figure {
      flex: 0 0 min(72vw, 310px);
      scroll-snap-align: start;
    }

    .screenshot-viewer {
      width: min(100vw - 8px, 512px);
      max-height: calc(100dvh - 8px);
      border-radius: 21px;
    }

    .viewer-panel {
      position: relative;
      grid-template-rows: auto minmax(0, 1fr) auto;
      max-height: calc(100dvh - 10px);
      padding: 4px;
      gap: 3px;
    }

    .viewer-bar {
      position: sticky;
      top: 0;
      z-index: 5;
      min-height: 31px;
      padding-bottom: 0;
      background: transparent;
    }

    .viewer-close {
      position: absolute;
      top: 6px;
      right: 6px;
      z-index: 6;
      width: 31px;
      height: 31px;
      background:
        linear-gradient(180deg, rgba(255, 253, 248, 0.9), rgba(244, 240, 233, 0.76)),
        #fffdf8;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.78),
        0 8px 18px rgba(39, 34, 29, 0.1);
    }

    .viewer-frame {
      position: relative;
      grid-template-columns: 1fr;
      gap: 0;
      min-height: 0;
      padding-top: 3px;
    }

    .viewer-image-stage {
      grid-column: 1;
      grid-row: 1;
      max-height: calc(100dvh - 96px);
      border-radius: 15px;
    }

    .viewer-image-stage img {
      max-height: calc(100dvh - 96px);
    }

    .viewer-image-stage img[data-zoomed="true"] {
      max-height: calc(100dvh - 96px);
    }

    .viewer-prev,
    .viewer-next {
      position: absolute;
      top: 50%;
      grid-row: 1;
      width: 34px;
      height: 56px;
      transform: translateY(-50%);
    }

    .viewer-nav {
      width: 34px;
      height: 56px;
      border-radius: 999px;
      background: rgba(255, 253, 248, 0.34);
      border-color: rgba(196, 185, 169, 0.18);
      color: rgba(55, 52, 47, 0.42);
      box-shadow: 0 6px 18px rgba(39, 34, 29, 0.06);
      font-size: 18px;
    }

    .viewer-nav:active {
      background: rgba(255, 253, 248, 0.54);
      color: var(--accent-text);
    }

    .viewer-prev {
      left: 6px;
    }

    .viewer-next {
      right: 6px;
    }

    .viewer-thumbs {
      justify-content: center;
      gap: 6px;
      padding: 1px 2px 2px;
      opacity: 0.36;
    }

    .viewer-thumb {
      width: 30px;
      height: 8px;
      border-radius: 999px;
      padding: 0;
      box-shadow: none;
    }

    .viewer-thumb[aria-current="true"] {
      transform: none;
    }

    .viewer-thumb img {
      display: none;
    }

    .button {
      width: 100%;
    }

  }
</style>

<script>
  const productRoot = document.querySelector('[data-product-slug]');
  const productSlug = productRoot?.getAttribute('data-product-slug') || '';
  const productLocale = productRoot?.getAttribute('data-product-locale') || document.documentElement.lang || '';
  const trackProductEvent = (eventName, params = {}) => {
    window.onnelTrack?.(eventName, {
      app: productSlug,
      locale: productLocale,
      page_path: window.location.pathname,
      ...params
    });
  };
  document.querySelectorAll('[data-store-link]').forEach((link) => {
    link.addEventListener('click', () => {
      trackProductEvent('store_click', {
        store: link.getAttribute('data-store') || '',
        position: link.getAttribute('data-store-position') || ''
      });
    });
  });

  const screenshotLinks = Array.from(document.querySelectorAll('[data-screenshot-link]'));
  const screenshotRow = document.querySelector('[data-screenshot-row]');
  const screenshotPrevButton = document.querySelector('[data-screenshot-prev]');
  const screenshotNextButton = document.querySelector('[data-screenshot-next]');
  const screenshotCount = document.querySelector('[data-screenshot-count]');
  const viewer = document.querySelector('.screenshot-viewer');
  const viewerImage = document.querySelector('[data-viewer-image]');
  const viewerStage = document.querySelector('[data-viewer-stage]');
  const closeButton = document.querySelector('[data-viewer-close]');
  const prevButton = document.querySelector('[data-viewer-prev]');
  const nextButton = document.querySelector('[data-viewer-next]');
  const thumbnailButtons = Array.from(document.querySelectorAll('[data-viewer-thumb]'));
  let currentScreenshotIndex = 0;
  let viewerZoom = 1;
  let viewerPanX = 0;
  let viewerPanY = 0;
  let dragStartX = 0;
  let dragStartY = 0;
  let dragPanStartX = 0;
  let dragPanStartY = 0;
  let isDraggingImage = false;
  let didDragImage = false;
  let suppressNextViewerClick = false;
  let isPinchingViewer = false;
  let pinchStartDistance = 0;
  let pinchStartZoom = 1;
  let touchStartX = 0;
  let touchStartY = 0;
  let touchLastX = 0;
  let touchLastY = 0;
  let touchPanStartX = 0;
  let touchPanStartY = 0;
  let isTouchPanningImage = false;
  let didTouchPanImage = false;
  const dragThreshold = 4;
  const swipeThreshold = 44;
  const zoomedEdgeSwipeThreshold = 64;
  const minViewerZoom = 1;
  const touchPanZoomThreshold = 1.03;
  const clickViewerZoom = 1.65;
  const maxViewerZoom = 2.35;
  const wheelZoomStep = 0.18;
  const pinchZoomDamping = 0.48;
  const scrollScreenshotRow = (direction) => {
    if (!(screenshotRow instanceof HTMLElement)) return;
    const firstItem = screenshotRow.querySelector('figure');
    const itemWidth = firstItem instanceof HTMLElement ? firstItem.getBoundingClientRect().width : 0;
    const columnGap = Number.parseFloat(getComputedStyle(screenshotRow).columnGap || '0') || 0;
    const step = itemWidth + columnGap;
    screenshotRow.scrollBy({ left: direction * step, behavior: 'smooth' });
  };
  const updateScreenshotStepState = () => {
    if (!(screenshotRow instanceof HTMLElement)) return;
    const maxScrollLeft = screenshotRow.scrollWidth - screenshotRow.clientWidth;
    const atStart = screenshotRow.scrollLeft <= 1;
    const atEnd = screenshotRow.scrollLeft >= maxScrollLeft - 1;
    if (screenshotPrevButton instanceof HTMLButtonElement) {
      screenshotPrevButton.disabled = atStart;
    }
    if (screenshotNextButton instanceof HTMLButtonElement) {
      screenshotNextButton.disabled = atEnd;
    }
    const firstItem = screenshotRow.querySelector('figure');
    const itemWidth = firstItem instanceof HTMLElement ? firstItem.getBoundingClientRect().width : 0;
    const columnGap = Number.parseFloat(getComputedStyle(screenshotRow).columnGap || '0') || 0;
    const step = itemWidth + columnGap;
    const itemCount = screenshotRow.querySelectorAll('figure').length;
    const activeIndex = step > 0 ? Math.min(itemCount - 1, Math.max(0, Math.round(screenshotRow.scrollLeft / step))) : 0;
    if (screenshotCount instanceof HTMLElement) {
      screenshotCount.textContent = `${activeIndex + 1} / ${itemCount}`;
    }
  };

  screenshotPrevButton?.addEventListener('click', () => {
    scrollScreenshotRow(-1);
    trackProductEvent('screenshot_gallery_previous', {});
  });
  screenshotNextButton?.addEventListener('click', () => {
    scrollScreenshotRow(1);
    trackProductEvent('screenshot_gallery_next', {});
  });
  screenshotRow?.addEventListener('scroll', updateScreenshotStepState, { passive: true });
  window.addEventListener('resize', updateScreenshotStepState);
  updateScreenshotStepState();

  const isViewerPanAtHorizontalEdge = (direction) => {
    if (!viewerImage || !viewerStage || viewerZoom <= touchPanZoomThreshold) return true;
    const stageRect = viewerStage.getBoundingClientRect();
    const baseWidth = viewerImage.offsetWidth || viewerImage.getBoundingClientRect().width / viewerZoom;
    const overflowX = Math.max(0, (baseWidth * viewerZoom - stageRect.width) / 2);
    if (overflowX <= 0) return true;
    const edgeSlack = 10;
    return direction < 0
      ? viewerPanX <= -overflowX + edgeSlack
      : viewerPanX >= overflowX - edgeSlack;
  };

  const resetViewerInteraction = () => {
    isDraggingImage = false;
    didDragImage = false;
    suppressNextViewerClick = false;
    isPinchingViewer = false;
    isTouchPanningImage = false;
    didTouchPanImage = false;
    pinchStartDistance = 0;
    if (viewerImage) viewerImage.dataset.dragging = 'false';
  };

  const constrainViewerPan = () => {
    if (!viewerImage || !viewerStage || viewerZoom <= minViewerZoom) {
      viewerPanX = 0;
      viewerPanY = 0;
      return;
    }
    const stageRect = viewerStage.getBoundingClientRect();
    const baseWidth = viewerImage.offsetWidth || viewerImage.getBoundingClientRect().width / viewerZoom;
    const baseHeight = viewerImage.offsetHeight || viewerImage.getBoundingClientRect().height / viewerZoom;
    const overflowX = Math.max(0, (baseWidth * viewerZoom - stageRect.width) / 2);
    const overflowY = Math.max(0, (baseHeight * viewerZoom - stageRect.height) / 2);
    const slack = 24;
    viewerPanX = Math.min(overflowX + slack, Math.max(-overflowX - slack, viewerPanX));
    viewerPanY = Math.min(overflowY + slack, Math.max(-overflowY - slack, viewerPanY));
  };

  const applyViewerZoom = () => {
    if (!viewerImage) return;
    constrainViewerPan();
    viewerImage.style.transform = `translate(${viewerPanX}px, ${viewerPanY}px) scale(${viewerZoom})`;
    viewerImage.dataset.zoomed = viewerZoom > 1 ? 'true' : 'false';
  };

  const resetViewerZoom = () => {
    viewerZoom = minViewerZoom;
    viewerPanX = 0;
    viewerPanY = 0;
    applyViewerZoom();
  };

  const setViewerZoomAtPoint = (targetZoom, clientX, clientY) => {
    if (!viewerImage || !viewerStage) return;
    const nextZoom = Math.min(maxViewerZoom, Math.max(minViewerZoom, targetZoom));
    if (nextZoom <= minViewerZoom) {
      resetViewerZoom();
      return;
    }
    const imageRect = viewerImage.getBoundingClientRect();
    const imageCenterX = imageRect.left + imageRect.width / 2;
    const imageCenterY = imageRect.top + imageRect.height / 2;
    const zoomRatio = nextZoom / viewerZoom;
    const offsetX = clientX - imageCenterX;
    const offsetY = clientY - imageCenterY;
    const nextCenterX = clientX - offsetX * zoomRatio;
    const nextCenterY = clientY - offsetY * zoomRatio;
    viewerPanX += nextCenterX - imageCenterX;
    viewerPanY += nextCenterY - imageCenterY;
    viewerZoom = nextZoom;
    applyViewerZoom();
  };

  const zoomViewerAtPoint = (clientX, clientY) => {
    if (!viewerImage || !viewerStage) return;
    if (viewerZoom > minViewerZoom) {
      resetViewerZoom();
      trackProductEvent('screenshot_zoom_reset', { screenshot_index: currentScreenshotIndex + 1 });
      return;
    }
    const imageRect = viewerImage.getBoundingClientRect();
    const stageRect = viewerStage.getBoundingClientRect();
    const imageCenterX = imageRect.left + imageRect.width / 2;
    const imageCenterY = imageRect.top + imageRect.height / 2;
    const stageCenterX = stageRect.left + stageRect.width / 2;
    const stageCenterY = stageRect.top + stageRect.height / 2;
    viewerZoom = clickViewerZoom;
    viewerPanX = stageCenterX - imageCenterX - (clientX - imageCenterX) * clickViewerZoom;
    viewerPanY = stageCenterY - imageCenterY - (clientY - imageCenterY) * clickViewerZoom;
    applyViewerZoom();
    trackProductEvent('screenshot_zoom', {
      screenshot_index: currentScreenshotIndex + 1,
      zoom: clickViewerZoom
    });
  };

  const getTouchDistance = (touches) => {
    const deltaX = touches[0].clientX - touches[1].clientX;
    const deltaY = touches[0].clientY - touches[1].clientY;
    return Math.hypot(deltaX, deltaY);
  };

  const getTouchCenter = (touches) => ({
    x: (touches[0].clientX + touches[1].clientX) / 2,
    y: (touches[0].clientY + touches[1].clientY) / 2
  });

  const setViewerImage = (index) => {
    if (!viewerImage) return;
    resetViewerInteraction();
    currentScreenshotIndex = (index + screenshotLinks.length) % screenshotLinks.length;
    const link = screenshotLinks[currentScreenshotIndex];
    const image = link.querySelector('img');
    viewerImage.src = link.getAttribute('href');
    viewerImage.alt = image?.getAttribute('alt') || '';
    viewerImage.hidden = false;
    resetViewerZoom();
    thumbnailButtons.forEach((button, thumbnailIndex) => {
      if (thumbnailIndex === currentScreenshotIndex) {
        button.setAttribute('aria-current', 'true');
      } else {
        button.removeAttribute('aria-current');
      }
    });
  };

  const openViewer = (index) => {
    if (!viewer || typeof viewer.showModal !== 'function') return;
    setViewerImage(index);
    viewer.showModal();
    trackProductEvent('screenshot_open', { screenshot_index: currentScreenshotIndex + 1 });
    closeButton?.focus({ preventScroll: true });
  };

  const closeViewer = () => {
    resetViewerInteraction();
    if (viewer?.open) viewer.close();
  };

  screenshotLinks.forEach((link, index) => {
    link.addEventListener('click', (event) => {
      if (!viewer || typeof viewer.showModal !== 'function') return;
      event.preventDefault();
      openViewer(index);
    });
  });

  closeButton?.addEventListener('click', closeViewer);
  prevButton?.addEventListener('click', () => {
    setViewerImage(currentScreenshotIndex - 1);
    trackProductEvent('screenshot_previous', { screenshot_index: currentScreenshotIndex + 1 });
  });
  nextButton?.addEventListener('click', () => {
    setViewerImage(currentScreenshotIndex + 1);
    trackProductEvent('screenshot_next', { screenshot_index: currentScreenshotIndex + 1 });
  });
  viewerImage?.addEventListener('mousedown', (event) => {
    if (!viewer?.open || !viewerImage) return;
    didDragImage = false;
    if (viewerImage.dataset.zoomed !== 'true') return;
    event.preventDefault();
    isDraggingImage = true;
    dragStartX = event.clientX;
    dragStartY = event.clientY;
    dragPanStartX = viewerPanX;
    dragPanStartY = viewerPanY;
    viewerImage.dataset.dragging = 'true';
  });
  document.addEventListener('mousemove', (event) => {
    if (!isDraggingImage || !viewerImage) return;
    if (event.buttons !== 1) {
      isDraggingImage = false;
      viewerImage.dataset.dragging = 'false';
      return;
    }
    const deltaX = event.clientX - dragStartX;
    const deltaY = event.clientY - dragStartY;
    if (!didDragImage && Math.hypot(deltaX, deltaY) < dragThreshold) return;
    didDragImage = true;
    viewerPanX = dragPanStartX + deltaX;
    viewerPanY = dragPanStartY + deltaY;
    applyViewerZoom();
  });
  document.addEventListener('mouseup', () => {
    if (!isDraggingImage || !viewerImage) return;
    isDraggingImage = false;
    viewerImage.dataset.dragging = 'false';
    if (didDragImage) {
      suppressNextViewerClick = true;
      window.setTimeout(() => {
        suppressNextViewerClick = false;
      }, 0);
    }
  });
  viewerImage?.addEventListener('click', (event) => {
    if (!viewer?.open) return;
    if (suppressNextViewerClick) {
      event.preventDefault();
      suppressNextViewerClick = false;
      didDragImage = false;
      return;
    }
    zoomViewerAtPoint(event.clientX, event.clientY);
  });
  viewerStage?.addEventListener('touchstart', (event) => {
    if (!viewer?.open) return;
    if (event.touches.length === 2) {
      event.preventDefault();
      isPinchingViewer = true;
      isTouchPanningImage = false;
      didTouchPanImage = false;
      pinchStartDistance = getTouchDistance(event.touches);
      pinchStartZoom = viewerZoom;
      isDraggingImage = false;
      didDragImage = false;
      if (viewerImage) viewerImage.dataset.dragging = 'false';
      return;
    }
    if (event.touches.length !== 1) return;
    const touch = event.touches[0];
    touchStartX = touch.clientX;
    touchStartY = touch.clientY;
    touchLastX = touch.clientX;
    touchLastY = touch.clientY;
    touchPanStartX = viewerPanX;
    touchPanStartY = viewerPanY;
    didTouchPanImage = false;
    isTouchPanningImage = viewerZoom > touchPanZoomThreshold;
    if (isTouchPanningImage) {
      event.preventDefault();
      if (viewerImage) viewerImage.dataset.dragging = 'true';
    }
  }, { passive: false });
  viewerStage?.addEventListener('touchmove', (event) => {
    if (!viewer?.open) return;
    if (isPinchingViewer && event.touches.length === 2 && pinchStartDistance > 0) {
      event.preventDefault();
      const center = getTouchCenter(event.touches);
      const distanceRatio = getTouchDistance(event.touches) / pinchStartDistance;
      const targetZoom = pinchStartZoom + (distanceRatio - 1) * pinchZoomDamping;
      setViewerZoomAtPoint(targetZoom, center.x, center.y);
      return;
    }
    if (event.touches.length !== 1 || isPinchingViewer) return;
    const touch = event.touches[0];
    touchLastX = touch.clientX;
    touchLastY = touch.clientY;
    const deltaX = touch.clientX - touchStartX;
    const deltaY = touch.clientY - touchStartY;
    if (isTouchPanningImage) {
      event.preventDefault();
      if (!didTouchPanImage && Math.hypot(deltaX, deltaY) < dragThreshold) return;
      didTouchPanImage = true;
      viewerPanX = touchPanStartX + deltaX;
      viewerPanY = touchPanStartY + deltaY;
      applyViewerZoom();
      return;
    }
    if (Math.abs(deltaX) > 8 && Math.abs(deltaX) > Math.abs(deltaY) * 1.25) {
      event.preventDefault();
    }
  }, { passive: false });
  viewerStage?.addEventListener('touchend', (event) => {
    if (isPinchingViewer) {
      if (event.touches.length >= 2) return;
      isPinchingViewer = false;
      pinchStartDistance = 0;
      pinchStartZoom = viewerZoom;
      suppressNextViewerClick = true;
      window.setTimeout(() => {
        suppressNextViewerClick = false;
      }, 0);
      return;
    }
    if (isTouchPanningImage) {
      isTouchPanningImage = false;
      if (viewerImage) viewerImage.dataset.dragging = 'false';
      const changedTouch = event.changedTouches[0];
      const endX = changedTouch?.clientX ?? touchLastX;
      const endY = changedTouch?.clientY ?? touchLastY;
      const deltaX = endX - touchStartX;
      const deltaY = endY - touchStartY;
      const direction = deltaX < 0 ? -1 : 1;
      if (
        Math.abs(deltaX) >= zoomedEdgeSwipeThreshold &&
        Math.abs(deltaX) > Math.abs(deltaY) * 1.35 &&
        isViewerPanAtHorizontalEdge(direction)
      ) {
        event.preventDefault();
        setViewerImage(currentScreenshotIndex + (direction < 0 ? 1 : -1));
        trackProductEvent(direction < 0 ? 'screenshot_next' : 'screenshot_previous', {
          screenshot_index: currentScreenshotIndex + 1
        });
        suppressNextViewerClick = true;
        window.setTimeout(() => {
          suppressNextViewerClick = false;
        }, 0);
        didTouchPanImage = false;
        return;
      }
      if (didTouchPanImage) {
        suppressNextViewerClick = true;
        window.setTimeout(() => {
          suppressNextViewerClick = false;
        }, 0);
      }
      didTouchPanImage = false;
      return;
    }
    if (event.touches.length > 0 || viewerZoom > touchPanZoomThreshold) return;
    const changedTouch = event.changedTouches[0];
    const endX = changedTouch?.clientX ?? touchLastX;
    const endY = changedTouch?.clientY ?? touchLastY;
    const deltaX = endX - touchStartX;
    const deltaY = endY - touchStartY;
    if (Math.abs(deltaX) >= swipeThreshold && Math.abs(deltaX) > Math.abs(deltaY) * 1.25) {
      event.preventDefault();
      setViewerImage(currentScreenshotIndex + (deltaX < 0 ? 1 : -1));
      trackProductEvent(deltaX < 0 ? 'screenshot_next' : 'screenshot_previous', {
        screenshot_index: currentScreenshotIndex + 1
      });
      suppressNextViewerClick = true;
      window.setTimeout(() => {
        suppressNextViewerClick = false;
      }, 0);
    }
  });
  viewerStage?.addEventListener('touchcancel', () => {
    resetViewerInteraction();
  });
  viewerStage?.addEventListener('wheel', (event) => {
    if (!viewer?.open) return;
    event.preventDefault();
    const direction = event.deltaY < 0 ? 1 : -1;
    if (direction < 0 && viewerZoom <= minViewerZoom) return;
    const targetZoom =
      direction > 0
        ? viewerZoom + wheelZoomStep
        : Math.max(minViewerZoom, viewerZoom - wheelZoomStep);
    setViewerZoomAtPoint(targetZoom, event.clientX, event.clientY);
  }, { passive: false });
  thumbnailButtons.forEach((button, index) => {
    button.addEventListener('click', () => {
      setViewerImage(index);
      trackProductEvent('screenshot_select', { screenshot_index: currentScreenshotIndex + 1 });
    });
  });

  viewer?.addEventListener('click', (event) => {
    if (event.target === viewer) closeViewer();
  });

  document.addEventListener('keydown', (event) => {
    if (!viewer?.open) return;
    if (event.key === 'ArrowLeft') {
      setViewerImage(currentScreenshotIndex - 1);
      trackProductEvent('screenshot_previous', { screenshot_index: currentScreenshotIndex + 1 });
    }
    if (event.key === 'ArrowRight') {
      setViewerImage(currentScreenshotIndex + 1);
      trackProductEvent('screenshot_next', { screenshot_index: currentScreenshotIndex + 1 });
    }
  });
</script>
