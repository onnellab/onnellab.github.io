---
import BaseLayout from '../layouts/BaseLayout.astro';
import { landingSubtitle, pageBodyDescription, renderBlocks, type ProductPageData } from '../lib/products';

type Props = {
  data: ProductPageData;
};

const { data } = Astro.props;
const { meta, copy } = data;
const labels =
  data.locale === 'ko'
    ? {
        switchLabel: 'English',
        platforms: '지원 플랫폼',
        appStore: 'App Store',
        googlePlay: 'Google Play',
        privacy: 'Privacy Policy',
        footerPrivacy: '개인정보 처리방침',
        support: 'Support',
        download: '다운로드',
        screens: '스크린샷',
        stores: '스토어'
      }
    : {
        switchLabel: '한국어',
        platforms: 'Platforms',
        appStore: 'App Store',
        googlePlay: 'Google Play',
        privacy: 'Privacy Policy',
        footerPrivacy: 'Privacy Policy',
        support: 'Support',
        download: 'Download',
        screens: 'Screenshots',
        stores: 'Stores'
      };

const bodyBlocks = renderBlocks(pageBodyDescription(copy));
const heroIntro = landingSubtitle(copy);
const heroSignals =
  (bodyBlocks.find((block) => block.type === 'ul')?.value as string[] | undefined)?.slice(0, 3) ?? [];
const homePath = data.locale === 'ko' ? '/ko/' : '/';
const pageStyle = `--accent-border: ${data.accent.border}; --accent-bg: ${data.accent.background}; --accent-text: ${data.accent.text};`;
const iconUrl = new URL(data.iconPath, Astro.site);
const canonicalUrl = new URL(data.canonicalPath, Astro.site);
const enPath = `/apps/${data.source.slug}/`;
const koPath = `/apps/${data.source.slug}/ko/`;
const offerPriceCurrency = meta.priceCurrency ?? (meta.price === 0 ? 'USD' : undefined);
const localizedAppStoreUrl = (url: string, locale: ProductPageData['locale']) => {
  const storeCountry = locale === 'ko' ? 'kr' : 'us';
  const language = locale === 'ko' ? 'ko' : 'en-US';
  const appStoreUrl = new URL(url);
  appStoreUrl.pathname = appStoreUrl.pathname.replace(/^\/(?:[a-z]{2}\/)?app\//, `/${storeCountry}/app/`);
  appStoreUrl.searchParams.set('l', language);
  return appStoreUrl.toString();
};
const localizedGooglePlayUrl = (url: string | undefined, locale: ProductPageData['locale']) => {
  if (!url) return undefined;
  const playStoreUrl = new URL(url);
  playStoreUrl.searchParams.set('hl', locale === 'ko' ? 'ko' : 'en');
  playStoreUrl.searchParams.set('gl', locale === 'ko' ? 'KR' : 'US');
  return playStoreUrl.toString();
};
const appStoreUrl = localizedAppStoreUrl(meta.appstore, data.locale);
const googlePlayUrl = localizedGooglePlayUrl(meta.googleplay, data.locale);
const storeUrls = [appStoreUrl, googlePlayUrl].filter(Boolean);
const screenshotUrls = data.screenshotPaths.map((screenshotPath) =>
  new URL(screenshotPath, Astro.site).toString()
);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  '@id': `${canonicalUrl.toString()}#softwareapplication`,
  name: meta.title,
  url: canonicalUrl.toString(),
  operatingSystem: meta.platforms.join(', '),
  applicationCategory: 'UtilitiesApplication',
  applicationSubCategory: copy.android.name || copy.ios.name,
  description: data.seoDescription,
  inLanguage: data.locale,
  image: iconUrl.toString(),
  ...(screenshotUrls.length > 0 ? { screenshot: screenshotUrls } : {}),
  downloadUrl: storeUrls,
  installUrl: storeUrls,
  sameAs: storeUrls,
  softwareHelp: `mailto:${meta.supportEmail}`,
  publisher: {
    '@type': 'Organization',
    '@id': new URL('/#organization', Astro.site).toString(),
    name: 'ONNELLAB',
    url: new URL('/', Astro.site).toString()
  },
  ...(meta.price !== undefined
    ? {
        offers: {
          '@type': 'Offer',
          price: meta.price,
          ...(offerPriceCurrency ? { priceCurrency: offerPriceCurrency } : {}),
          ...(meta.pricing ? { description: meta.pricing } : {}),
          url: canonicalUrl.toString()
        }
      }
    : {}),
  privacyPolicy: meta.privacy
};
---

<BaseLayout
  title={data.seoTitle}
  description={data.seoDescription}
  canonicalPath={data.canonicalPath}
  lang={data.locale}
  image={data.iconPath}
  jsonLd={jsonLd}
  alternates={[
    { lang: 'en', path: enPath },
    { lang: 'ko', path: koPath },
    { lang: 'x-default', path: enPath }
  ]}
>
  <main class="page-shell" style={pageStyle}>
    <header class="topbar" aria-label="ONNELLAB">
      <a class="brand" href={homePath}>ONNELLAB</a>
      <a class="language" href={data.alternatePath} data-locale-choice={data.locale === 'ko' ? 'en' : 'ko'}>{labels.switchLabel}</a>
    </header>

    <section class="hero" aria-labelledby="product-title" data-app={data.source.slug}>
      <div class="hero-grid">
        <div class="identity">
          <img src={data.iconPath} alt={`${meta.title} icon`} width="88" height="88" data-no-visual-search="true" />
          <div>
            <h1 id="product-title">{meta.title}</h1>
            {heroIntro && <p class="intro">{heroIntro}</p>}
          </div>
        </div>

        {heroSignals.length > 0 && (
          <div class="task-preview" aria-hidden="true">
            {heroSignals.map((signal, index) => (
              <div class="task-row">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <strong>{signal}</strong>
              </div>
            ))}
          </div>
        )}
      </div>

      <div class="hero-actions">
        <div class="actions store-actions" aria-label={labels.stores}>
          <a class="button primary" href={appStoreUrl}>{labels.appStore}</a>
          {googlePlayUrl && <a class="button primary" href={googlePlayUrl}>{labels.googlePlay}</a>}
        </div>
        <div class="support-links" aria-label="Support links">
          <a href={meta.privacy}>{labels.privacy}</a>
          <a href={`mailto:${meta.supportEmail}`}>{labels.support}</a>
        </div>
      </div>

      <dl class="meta-list">
        <div class="meta-pill">
          <dt>{labels.platforms}</dt>
          <dd>
            {meta.platforms.map((platform) => <span>{platform}</span>)}
          </dd>
        </div>
      </dl>
    </section>

    <section class="content-band" aria-label={copy.android.name ?? copy.ios.name ?? meta.title}>
      <div class="copy-column">
        {bodyBlocks.map((block) => (
          block.type === 'h' ? (
            <h2>{block.value}</h2>
          ) : block.type === 'ul' ? (
            <ul>
              {(block.value as string[]).map((item) => <li>{item}</li>)}
            </ul>
          ) : (
            <p>{block.value}</p>
          )
        ))}
      </div>
    </section>

    {data.screenshotPaths.length > 0 && (
      <details class="screens-band">
        <summary>{labels.screens}</summary>
        <div class="screenshot-row">
          {data.screenshotPaths.slice(0, 3).map((screenshotPath, index) => (
            <figure>
              <a
                class="screenshot-link"
                href={screenshotPath}
                data-screenshot-link
                data-screenshot-index={index}
                aria-label={`${meta.title} ${labels.screens} ${index + 1}`}
              >
                <img
                  src={screenshotPath}
                  alt={`${meta.title} ${labels.screens} ${index + 1}`}
                  width="1242"
                  height="2688"
                  loading="lazy"
                  decoding="async"
                  data-no-visual-search="true"
                />
              </a>
            </figure>
          ))}
        </div>
        <dialog class="screenshot-viewer" aria-label={labels.screens}>
          <div class="viewer-panel">
            <div class="viewer-bar">
              <button class="viewer-close" type="button" data-viewer-close aria-label="Close">×</button>
            </div>
            <div class="viewer-frame">
              <button class="viewer-nav viewer-prev" type="button" data-viewer-prev aria-label="Previous">‹</button>
              <div class="viewer-image-stage" data-viewer-stage>
                <img data-viewer-image data-no-visual-search="true" alt="" />
              </div>
              <button class="viewer-nav viewer-next" type="button" data-viewer-next aria-label="Next">›</button>
            </div>
            <div class="viewer-thumbs" aria-label={labels.screens}>
              {data.screenshotPaths.slice(0, 3).map((screenshotPath, index) => (
                <button
                  class="viewer-thumb"
                  type="button"
                  data-viewer-thumb
                  data-screenshot-index={index}
                  aria-label={`${meta.title} ${labels.screens} ${index + 1}`}
                >
                  <img
                    src={screenshotPath}
                    alt=""
                    width="1242"
                    height="2688"
                    loading="lazy"
                    decoding="async"
                    data-no-visual-search="true"
                  />
                </button>
              ))}
            </div>
          </div>
        </dialog>
      </details>
    )}

    <section class="download-band" aria-label={labels.download}>
      <p class="eyebrow">{labels.download}</p>
      <div class="actions compact" aria-label={labels.stores}>
        <a class="button primary" href={appStoreUrl}>{labels.appStore}</a>
        {googlePlayUrl && <a class="button primary" href={googlePlayUrl}>{labels.googlePlay}</a>}
      </div>
    </section>

    <footer>
      <a href={meta.privacy}>{labels.footerPrivacy}</a>
      <a href={`mailto:${meta.supportEmail}`}>{meta.supportEmail}</a>
    </footer>
  </main>
</BaseLayout>

<style>
  .page-shell {
    width: min(1040px, calc(100% - 36px));
    margin: 0 auto;
    padding: 24px 0 30px;
  }

  .topbar,
  footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    color: #737067;
    font-size: 14px;
  }

  .brand,
  .language,
  footer a {
    text-decoration: none;
  }

  .brand {
    color: #37342f;
    font-weight: 560;
  }

  .language {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    border: 1px solid #ded6ca;
    border-radius: 999px;
    padding: 6px 12px;
    background: rgba(255, 253, 248, 0.72);
    color: #5f5a50;
    font-size: 13px;
    font-weight: 650;
    line-height: 1.35;
  }

  .language:hover,
  .language:focus-visible {
    border-color: #cfc5b7;
    background: #fffdf8;
  }

  .language:focus-visible {
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }

  .hero {
    position: relative;
    min-height: 452px;
    display: grid;
    align-content: center;
    gap: 19px;
    border-bottom: 1px solid #e0d8cb;
    padding: 48px 0 40px;
    overflow: hidden;
  }

  .hero[data-app] {
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0), rgba(255, 253, 248, 0.34) 48%, rgba(255, 253, 248, 0));
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 78px 0;
    background:
      linear-gradient(90deg, rgba(255, 253, 248, 0), rgba(255, 253, 248, 0.72), rgba(255, 253, 248, 0));
    opacity: 0.58;
    pointer-events: none;
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 188px 0 124px auto;
    width: 118px;
    background: repeating-linear-gradient(
      0deg,
      rgba(255, 253, 248, 0),
      rgba(255, 253, 248, 0) 12px,
      var(--accent-border) 12px,
      var(--accent-border) 13px
    );
    opacity: 0.082;
    pointer-events: none;
  }

  .hero[data-app="tagweaver"]::after {
    inset: 176px 2px 118px auto;
    width: 138px;
    background:
      linear-gradient(90deg, var(--accent-border) 0 1px, transparent 1px),
      linear-gradient(0deg, var(--accent-border) 0 1px, transparent 1px);
    background-size: 22px 22px;
    opacity: 0.105;
  }

  .hero[data-app="aligna"]::after {
    inset: 184px 0 116px auto;
    width: 140px;
    background: var(--accent-border);
    -webkit-mask-image: url("data:image/svg+xml,%3Csvg width='132' height='48' viewBox='0 0 132 48' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M4 8H72M24 22H116M12 36H88' stroke='white' stroke-width='1' stroke-linecap='round'/%3E%3C/svg%3E");
    mask-image: url("data:image/svg+xml,%3Csvg width='132' height='48' viewBox='0 0 132 48' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M4 8H72M24 22H116M12 36H88' stroke='white' stroke-width='1' stroke-linecap='round'/%3E%3C/svg%3E");
    -webkit-mask-repeat: repeat-y;
    mask-repeat: repeat-y;
    opacity: 0.105;
  }

  .hero[data-app="vaultxt"]::after {
    inset: 182px 4px 114px auto;
    width: 142px;
    background: repeating-linear-gradient(
      0deg,
      var(--accent-border) 0 1px,
      transparent 1px 13px
    );
    opacity: 0.105;
  }

  .hero[data-app="clipnest"]::after {
    inset: 180px 0 116px auto;
    width: 136px;
    background: var(--accent-border);
    -webkit-mask-image: url("data:image/svg+xml,%3Csvg width='116' height='58' viewBox='0 0 116 58' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M18 18h42v22H18zM38 12h42v28H38zM58 20h42v20H58z' fill='none' stroke='white' stroke-width='1' stroke-linejoin='round'/%3E%3C/svg%3E");
    mask-image: url("data:image/svg+xml,%3Csvg width='116' height='58' viewBox='0 0 116 58' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M18 18h42v22H18zM38 12h42v28H38zM58 20h42v20H58z' fill='none' stroke='white' stroke-width='1' stroke-linejoin='round'/%3E%3C/svg%3E");
    -webkit-mask-repeat: repeat-y;
    mask-repeat: repeat-y;
    opacity: 0.105;
  }

  .hero[data-app="segra"]::after {
    inset: 178px 0 116px auto;
    width: 142px;
    background: var(--accent-border);
    -webkit-mask-image: url("data:image/svg+xml,%3Csvg width='132' height='56' viewBox='0 0 132 56' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 28C12 12 24 12 36 28S60 44 72 28s24-16 36 0 24 16 36 0' fill='none' stroke='white' stroke-width='1' stroke-linecap='round'/%3E%3Cpath d='M8 40h116M8 16h116' fill='none' stroke='white' stroke-width='1' stroke-linecap='round' opacity='.42'/%3E%3C/svg%3E");
    mask-image: url("data:image/svg+xml,%3Csvg width='132' height='56' viewBox='0 0 132 56' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 28C12 12 24 12 36 28S60 44 72 28s24-16 36 0 24 16 36 0' fill='none' stroke='white' stroke-width='1' stroke-linecap='round'/%3E%3Cpath d='M8 40h116M8 16h116' fill='none' stroke='white' stroke-width='1' stroke-linecap='round' opacity='.42'/%3E%3C/svg%3E");
    -webkit-mask-repeat: repeat-y;
    mask-repeat: repeat-y;
    opacity: 0.105;
  }

  .hero[data-app="quivra"]::after {
    inset: 180px 0 118px auto;
    width: 136px;
    background:
      radial-gradient(circle at 18px 18px, var(--accent-border) 0 1px, transparent 1.5px),
      linear-gradient(135deg, transparent 0 48%, var(--accent-border) 48% 49%, transparent 49%);
    background-size: 30px 30px;
    opacity: 0.1;
  }

  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(250px, 312px);
    align-items: center;
    gap: 46px;
    z-index: 1;
  }

  .identity {
    position: relative;
    display: grid;
    grid-template-columns: 124px minmax(0, 1fr);
    align-items: center;
    gap: 28px;
  }

  .identity::after {
    content: "";
    position: absolute;
    left: 152px;
    bottom: -20px;
    width: min(184px, 32vw);
    height: 1px;
    background: linear-gradient(90deg, var(--accent-border), rgba(255, 253, 248, 0));
    opacity: 0.72;
  }

  .identity img {
    width: 124px;
    height: 124px;
    border: 1px solid var(--accent-border);
    border-radius: 26px;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.96), var(--accent-bg)),
      #fffdf8;
  }

  .hero[data-app="tagweaver"] .identity img,
  .hero[data-app="melivra"] .identity img {
    background:
      linear-gradient(135deg, rgba(255, 253, 248, 0.98), var(--accent-bg)),
      #fffdf8;
  }

  .hero[data-app="vaultxt"] .identity img {
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.98), var(--accent-bg)),
      #fffdf8;
  }

  .hero[data-app="aligna"] .identity img,
  .hero[data-app="segra"] .identity img {
    background:
      linear-gradient(90deg, rgba(255, 253, 248, 0.98), var(--accent-bg)),
      #fffdf8;
  }

  .hero[data-app="clipnest"] .identity img,
  .hero[data-app="quivra"] .identity img {
    background:
      linear-gradient(160deg, rgba(255, 253, 248, 0.98), var(--accent-bg)),
      #fffdf8;
  }

  .identity img:hover {
    border-color: var(--accent-border);
  }

  .eyebrow {
    margin: 0 0 8px;
    color: #827d72;
    font-size: 13px;
    font-weight: 600;
  }

  h1 {
    margin: 0;
    color: #383631;
    font-size: clamp(50px, 8.6vw, 84px);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .intro {
    max-width: 560px;
    margin: 16px 0 0;
    color: #5b574f;
    font-size: 18px;
    line-height: 1.55;
  }

  .task-preview {
    display: grid;
    gap: 8px;
    border-left: 1px solid rgba(210, 199, 184, 0.18);
    padding: 4px 0 4px 18px;
    background: linear-gradient(90deg, rgba(255, 253, 248, 0.18), rgba(255, 253, 248, 0));
  }

  .task-row {
    position: relative;
    display: grid;
    grid-template-columns: 25px minmax(0, 1fr);
    gap: 11px;
    padding: 6px 0;
  }

  .task-row + .task-row {
    border-top: 1px solid rgba(210, 199, 184, 0.14);
  }

  .task-row span {
    width: 19px;
    height: 19px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--accent-border);
    border-radius: 999px;
    background: rgba(255, 253, 248, 0.58);
    color: var(--accent-text);
    font-size: 9px;
    font-weight: 650;
    line-height: 1;
  }

  .task-row strong {
    color: #504a41;
    font-size: 13.8px;
    font-weight: 580;
    line-height: 1.46;
  }

  .hero-actions {
    position: relative;
    display: grid;
    gap: 8px;
    margin-left: 152px;
    width: min(100%, 298px);
    z-index: 1;
  }

  .actions {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    z-index: 1;
  }

  .support-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 9px;
  }

  .support-links a {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #ded6ca;
    border-radius: 8px;
    padding: 9px 14px;
    background: #fffdf8;
    color: #5f5a50;
    text-decoration: none;
    font-weight: 600;
    white-space: nowrap;
  }

  .support-links a:hover,
  .support-links a:focus-visible {
    border-color: #cfc5b7;
    background: rgba(255, 253, 248, 0.76);
    color: #4f4b43;
  }

  .button {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #d8d0c3;
    border-radius: 8px;
    padding: 9px 14px;
    background: rgba(255, 253, 248, 0.78);
    color: #4a453d;
    text-decoration: none;
    font-weight: 600;
  }

  .button.primary {
    background: #62574a;
    border-color: #a09483;
    color: #fffaf0;
  }

  .store-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .store-actions .button,
  .support-links a {
    width: 100%;
  }

  .meta-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 0 0 0 152px;
  }

  .meta-pill {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    border: 1px solid var(--accent-border);
    border-radius: 8px;
    padding: 7px 10px;
    background: var(--accent-bg);
  }

  dt {
    color: var(--accent-text);
    font-size: 13px;
  }

  dd {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin: 0;
    color: #464139;
    font-weight: 600;
  }

  dd span {
    border: 1px solid var(--accent-border);
    border-radius: 999px;
    padding: 2px 7px;
    background: var(--accent-bg);
    color: var(--accent-text);
    font-size: 12px;
    line-height: 1.4;
  }

  .content-band,
  .screens-band,
  .download-band {
    border-top: 1px solid #e3dbcf;
    padding: 42px 0;
  }

  .content-band {
    padding-top: 50px;
  }

  .copy-column {
    position: relative;
    padding-left: 18px;
    border-left: 1px solid rgba(224, 216, 203, 0.42);
  }

  .copy-column::before {
    content: "";
    position: absolute;
    left: -1px;
    top: 0;
    display: block;
    width: 1px;
    height: 58px;
    background: linear-gradient(180deg, rgba(185, 173, 157, 0.54), rgba(255, 253, 248, 0));
  }

  .screens-band summary {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    color: #37342f;
    font-size: 17px;
    font-weight: 620;
    list-style: none;
    border: 1px solid rgba(211, 200, 185, 0.88);
    border-radius: 999px;
    padding: 8px 13px;
    background: linear-gradient(180deg, rgba(255, 253, 248, 0.92), rgba(250, 248, 245, 0.64));
    transition: border-color 140ms ease, background 140ms ease, color 140ms ease;
  }

  .screens-band summary::-webkit-details-marker {
    display: none;
  }

  .screens-band summary::after {
    content: "";
    width: 7px;
    height: 7px;
    border-right: 1.5px solid var(--accent-text);
    border-bottom: 1.5px solid var(--accent-text);
    opacity: 0.72;
    transform: rotate(45deg) translateY(-1px);
