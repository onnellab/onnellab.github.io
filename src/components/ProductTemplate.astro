---
import BaseLayout from '../layouts/BaseLayout.astro';
import { landingSubtitle, pageBodyDescription, renderBlocks, type ProductPageData } from '../lib/products';

type Props = {
  data: ProductPageData;
};

const { data } = Astro.props;
const { meta, copy } = data;
const labels =
  data.locale === 'ko'
    ? {
        switchLabel: 'English',
        platforms: '지원 플랫폼',
        appStore: 'App Store',
        googlePlay: 'Google Play',
        privacy: 'Privacy Policy',
        support: 'Support',
        download: '다운로드',
        screens: '화면',
        stores: '스토어',
        status: '상태'
      }
    : {
        switchLabel: '한국어',
        platforms: 'Platforms',
        appStore: 'App Store',
        googlePlay: 'Google Play',
        privacy: 'Privacy Policy',
        support: 'Support',
        download: 'Download',
        screens: 'Screens',
        stores: 'Stores',
        status: 'Status'
      };

const bodyBlocks = renderBlocks(pageBodyDescription(copy));
const heroIntro = landingSubtitle(copy);
const heroSignals =
  (bodyBlocks.find((block) => block.type === 'ul')?.value as string[] | undefined)?.slice(0, 3) ?? [];
const homePath = data.locale === 'ko' ? '/ko/' : '/';
const pageStyle = `--accent-border: ${data.accent.border}; --accent-bg: ${data.accent.background}; --accent-text: ${data.accent.text};`;
const iconUrl = new URL(data.iconPath, Astro.site);
const canonicalUrl = new URL(data.canonicalPath, Astro.site);
const enPath = `/apps/${data.source.slug}/`;
const koPath = `/apps/${data.source.slug}/ko/`;
const offerPriceCurrency = meta.priceCurrency ?? (meta.price === 0 ? 'USD' : undefined);
const localizedAppStoreUrl = (url: string, locale: ProductPageData['locale']) => {
  const storeCountry = locale === 'ko' ? 'kr' : 'us';
  const language = locale === 'ko' ? 'ko' : 'en-US';
  const appStoreUrl = new URL(url);
  appStoreUrl.pathname = appStoreUrl.pathname.replace(/^\/(?:[a-z]{2}\/)?app\//, `/${storeCountry}/app/`);
  appStoreUrl.searchParams.set('l', language);
  return appStoreUrl.toString();
};
const localizedGooglePlayUrl = (url: string | undefined, locale: ProductPageData['locale']) => {
  if (!url) return undefined;
  const playStoreUrl = new URL(url);
  playStoreUrl.searchParams.set('hl', locale === 'ko' ? 'ko' : 'en');
  playStoreUrl.searchParams.set('gl', locale === 'ko' ? 'KR' : 'US');
  return playStoreUrl.toString();
};
const appStoreUrl = localizedAppStoreUrl(meta.appstore, data.locale);
const googlePlayUrl = localizedGooglePlayUrl(meta.googleplay, data.locale);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: meta.title,
  operatingSystem: meta.platforms.join(', '),
  applicationCategory: 'UtilitiesApplication',
  applicationSubCategory: copy.android.name || copy.ios.name,
  description: data.seoDescription,
  inLanguage: data.locale,
  image: iconUrl.toString(),
  downloadUrl: [appStoreUrl, googlePlayUrl].filter(Boolean),
  sameAs: [appStoreUrl, googlePlayUrl].filter(Boolean),
  publisher: {
    '@type': 'Organization',
    name: 'ONNELLAB',
    url: new URL('/', Astro.site).toString()
  },
  ...(meta.price !== undefined
    ? {
        offers: {
          '@type': 'Offer',
          price: meta.price,
          ...(offerPriceCurrency ? { priceCurrency: offerPriceCurrency } : {}),
          ...(meta.pricing ? { description: meta.pricing } : {})
        }
      }
    : {}),
  url: canonicalUrl.toString()
};
---

<BaseLayout
  title={data.seoTitle}
  description={data.seoDescription}
  canonicalPath={data.canonicalPath}
  lang={data.locale}
  image={data.iconPath}
  jsonLd={jsonLd}
  alternates={[
    { lang: 'en', path: enPath },
    { lang: 'ko', path: koPath },
    { lang: 'x-default', path: enPath }
  ]}
>
  <main class="page-shell" style={pageStyle}>
    <header class="topbar" aria-label="ONNELLAB">
      <a class="brand" href={homePath}>ONNELLAB</a>
      <a class="language" href={data.alternatePath} data-locale-choice={data.locale === 'ko' ? 'en' : 'ko'}>{labels.switchLabel}</a>
    </header>

    <section class="hero" aria-labelledby="product-title">
      <div class="hero-grid">
        <div class="identity">
          <img src={data.iconPath} alt={`${meta.title} icon`} width="88" height="88" />
          <div>
            <p class="eyebrow">{labels.status}: {meta.status}</p>
            <h1 id="product-title">{meta.title}</h1>
            {heroIntro && <p class="intro">{heroIntro}</p>}
          </div>
        </div>

        {heroSignals.length > 0 && (
          <div class="task-preview" aria-hidden="true">
            {heroSignals.map((signal, index) => (
              <div class="task-row">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <strong>{signal}</strong>
              </div>
            ))}
          </div>
        )}
      </div>

      <div class="hero-actions">
        <div class="actions store-actions" aria-label={labels.stores}>
          <a class="button primary" href={appStoreUrl}>{labels.appStore}</a>
          {googlePlayUrl && <a class="button primary" href={googlePlayUrl}>{labels.googlePlay}</a>}
        </div>
        <div class="support-links" aria-label="Support links">
          <a href={meta.privacy}>{labels.privacy}</a>
          <a href={`mailto:${meta.supportEmail}`}>{labels.support}</a>
        </div>
      </div>

      <dl class="meta-list">
        <div class="meta-pill">
          <dt>{labels.platforms}</dt>
          <dd>
            {meta.platforms.map((platform) => <span>{platform}</span>)}
          </dd>
        </div>
      </dl>
    </section>

    <section class="content-band" aria-label={copy.android.name ?? copy.ios.name ?? meta.title}>
      <div class="copy-column">
        {bodyBlocks.map((block) => (
          block.type === 'h' ? (
            <h2>{block.value}</h2>
          ) : block.type === 'ul' ? (
            <ul>
              {(block.value as string[]).map((item) => <li>{item}</li>)}
            </ul>
          ) : (
            <p>{block.value}</p>
          )
        ))}
      </div>
    </section>

    {data.screenshotPaths.length > 0 && (
      <details class="screens-band">
        <summary>{labels.screens}</summary>
        <div class="screenshot-row">
          {data.screenshotPaths.slice(0, 3).map((screenshotPath, index) => (
            <figure>
              <a
                class="screenshot-link"
                href={screenshotPath}
                data-screenshot-link
                data-screenshot-index={index}
                aria-label={`${meta.title} ${labels.screens} ${index + 1}`}
              >
                <img
                  src={screenshotPath}
                  alt={`${meta.title} ${labels.screens} ${index + 1}`}
                  width="1242"
                  height="2688"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            </figure>
          ))}
        </div>
        <dialog class="screenshot-viewer" aria-label={labels.screens}>
          <div class="viewer-panel">
            <div class="viewer-bar">
              <button class="viewer-close" type="button" data-viewer-close aria-label="Close">×</button>
            </div>
            <div class="viewer-frame">
              <button class="viewer-nav viewer-prev" type="button" data-viewer-prev aria-label="Previous">‹</button>
              <div class="viewer-image-stage" data-viewer-stage>
                <img data-viewer-image alt="" />
              </div>
              <button class="viewer-nav viewer-next" type="button" data-viewer-next aria-label="Next">›</button>
            </div>
            <div class="viewer-thumbs" aria-label={labels.screens}>
              {data.screenshotPaths.slice(0, 3).map((screenshotPath, index) => (
                <button
                  class="viewer-thumb"
                  type="button"
                  data-viewer-thumb
                  data-screenshot-index={index}
                  aria-label={`${meta.title} ${labels.screens} ${index + 1}`}
                >
                  <img
                    src={screenshotPath}
                    alt=""
                    width="1242"
                    height="2688"
                    loading="lazy"
                    decoding="async"
                  />
                </button>
              ))}
            </div>
          </div>
        </dialog>
      </details>
    )}

    <section class="download-band" aria-label={labels.download}>
      <div>
        <p class="eyebrow">{labels.download}</p>
        <h2>{meta.title}</h2>
      </div>
      <div class="actions compact" aria-label={labels.stores}>
        <a class="button primary" href={appStoreUrl}>{labels.appStore}</a>
        {googlePlayUrl && <a class="button primary" href={googlePlayUrl}>{labels.googlePlay}</a>}
      </div>
    </section>

    <footer>
      <span>{meta.title}</span>
      <a href={meta.privacy}>{labels.privacy}</a>
      <a href={`mailto:${meta.supportEmail}`}>{meta.supportEmail}</a>
    </footer>
  </main>
</BaseLayout>

<style>
  .page-shell {
    width: min(1040px, calc(100% - 36px));
    margin: 0 auto;
    padding: 24px 0 30px;
  }

  .topbar,
  footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    color: #737067;
    font-size: 14px;
  }

  .brand,
  .language,
  footer a {
    text-decoration: none;
  }

  .brand {
    font-weight: 650;
    color: #37342f;
  }

  .language {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    border: 1px solid #ded6ca;
    border-radius: 999px;
    padding: 6px 12px;
    background: rgba(255, 253, 248, 0.72);
    color: #5f5a50;
    font-size: 13px;
    font-weight: 650;
    line-height: 1.35;
  }

  .language:hover,
  .language:focus-visible {
    border-color: #cfc5b7;
    background: #fffdf8;
  }

  .language:focus-visible {
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }

  .hero {
    position: relative;
    min-height: 520px;
    display: grid;
    align-content: center;
    gap: 18px;
    border-bottom: 1px solid #e0d8cb;
    padding: 64px 0 48px;
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 78px 0 78px 56%;
    background:
      linear-gradient(90deg, var(--accent-bg), rgba(255, 253, 248, 0));
    opacity: 0.5;
    pointer-events: none;
  }

  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(230px, 310px);
    align-items: center;
    gap: 42px;
    z-index: 1;
  }

  .identity {
    display: grid;
    grid-template-columns: 124px minmax(0, 1fr);
    align-items: center;
    gap: 28px;
  }

  .identity img {
    width: 124px;
    height: 124px;
    border: 1px solid var(--accent-border);
    border-radius: 26px;
    background: #fffdf8;
    box-shadow:
      0 0 0 5px rgba(255, 253, 248, 0.72),
      0 18px 42px rgba(73, 63, 50, 0.08);
  }

  .eyebrow {
    margin: 0 0 8px;
    color: #827d72;
    font-size: 13px;
    font-weight: 600;
  }

  h1 {
    margin: 0;
    color: #383631;
    font-size: clamp(52px, 9vw, 88px);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .intro {
    max-width: 560px;
    margin: 18px 0 0;
    color: #5b574f;
    font-size: 19px;
    line-height: 1.55;
  }

  .task-preview {
    display: grid;
    gap: 0;
    border-left: 1px solid var(--accent-border);
    background:
      linear-gradient(90deg, rgba(255, 253, 248, 0.82), rgba(255, 253, 248, 0)),
      linear-gradient(180deg, transparent, var(--accent-bg), transparent);
    padding: 8px 0 8px 24px;
  }

  .task-row {
    position: relative;
    display: grid;
    grid-template-columns: 38px minmax(0, 1fr);
    gap: 14px;
    padding: 13px 0;
    border-bottom: 1px solid rgba(231, 223, 211, 0.92);
  }

  .task-row:first-child {
    border-top: 1px solid rgba(231, 223, 211, 0.92);
  }

  .task-row span {
    width: 24px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--accent-border);
    border-radius: 999px;
    background: rgba(255, 253, 248, 0.72);
    color: var(--accent-text);
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
  }

  .task-row strong {
    color: #464139;
    font-size: 15px;
    font-weight: 650;
    line-height: 1.45;
  }

  .hero-actions {
    position: relative;
    display: grid;
    gap: 8px;
    margin-left: 152px;
    z-index: 1;
  }

  .actions {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    z-index: 1;
  }

  .support-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    color: #827d72;
    font-size: 13px;
  }

  .support-links a {
    color: inherit;
    text-decoration: none;
  }

  .support-links a:hover,
  .support-links a:focus-visible {
    color: #4f4b43;
  }

  .button {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #d8d0c3;
    border-radius: 8px;
    padding: 9px 14px;
    background: rgba(255, 253, 248, 0.78);
    color: #4a453d;
    text-decoration: none;
    font-weight: 600;
  }

  .button.primary {
    background: #62574a;
    border-color: #a09483;
    color: #fffaf0;
  }

  .meta-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 0 0 0 152px;
  }

  .meta-pill {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    border: 1px solid var(--accent-border);
    border-radius: 8px;
    padding: 7px 10px;
    background: var(--accent-bg);
  }

  dt {
    color: #827d72;
    font-size: 13px;
  }

  dd {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin: 0;
    color: #464139;
    font-weight: 600;
  }

  dd span {
    border: 1px solid var(--accent-border);
    border-radius: 999px;
    padding: 2px 7px;
    background: #fffdf8;
    color: var(--accent-text);
    font-size: 12px;
    line-height: 1.4;
  }

  .content-band,
  .screens-band,
  .download-band {
    border-top: 1px solid #e3dbcf;
    padding: 46px 0;
  }

  .content-band {
    padding-top: 50px;
  }

  .screens-band summary {
    cursor: pointer;
    color: #37342f;
    font-size: 18px;
    font-weight: 650;
    list-style-position: outside;
  }

  .screenshot-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 22px;
  }

  figure {
    margin: 0;
    border: 1px solid var(--accent-border);
    border-radius: 8px;
    padding: 7px;
    background: #fffdf8;
  }

  figure img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 6px;
  }

  .screenshot-link {
    display: block;
    border-radius: 6px;
    cursor: zoom-in;
  }

  .screenshot-link:focus-visible {
    outline: 2px solid var(--accent-text);
    outline-offset: 3px;
  }

  .screenshot-link:hover img {
    box-shadow: 0 0 0 1px var(--accent-text);
  }

  .screenshot-viewer {
    width: min(1120px, calc(100vw - 32px));
    max-height: calc(100vh - 32px);
    border: 1px solid rgba(210, 201, 188, 0.56);
    border-radius: 22px;
    padding: 0;
    background:
      linear-gradient(180deg, rgba(250, 249, 246, 0.98), rgba(238, 234, 227, 0.98)),
      #f2eee7;
    color: #37342f;
    box-shadow:
      0 28px 86px rgba(39, 34, 29, 0.26),
      0 0 0 1px rgba(255, 253, 248, 0.42),
      inset 0 1px 0 rgba(255, 255, 255, 0.78);
    overscroll-behavior: contain;
  }

  .screenshot-viewer::backdrop {
    background:
      radial-gradient(circle at 50% 40%, rgba(137, 123, 101, 0.24), transparent 36%),
      rgba(34, 30, 26, 0.8);
  }

  .viewer-panel {
    display: grid;
    gap: 14px;
    padding: 14px;
  }

  .viewer-bar {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    min-height: 34px;
  }

  .viewer-close,
  .viewer-nav {
    border: 1px solid rgba(196, 185, 169, 0.42);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.74), rgba(244, 240, 233, 0.58)),
      rgba(255, 253, 248, 0.56);
    color: #37342f;
    font: inherit;
    font-weight: 560;
    cursor: pointer;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.72),
      0 8px 20px rgba(39, 34, 29, 0.08);
  }

  .viewer-close:hover,
  .viewer-nav:hover {
    border-color: var(--accent-border);
    background:
      linear-gradient(180deg, #fffdf8, rgba(245, 241, 234, 0.82)),
      #fffdf8;
    color: var(--accent-text);
  }

  .viewer-close {
    width: 34px;
    height: 34px;
    padding: 0;
    font-size: 18px;
    line-height: 1;
  }

  .viewer-frame {
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr) 44px;
    align-items: center;
    gap: 12px;
  }

  .viewer-image-stage {
    position: relative;
    z-index: 1;
    max-width: 100%;
    max-height: calc(100vh - 194px);
    overflow: hidden;
    border-radius: 14px;
    cursor: zoom-in;
    touch-action: none;
    overscroll-behavior: contain;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.5), rgba(44, 39, 33, 0.035)),
      rgba(44, 39, 33, 0.045);
  }

  .viewer-image-stage img {
    display: block;
    width: auto;
    max-width: 100%;
    max-height: calc(100vh - 194px);
    margin: 0 auto;
    border: 1px solid rgba(210, 201, 188, 0.82);
    border-radius: 14px;
    background: #f7f4ee;
    box-shadow: 0 14px 36px rgba(55, 50, 43, 0.14);
    transform-origin: center;
    user-select: none;
    -webkit-user-drag: none;
    will-change: transform;
  }

  .viewer-image-stage img[data-zoomed="true"] {
    max-width: none;
    max-height: none;
    cursor: grab;
  }

  .viewer-image-stage:has(img[data-zoomed="true"]) {
    cursor: grab;
  }

  .viewer-image-stage:has(img[data-dragging="true"]) {
    cursor: grabbing;
  }

  .viewer-image-stage img[data-dragging="true"] {
    cursor: grabbing;
  }

  .viewer-nav {
    position: relative;
    z-index: 2;
    width: 40px;
    height: 40px;
    justify-self: center;
    padding: 0;
    font-size: 23px;
    line-height: 1;
  }

  .viewer-thumbs {
    display: flex;
    justify-content: center;
    gap: 9px;
    overflow-x: auto;
    padding: 3px 2px 5px;
  }

  .viewer-thumb {
    width: 48px;
    height: 64px;
    flex: 0 0 auto;
    border: 1px solid rgba(196, 185, 169, 0.58);
    border-radius: 13px;
    padding: 4px;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.78), rgba(241, 237, 230, 0.52)),
      rgba(255, 253, 248, 0.58);
    cursor: pointer;
    transition: border-color 140ms ease, background 140ms ease, box-shadow 140ms ease, transform 140ms ease;
  }

  .viewer-thumb[aria-current="true"] {
    border-color: var(--accent-border);
    background:
      linear-gradient(180deg, #fffdf8, rgba(246, 242, 235, 0.84)),
      #fffdf8;
    box-shadow:
      0 0 0 1px rgba(255, 253, 248, 0.94),
      0 12px 26px rgba(55, 50, 43, 0.13),
      inset 0 0 0 1px var(--accent-border);
    transform: translateY(-1px);
  }

  .viewer-thumb img {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 4px;
    object-fit: cover;
  }

  .viewer-close:focus-visible,
  .viewer-nav:focus-visible,
  .viewer-thumb:focus-visible {
    outline: 2px solid var(--accent-text);
    outline-offset: 2px;
  }

  .download-band {
    display: grid;
    justify-items: center;
    gap: 16px;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0), rgba(255, 253, 248, 0.52), rgba(255, 253, 248, 0));
    text-align: center;
  }

  .download-band h2 {
    margin: 0;
  }

  .actions.compact {
    justify-content: center;
    margin-left: 0;
    width: 100%;
  }

  .copy-column {
    max-width: 720px;
  }

  h2 {
    margin: 28px 0 12px;
    font-size: 21px;
    line-height: 1.25;
    letter-spacing: 0;
  }

  h3 {
    margin: 0 0 12px;
    font-size: 20px;
    line-height: 1.3;
    letter-spacing: 0;
  }

  p,
  li {
    color: #4f4b43;
    font-size: 16px;
    line-height: 1.78;
  }

  .copy-column > p:first-child {
    color: #3f3b35;
    font-size: 17px;
    line-height: 1.7;
  }

  .copy-column p + p {
    margin-top: 18px;
  }

  ul {
    margin: 14px 0 0;
    padding-left: 20px;
  }

  footer {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    justify-items: center;
    align-items: center;
    gap: 9px;
    border-top: 1px solid #e0d8cb;
    padding-top: 20px;
    text-align: center;
  }

  footer > * {
    justify-self: center;
    width: fit-content;
    max-width: 100%;
    text-align: center;
  }

  footer span {
    order: 2;
  }

  footer a:first-of-type {
    order: 1;
    color: #4f4b43;
    font-weight: 650;
  }

  footer a:last-child {
    order: 3;
    color: #827d72;
    font-size: 13px;
  }

  @media (max-width: 680px) {
    .page-shell {
      width: min(100% - 24px, 980px);
      padding-top: 20px;
    }

    .hero {
      min-height: auto;
      padding: 34px 0 28px;
    }

    .hero::before {
      inset: 86px 0 auto 0;
      height: 188px;
      opacity: 0.22;
    }

    .identity,
    .hero-actions,
    .actions,
    .hero-grid {
      display: grid;
      grid-template-columns: 1fr;
    }

    .identity {
      gap: 16px;
    }

    .identity img {
      width: 86px;
      height: 86px;
      border-radius: 19px;
    }

    h1 {
      font-size: clamp(42px, 15vw, 62px);
    }

    .intro {
      margin-top: 12px;
      font-size: 17px;
      line-height: 1.55;
    }

    .hero-actions,
    .actions,
    .meta-list {
      margin-left: 0;
    }

    .actions {
      gap: 8px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .store-actions:has(.button:only-child) {
      grid-template-columns: minmax(0, 1fr);
    }

    .task-preview {
      border-left: 0;
      border-top: 1px solid var(--accent-border);
      background: linear-gradient(180deg, rgba(255, 253, 248, 0.52), rgba(255, 253, 248, 0));
      padding: 8px 0 0;
    }

    .task-row {
      grid-template-columns: 34px minmax(0, 1fr);
      gap: 9px;
      padding: 11px 0;
    }

    .actions.compact {
      justify-content: stretch;
    }

    .actions.compact:has(.button:only-child) {
      grid-template-columns: minmax(0, min(220px, 100%));
      justify-content: center;
    }

    .content-band,
    .screens-band,
    .download-band {
      padding: 30px 0;
    }

    p,
    li {
      font-size: 16px;
      line-height: 1.68;
    }

    .screenshot-row {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 4px;
    }

    figure {
      flex: 0 0 min(74vw, 320px);
      scroll-snap-align: start;
    }

    .screenshot-viewer {
      width: min(100vw - 18px, 520px);
    }

    .viewer-panel {
      padding: 10px;
      gap: 11px;
    }

    .viewer-frame {
      grid-template-columns: 1fr 1fr;
      gap: 9px;
    }

    .viewer-image-stage {
      grid-column: 1 / -1;
      grid-row: 1;
      max-height: calc(100vh - 204px);
    }

    .viewer-image-stage img {
      max-height: calc(100vh - 204px);
    }

    .viewer-prev,
    .viewer-next {
      grid-row: 2;
    }

    .viewer-nav {
      width: 100%;
      height: 38px;
      border-radius: 12px;
    }

    .viewer-thumbs {
      justify-content: center;
    }

    .button {
      width: 100%;
    }

  }
</style>

<script>
  const screenshotLinks = Array.from(document.querySelectorAll('[data-screenshot-link]'));
  const viewer = document.querySelector('.screenshot-viewer');
  const viewerImage = document.querySelector('[data-viewer-image]');
  const viewerStage = document.querySelector('[data-viewer-stage]');
  const closeButton = document.querySelector('[data-viewer-close]');
  const prevButton = document.querySelector('[data-viewer-prev]');
  const nextButton = document.querySelector('[data-viewer-next]');
  const thumbnailButtons = Array.from(document.querySelectorAll('[data-viewer-thumb]'));
  let currentScreenshotIndex = 0;
  let viewerZoom = 1;
  let viewerPanX = 0;
  let viewerPanY = 0;
  let dragStartX = 0;
  let dragStartY = 0;
  let dragPanStartX = 0;
  let dragPanStartY = 0;
  let isDraggingImage = false;
  let didDragImage = false;
  let suppressNextViewerClick = false;
  let isPinchingViewer = false;
  let pinchStartDistance = 0;
  let pinchStartZoom = 1;
  const dragThreshold = 4;
  const minViewerZoom = 1;
  const clickViewerZoom = 1.15;
  const maxViewerZoom = 2;
  const wheelZoomStep = 0.1;

  const applyViewerZoom = () => {
    if (!viewerImage) return;
    viewerImage.style.transform = `translate(${viewerPanX}px, ${viewerPanY}px) scale(${viewerZoom})`;
    viewerImage.dataset.zoomed = viewerZoom > 1 ? 'true' : 'false';
  };

  const resetViewerZoom = () => {
    viewerZoom = minViewerZoom;
    viewerPanX = 0;
    viewerPanY = 0;
    applyViewerZoom();
  };

  const setViewerZoomAtPoint = (targetZoom, clientX, clientY) => {
    if (!viewerImage || !viewerStage) return;
    const nextZoom = Math.min(maxViewerZoom, Math.max(minViewerZoom, targetZoom));
    if (nextZoom <= minViewerZoom) {
      resetViewerZoom();
      return;
    }
    const imageRect = viewerImage.getBoundingClientRect();
    const imageCenterX = imageRect.left + imageRect.width / 2;
    const imageCenterY = imageRect.top + imageRect.height / 2;
    const zoomRatio = nextZoom / viewerZoom;
    const offsetX = clientX - imageCenterX;
    const offsetY = clientY - imageCenterY;
    const nextCenterX = clientX - offsetX * zoomRatio;
    const nextCenterY = clientY - offsetY * zoomRatio;
    viewerPanX += nextCenterX - imageCenterX;
    viewerPanY += nextCenterY - imageCenterY;
    viewerZoom = nextZoom;
    applyViewerZoom();
  };

  const zoomViewerAtPoint = (clientX, clientY) => {
    if (!viewerImage || !viewerStage) return;
    if (viewerZoom > minViewerZoom) {
      resetViewerZoom();
      return;
    }
    const imageRect = viewerImage.getBoundingClientRect();
    const stageRect = viewerStage.getBoundingClientRect();
    const imageCenterX = imageRect.left + imageRect.width / 2;
    const imageCenterY = imageRect.top + imageRect.height / 2;
    const stageCenterX = stageRect.left + stageRect.width / 2;
    const stageCenterY = stageRect.top + stageRect.height / 2;
    viewerZoom = clickViewerZoom;
    viewerPanX = stageCenterX - imageCenterX - (clientX - imageCenterX) * clickViewerZoom;
    viewerPanY = stageCenterY - imageCenterY - (clientY - imageCenterY) * clickViewerZoom;
    applyViewerZoom();
  };

  const getTouchDistance = (touches) => {
    const deltaX = touches[0].clientX - touches[1].clientX;
    const deltaY = touches[0].clientY - touches[1].clientY;
    return Math.hypot(deltaX, deltaY);
  };

  const getTouchCenter = (touches) => ({
    x: (touches[0].clientX + touches[1].clientX) / 2,
    y: (touches[0].clientY + touches[1].clientY) / 2
  });

  const setViewerImage = (index) => {
    if (!viewerImage) return;
    currentScreenshotIndex = (index + screenshotLinks.length) % screenshotLinks.length;
    const link = screenshotLinks[currentScreenshotIndex];
    const image = link.querySelector('img');
    viewerImage.src = link.getAttribute('href');
    viewerImage.alt = image?.getAttribute('alt') || '';
    resetViewerZoom();
    thumbnailButtons.forEach((button, thumbnailIndex) => {
      if (thumbnailIndex === currentScreenshotIndex) {
        button.setAttribute('aria-current', 'true');
      } else {
        button.removeAttribute('aria-current');
      }
    });
  };

  const openViewer = (index) => {
    if (!viewer || typeof viewer.showModal !== 'function') return;
    setViewerImage(index);
    viewer.showModal();
  };

  const closeViewer = () => {
    if (viewer?.open) viewer.close();
  };

  screenshotLinks.forEach((link, index) => {
    link.addEventListener('click', (event) => {
      if (!viewer || typeof viewer.showModal !== 'function') return;
      event.preventDefault();
      openViewer(index);
    });
  });

  closeButton?.addEventListener('click', closeViewer);
  prevButton?.addEventListener('click', () => setViewerImage(currentScreenshotIndex - 1));
  nextButton?.addEventListener('click', () => setViewerImage(currentScreenshotIndex + 1));
  viewerImage?.addEventListener('mousedown', (event) => {
    if (!viewer?.open || !viewerImage) return;
    didDragImage = false;
    if (viewerImage.dataset.zoomed !== 'true') return;
    event.preventDefault();
    isDraggingImage = true;
    dragStartX = event.clientX;
    dragStartY = event.clientY;
    dragPanStartX = viewerPanX;
    dragPanStartY = viewerPanY;
    viewerImage.dataset.dragging = 'true';
  });
  document.addEventListener('mousemove', (event) => {
    if (!isDraggingImage || !viewerImage) return;
    if (event.buttons !== 1) {
      isDraggingImage = false;
      viewerImage.dataset.dragging = 'false';
      return;
    }
    const deltaX = event.clientX - dragStartX;
    const deltaY = event.clientY - dragStartY;
    if (!didDragImage && Math.hypot(deltaX, deltaY) < dragThreshold) return;
    didDragImage = true;
    viewerPanX = dragPanStartX + deltaX;
    viewerPanY = dragPanStartY + deltaY;
    applyViewerZoom();
  });
  document.addEventListener('mouseup', () => {
    if (!isDraggingImage || !viewerImage) return;
    isDraggingImage = false;
    viewerImage.dataset.dragging = 'false';
    if (didDragImage) {
      suppressNextViewerClick = true;
      window.setTimeout(() => {
        suppressNextViewerClick = false;
      }, 0);
    }
  });
  viewerImage?.addEventListener('click', (event) => {
    if (!viewer?.open) return;
    if (suppressNextViewerClick) {
      event.preventDefault();
      suppressNextViewerClick = false;
      didDragImage = false;
      return;
    }
    zoomViewerAtPoint(event.clientX, event.clientY);
  });
  viewerStage?.addEventListener('touchstart', (event) => {
    if (!viewer?.open || event.touches.length !== 2) return;
    event.preventDefault();
    isPinchingViewer = true;
    pinchStartDistance = getTouchDistance(event.touches);
    pinchStartZoom = viewerZoom;
    isDraggingImage = false;
    didDragImage = false;
    if (viewerImage) viewerImage.dataset.dragging = 'false';
  }, { passive: false });
  viewerStage?.addEventListener('touchmove', (event) => {
    if (!viewer?.open || !isPinchingViewer || event.touches.length !== 2 || pinchStartDistance <= 0) return;
    event.preventDefault();
    const center = getTouchCenter(event.touches);
    const targetZoom = pinchStartZoom * (getTouchDistance(event.touches) / pinchStartDistance);
    setViewerZoomAtPoint(targetZoom, center.x, center.y);
  }, { passive: false });
  viewerStage?.addEventListener('touchend', (event) => {
    if (!isPinchingViewer || event.touches.length >= 2) return;
    isPinchingViewer = false;
    pinchStartDistance = 0;
    pinchStartZoom = viewerZoom;
    suppressNextViewerClick = true;
    window.setTimeout(() => {
      suppressNextViewerClick = false;
    }, 0);
  });
  viewerStage?.addEventListener('wheel', (event) => {
    if (!viewer?.open) return;
    event.preventDefault();
    const direction = event.deltaY < 0 ? 1 : -1;
    if (direction < 0 && viewerZoom <= minViewerZoom) return;
    const targetZoom =
      direction > 0
        ? viewerZoom + wheelZoomStep
        : Math.max(minViewerZoom, viewerZoom - wheelZoomStep);
    setViewerZoomAtPoint(targetZoom, event.clientX, event.clientY);
  }, { passive: false });
  thumbnailButtons.forEach((button, index) => {
    button.addEventListener('click', () => setViewerImage(index));
  });

  viewer?.addEventListener('click', (event) => {
    if (event.target === viewer) closeViewer();
  });

  document.addEventListener('keydown', (event) => {
    if (!viewer?.open) return;
    if (event.key === 'ArrowLeft') setViewerImage(currentScreenshotIndex - 1);
    if (event.key === 'ArrowRight') setViewerImage(currentScreenshotIndex + 1);
  });
</script>
