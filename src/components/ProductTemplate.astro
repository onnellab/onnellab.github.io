---
import BaseLayout from '../layouts/BaseLayout.astro';
import { landingSubtitle, pageBodyDescription, renderBlocks, type ProductPageData } from '../lib/products';

type Props = {
  data: ProductPageData;
};

const { data } = Astro.props;
const { meta, copy } = data;
const labels =
  data.locale === 'ko'
    ? {
        switchLabel: 'English',
        platforms: '지원 플랫폼',
        appStore: 'App Store',
        googlePlay: 'Google Play',
        privacy: 'Privacy Policy',
        support: 'Support',
        download: '다운로드',
        screens: '화면',
        stores: '스토어',
        status: '상태'
      }
    : {
        switchLabel: '한국어',
        platforms: 'Platforms',
        appStore: 'App Store',
        googlePlay: 'Google Play',
        privacy: 'Privacy Policy',
        support: 'Support',
        download: 'Download',
        screens: 'Screens',
        stores: 'Stores',
        status: 'Status'
      };

const bodyBlocks = renderBlocks(pageBodyDescription(copy));
const heroIntro = landingSubtitle(copy);
const heroSignals =
  (bodyBlocks.find((block) => block.type === 'ul')?.value as string[] | undefined)?.slice(0, 3) ?? [];
const homePath = data.locale === 'ko' ? '/ko/' : '/';
const pageStyle = `--accent-border: ${data.accent.border}; --accent-bg: ${data.accent.background}; --accent-text: ${data.accent.text};`;
const iconUrl = new URL(data.iconPath, Astro.site);
const canonicalUrl = new URL(data.canonicalPath, Astro.site);
const enPath = `/apps/${data.source.slug}/`;
const koPath = `/apps/${data.source.slug}/ko/`;
const offerPriceCurrency = meta.priceCurrency ?? (meta.price === 0 ? 'USD' : undefined);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: meta.title,
  operatingSystem: meta.platforms.join(', '),
  applicationCategory: 'UtilitiesApplication',
  applicationSubCategory: copy.android.name || copy.ios.name,
  description: data.seoDescription,
  inLanguage: data.locale,
  image: iconUrl.toString(),
  downloadUrl: [meta.appstore, meta.googleplay].filter(Boolean),
  sameAs: [meta.appstore, meta.googleplay].filter(Boolean),
  publisher: {
    '@type': 'Organization',
    name: 'ONNELLAB',
    url: new URL('/', Astro.site).toString()
  },
  ...(meta.price !== undefined
    ? {
        offers: {
          '@type': 'Offer',
          price: meta.price,
          ...(offerPriceCurrency ? { priceCurrency: offerPriceCurrency } : {}),
          ...(meta.pricing ? { description: meta.pricing } : {})
        }
      }
    : {}),
  url: canonicalUrl.toString()
};
---

<BaseLayout
  title={data.seoTitle}
  description={data.seoDescription}
  canonicalPath={data.canonicalPath}
  lang={data.locale}
  image={data.iconPath}
  jsonLd={jsonLd}
  alternates={[
    { lang: 'en', path: enPath },
    { lang: 'ko', path: koPath },
    { lang: 'x-default', path: enPath }
  ]}
>
  <main class="page-shell" style={pageStyle}>
    <header class="topbar" aria-label="ONNELLAB">
      <a class="brand" href={homePath}>ONNELLAB</a>
      <a class="language" href={data.alternatePath}>{labels.switchLabel}</a>
    </header>

    <section class="hero" aria-labelledby="product-title">
      <div class="hero-grid">
        <div class="identity">
          <img src={data.iconPath} alt={`${meta.title} icon`} width="88" height="88" />
          <div>
            <p class="eyebrow">{labels.status}: {meta.status}</p>
            <h1 id="product-title">{meta.title}</h1>
            {heroIntro && <p class="intro">{heroIntro}</p>}
          </div>
        </div>

        {heroSignals.length > 0 && (
          <div class="task-preview" aria-hidden="true">
            {heroSignals.map((signal, index) => (
              <div class="task-row">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <strong>{signal}</strong>
              </div>
            ))}
          </div>
        )}
      </div>

      <div class="actions" aria-label={labels.stores}>
        <a class="button primary" href={meta.appstore}>{labels.appStore}</a>
        {meta.googleplay && <a class="button primary" href={meta.googleplay}>{labels.googlePlay}</a>}
        <a class="button" href={meta.privacy}>{labels.privacy}</a>
        <a class="button" href={`mailto:${meta.supportEmail}`}>{labels.support}</a>
      </div>

      <dl class="meta-list">
        <div class="meta-pill">
          <dt>{labels.platforms}</dt>
          <dd>
            {meta.platforms.map((platform) => <span>{platform}</span>)}
          </dd>
        </div>
      </dl>
    </section>

    <section class="content-band" aria-label={copy.android.name ?? copy.ios.name ?? meta.title}>
      <div class="copy-column">
        {bodyBlocks.map((block) => (
          block.type === 'h' ? (
            <h2>{block.value}</h2>
          ) : block.type === 'ul' ? (
            <ul>
              {(block.value as string[]).map((item) => <li>{item}</li>)}
            </ul>
          ) : (
            <p>{block.value}</p>
          )
        ))}
      </div>
    </section>

    {data.screenshotPaths.length > 0 && (
      <details class="screens-band">
        <summary>{labels.screens}</summary>
        <div class="screenshot-row">
          {data.screenshotPaths.slice(0, 3).map((screenshotPath, index) => (
            <figure>
              <a
                class="screenshot-link"
                href={screenshotPath}
                data-screenshot-link
                data-screenshot-index={index}
                aria-label={`${meta.title} ${labels.screens} ${index + 1}`}
              >
                <img
                  src={screenshotPath}
                  alt={`${meta.title} ${labels.screens} ${index + 1}`}
                  width="1242"
                  height="2688"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            </figure>
          ))}
        </div>
        <dialog class="screenshot-viewer" aria-label={labels.screens}>
          <div class="viewer-panel">
            <div class="viewer-bar">
              <button class="viewer-close" type="button" data-viewer-close aria-label="Close">×</button>
            </div>
            <div class="viewer-frame">
              <button class="viewer-nav viewer-prev" type="button" data-viewer-prev aria-label="Previous">‹</button>
              <img data-viewer-image alt="" />
              <button class="viewer-nav viewer-next" type="button" data-viewer-next aria-label="Next">›</button>
            </div>
            <div class="viewer-thumbs" aria-label={labels.screens}>
              {data.screenshotPaths.slice(0, 3).map((screenshotPath, index) => (
                <button
                  class="viewer-thumb"
                  type="button"
                  data-viewer-thumb
                  data-screenshot-index={index}
                  aria-label={`${meta.title} ${labels.screens} ${index + 1}`}
                >
                  <img
                    src={screenshotPath}
                    alt=""
                    width="1242"
                    height="2688"
                    loading="lazy"
                    decoding="async"
                  />
                </button>
              ))}
            </div>
          </div>
        </dialog>
      </details>
    )}

    <section class="download-band" aria-label={labels.download}>
      <div>
        <p class="eyebrow">{labels.download}</p>
        <h2>{meta.title}</h2>
      </div>
      <div class="actions compact" aria-label={labels.stores}>
        <a class="button primary" href={meta.appstore}>{labels.appStore}</a>
        {meta.googleplay && <a class="button primary" href={meta.googleplay}>{labels.googlePlay}</a>}
        <a class="button" href={meta.privacy}>{labels.privacy}</a>
      </div>
    </section>

    <footer>
      <span>{meta.title}</span>
      <a href={meta.privacy}>{labels.privacy}</a>
      <a href={`mailto:${meta.supportEmail}`}>{meta.supportEmail}</a>
    </footer>
  </main>
</BaseLayout>

<style>
  .page-shell {
    width: min(980px, calc(100% - 32px));
    margin: 0 auto;
    padding: 22px 0 28px;
  }

  .topbar,
  footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    color: #737067;
    font-size: 14px;
  }

  .brand,
  .language,
  footer a {
    text-decoration: none;
  }

  .brand {
    font-weight: 650;
    color: #37342f;
  }

  .language {
    border: 1px solid #ddd5c8;
    border-radius: 8px;
    padding: 8px 12px;
    background: #fffdf8;
  }

  .hero {
    min-height: calc(100vh - 64px);
    display: grid;
    align-content: center;
    gap: 24px;
    padding: 76px 0 58px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(220px, 300px);
    align-items: center;
    gap: 28px;
  }

  .identity {
    display: grid;
    grid-template-columns: 136px minmax(0, 1fr);
    align-items: start;
    gap: 30px;
  }

  .identity img {
    width: 136px;
    height: 136px;
    border-radius: 28px;
    background: #eee8dd;
    box-shadow: 0 0 0 1px var(--accent-border);
  }

  .eyebrow {
    margin: 0 0 8px;
    color: #827d72;
    font-size: 13px;
    font-weight: 600;
  }

  h1 {
    margin: 0;
    font-size: clamp(52px, 10vw, 96px);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .intro {
    max-width: 560px;
    margin: 18px 0 0;
    color: #5b574f;
    font-size: 19px;
    line-height: 1.55;
  }

  .task-preview {
    border-left: 1px solid var(--accent-border);
    padding-left: 22px;
  }

  .task-row {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr);
    gap: 12px;
    padding: 11px 0;
    border-bottom: 1px solid #e7dfd3;
  }

  .task-row:first-child {
    border-top: 1px solid #e7dfd3;
  }

  .task-row span {
    color: var(--accent-text);
    font-size: 12px;
    font-weight: 700;
  }

  .task-row strong {
    color: #464139;
    font-size: 15px;
    font-weight: 650;
    line-height: 1.45;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-left: 140px;
  }

  .button {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #d6cec0;
    border-radius: 8px;
    padding: 10px 15px;
    background: #fffdf8;
    color: #37342f;
    text-decoration: none;
    font-weight: 620;
  }

  .button.primary {
    background: #3a3630;
    border-color: var(--accent-text);
    color: #fffaf0;
  }

  .meta-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 2px 0 0 140px;
  }

  .meta-pill {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    border: 1px solid var(--accent-border);
    border-radius: 8px;
    padding: 8px 11px;
    background: var(--accent-bg);
  }

  dt {
    color: #827d72;
    font-size: 13px;
  }

  dd {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin: 0;
    color: #464139;
    font-weight: 600;
  }

  dd span {
    border: 1px solid var(--accent-border);
    border-radius: 999px;
    padding: 2px 7px;
    background: #fffdf8;
    color: var(--accent-text);
    font-size: 12px;
    line-height: 1.4;
  }

  .content-band,
  .screens-band,
  .download-band {
    border-top: 1px solid #e0d8cb;
    padding: 44px 0;
  }

  .screens-band summary {
    cursor: pointer;
    color: #37342f;
    font-size: 20px;
    font-weight: 650;
    list-style-position: outside;
  }

  .screenshot-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin-top: 24px;
  }

  figure {
    margin: 0;
    border: 1px solid var(--accent-border);
    border-radius: 8px;
    padding: 8px;
    background: #fffdf8;
  }

  figure img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 6px;
  }

  .screenshot-link {
    display: block;
    border-radius: 6px;
    cursor: zoom-in;
  }

  .screenshot-link:focus-visible {
    outline: 2px solid var(--accent-text);
    outline-offset: 3px;
  }

  .screenshot-link:hover img {
    box-shadow: 0 0 0 1px var(--accent-text);
  }

  .screenshot-viewer {
    width: min(1120px, calc(100vw - 32px));
    max-height: calc(100vh - 32px);
    border: 1px solid rgba(224, 216, 203, 0.72);
    border-radius: 12px;
    padding: 0;
    background: rgba(255, 253, 248, 0.97);
    color: #37342f;
    box-shadow:
      0 22px 70px rgba(55, 50, 43, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.72);
  }

  .screenshot-viewer::backdrop {
    background: rgba(55, 50, 43, 0.76);
  }

  .viewer-panel {
    display: grid;
    gap: 14px;
    padding: 14px;
  }

  .viewer-bar {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .viewer-close,
  .viewer-nav {
    border: 1px solid rgba(214, 206, 192, 0.58);
    border-radius: 8px;
    background: rgba(255, 253, 248, 0.72);
    color: #37342f;
    font: inherit;
    font-weight: 620;
    cursor: pointer;
  }

  .viewer-close:hover,
  .viewer-nav:hover {
    border-color: var(--accent-border);
    background: rgba(255, 253, 248, 0.92);
    color: var(--accent-text);
  }

  .viewer-close {
    width: 34px;
    height: 34px;
    padding: 0;
    font-size: 21px;
    line-height: 1;
  }

  .viewer-frame {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr) 56px;
    align-items: center;
    gap: 12px;
  }

  .viewer-frame img {
    display: block;
    width: auto;
    max-width: 100%;
    max-height: calc(100vh - 194px);
    margin: 0 auto;
    border: 1px solid #e0d8cb;
    border-radius: 10px;
    background: #faf8f5;
  }

  .viewer-nav {
    width: 44px;
    height: 44px;
    justify-self: center;
    padding: 0;
    font-size: 28px;
    line-height: 1;
  }

  .viewer-thumbs {
    display: flex;
    justify-content: center;
    gap: 8px;
    overflow-x: auto;
    padding: 2px 2px 4px;
  }

  .viewer-thumb {
    width: 42px;
    height: 56px;
    flex: 0 0 auto;
    border: 1px solid rgba(214, 206, 192, 0.76);
    border-radius: 8px;
    padding: 2px;
    background: rgba(250, 248, 245, 0.82);
    cursor: pointer;
  }

  .viewer-thumb[aria-current="true"] {
    border-color: var(--accent-text);
    background: #fffdf8;
    box-shadow:
      0 0 0 1px rgba(255, 253, 248, 0.9),
      inset 0 0 0 1px var(--accent-text);
  }

  .viewer-thumb img {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 4px;
    object-fit: cover;
  }

  .viewer-close:focus-visible,
  .viewer-nav:focus-visible,
  .viewer-thumb:focus-visible {
    outline: 2px solid var(--accent-text);
    outline-offset: 2px;
  }

  .download-band {
    display: grid;
    justify-items: center;
    gap: 18px;
    text-align: center;
  }

  .download-band h2 {
    margin: 0;
  }

  .actions.compact {
    justify-content: center;
    margin-left: 0;
  }

  .copy-column {
    max-width: 720px;
  }

  h2 {
    margin: 28px 0 12px;
    font-size: 22px;
    line-height: 1.25;
    letter-spacing: 0;
  }

  h3 {
    margin: 0 0 12px;
    font-size: 20px;
    line-height: 1.3;
    letter-spacing: 0;
  }

  p,
  li {
    color: #4f4b43;
    font-size: 17px;
    line-height: 1.7;
  }

  ul {
    margin: 14px 0 0;
    padding-left: 20px;
  }

  footer {
    border-top: 1px solid #e0d8cb;
    padding-top: 20px;
    flex-wrap: wrap;
  }

  @media (max-width: 680px) {
    .page-shell {
      width: min(100% - 24px, 980px);
    }

    .hero {
      min-height: auto;
      padding: 52px 0 36px;
    }

    .identity,
    .actions,
    .hero-grid {
      display: grid;
      grid-template-columns: 1fr;
    }

    .identity {
      gap: 18px;
    }

    .identity img {
      width: 88px;
      height: 88px;
    }

    .actions,
    .meta-list {
      margin-left: 0;
    }

    .task-preview {
      border-left: 0;
      padding-left: 0;
    }

    .actions.compact {
      justify-content: stretch;
    }

    .screenshot-row {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 4px;
    }

    figure {
      flex: 0 0 min(74vw, 320px);
      scroll-snap-align: start;
    }

    .screenshot-viewer {
      width: min(100vw - 18px, 520px);
    }

    .viewer-panel {
      padding: 10px;
    }

    .viewer-frame {
      grid-template-columns: 1fr 1fr;
    }

    .viewer-frame img {
      grid-column: 1 / -1;
      grid-row: 1;
      max-height: calc(100vh - 204px);
    }

    .viewer-prev,
    .viewer-next {
      grid-row: 2;
    }

    .viewer-thumbs {
      justify-content: flex-start;
    }

    .button {
      width: 100%;
    }
  }
</style>

<script>
  const screenshotLinks = Array.from(document.querySelectorAll('[data-screenshot-link]'));
  const viewer = document.querySelector('.screenshot-viewer');
  const viewerImage = document.querySelector('[data-viewer-image]');
  const closeButton = document.querySelector('[data-viewer-close]');
  const prevButton = document.querySelector('[data-viewer-prev]');
  const nextButton = document.querySelector('[data-viewer-next]');
  const thumbnailButtons = Array.from(document.querySelectorAll('[data-viewer-thumb]'));
  let currentScreenshotIndex = 0;

  const setViewerImage = (index) => {
    if (!viewerImage) return;
    currentScreenshotIndex = (index + screenshotLinks.length) % screenshotLinks.length;
    const link = screenshotLinks[currentScreenshotIndex];
    const image = link.querySelector('img');
    viewerImage.src = link.getAttribute('href');
    viewerImage.alt = image?.getAttribute('alt') || '';
    thumbnailButtons.forEach((button, thumbnailIndex) => {
      if (thumbnailIndex === currentScreenshotIndex) {
        button.setAttribute('aria-current', 'true');
      } else {
        button.removeAttribute('aria-current');
      }
    });
  };

  const openViewer = (index) => {
    if (!viewer || typeof viewer.showModal !== 'function') return;
    setViewerImage(index);
    viewer.showModal();
  };

  const closeViewer = () => {
    if (viewer?.open) viewer.close();
  };

  screenshotLinks.forEach((link, index) => {
    link.addEventListener('click', (event) => {
      if (!viewer || typeof viewer.showModal !== 'function') return;
      event.preventDefault();
      openViewer(index);
    });
  });

  closeButton?.addEventListener('click', closeViewer);
  prevButton?.addEventListener('click', () => setViewerImage(currentScreenshotIndex - 1));
  nextButton?.addEventListener('click', () => setViewerImage(currentScreenshotIndex + 1));
  thumbnailButtons.forEach((button, index) => {
    button.addEventListener('click', () => setViewerImage(index));
  });

  viewer?.addEventListener('click', (event) => {
    if (event.target === viewer) closeViewer();
  });

  document.addEventListener('keydown', (event) => {
    if (!viewer?.open) return;
    if (event.key === 'ArrowLeft') setViewerImage(currentScreenshotIndex - 1);
    if (event.key === 'ArrowRight') setViewerImage(currentScreenshotIndex + 1);
  });
</script>
