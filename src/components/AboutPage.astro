---
import BaseLayout from '../layouts/BaseLayout.astro';
import type { Locale } from '../lib/products';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const isKo = locale === 'ko';
const text = isKo
  ? {
      title: 'ONNELLAB 소개',
      description: 'ONNELLAB은 한국에서 조용하고 신중한 유틸리티 앱을 만드는 독립 앱 스튜디오입니다.',
      heading: 'ONNELLAB 소개',
      studioLabel: 'Independent App Studio',
      intro: [
        '한국에서 조용한 유틸리티 앱을 만듭니다.',
        '신중하게 설계하고, 오프라인에서도 바로 쓸 수 있게 만듭니다.',
        'Flutter • iOS • Android'
      ],
      principlesTitle: '제품 원칙',
      principles: [
        '계정 없이 바로 사용할 수 있는 도구를 우선합니다.',
        '가능한 작업은 기기 안에서 처리하고, 불필요한 업로드를 만들지 않습니다.',
        '한 앱은 한 가지 일을 조용하고 예측 가능하게 끝내도록 설계합니다.'
      ],
      timeline: '타임라인',
      eventLabel: '출시',
      closing: 'ONNELLAB은 작고 오래 쓰는 도구를 계속 만듭니다.',
      contact: '문의하기',
      homeHref: '/ko/',
      switchHref: '/about/',
      switchLabel: 'English',
      email: 'onnellab.app@gmail.com'
    }
  : {
      title: 'About ONNELLAB',
      description: 'ONNELLAB is an independent app studio from Korea focused on thoughtful utilities and offline-first apps.',
      heading: 'About ONNELLAB',
      studioLabel: 'Independent App Studio',
      intro: [
        'Quiet utility apps from Korea.',
        'Built thoughtfully to work offline, simply and reliably.',
        'Flutter • iOS • Android'
      ],
      principlesTitle: 'Product principles',
      principles: [
        'Tools should be usable without creating an account first.',
        'Whenever possible, work should happen on device without unnecessary uploads.',
        'Each app should finish one job quietly and predictably.'
      ],
      timeline: 'Timeline',
      eventLabel: 'launch',
      closing: 'ONNELLAB continues to build small tools made to last.',
      contact: 'Contact',
      homeHref: '/',
      switchHref: '/about/ko/',
      switchLabel: '한국어',
      email: 'onnellab.app@gmail.com'
    };
const canonicalPath = isKo ? '/about/ko/' : '/about/';
const timelineItems = [
  { date: '2026.03.30', displayDate: '2026.03', app: 'TagWeaver', summary: isKo ? 'MP3/FLAC 태그 편집기' : 'MP3/FLAC tag editor' },
  { date: '2026.04.02', displayDate: '2026.04', app: 'Quivra', summary: isKo ? '미디어 변환기' : 'media converter' },
  { date: '2026.04.24', displayDate: '2026.04', repeatedMonth: true, app: 'VaultXT', summary: isKo ? '대용량 TXT 편집기' : 'large TXT editor' },
  { date: '2026.06.25', displayDate: '2026.06', app: 'ClipNest', summary: isKo ? '클립보드 기록' : 'clipboard history' },
  { date: '2026.06.30', displayDate: '2026.06', repeatedMonth: true, app: 'Aligna', summary: isKo ? '일괄 파일명 정리' : 'batch file renamer' },
  { date: '2026.07.01', displayDate: '2026.07', app: 'Segra', summary: isKo ? '오디오 자르기와 병합' : 'audio cutter and merger' }
];
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': new URL(`${canonicalPath}#about`, Astro.site).toString(),
  name: text.title,
  description: text.description,
  url: new URL(canonicalPath, Astro.site).toString(),
  inLanguage: locale,
  mainEntity: {
    '@type': 'Organization',
    '@id': new URL('/#organization', Astro.site).toString(),
    name: 'ONNELLAB',
    url: new URL('/', Astro.site).toString(),
    email: 'onnellab.app@gmail.com'
  }
};
---

<BaseLayout
  title={text.title}
  description={text.description}
  canonicalPath={canonicalPath}
  lang={locale}
  jsonLd={organizationJsonLd}
  alternates={[
    { lang: 'en', path: '/about/' },
    { lang: 'ko', path: '/about/ko/' },
    { lang: 'x-default', path: '/about/' }
  ]}
>
  <main class="page-shell">
    <nav aria-label="Navigation">
      <a class="brand" href={text.homeHref}>ONNELLAB</a>
      <a class="language" href={text.switchHref} data-locale-choice={isKo ? 'en' : 'ko'}>{text.switchLabel}</a>
    </nav>

    <section class="about-hero" aria-labelledby="about-title">
      <p class="studio-label">{text.studioLabel}</p>
      <h1 id="about-title" data-locale={locale}>{text.heading}</h1>
      <div class="intro-lines">
        {text.intro.map((line) => <p>{line}</p>)}
      </div>
      <div class="contact-block">
        <a class="contact-link" href={`mailto:${text.email}`}>{text.contact}</a>
        <p>{text.email}</p>
      </div>
    </section>

    <section class="principles-section" aria-labelledby="principles-title">
      <h2 id="principles-title">{text.principlesTitle}</h2>
      <ul class="principles-list">
        {text.principles.map((principle) => <li>{principle}</li>)}
      </ul>
    </section>

    <section class="timeline-section" aria-labelledby="timeline-title">
      <h2 id="timeline-title">{text.timeline}</h2>
      <ol class="timeline">
        {timelineItems.map((item) => (
          <li>
            <time class:list={[item.repeatedMonth && 'is-repeated']} datetime={item.date.replace(/\./g, '-')}>
              {item.displayDate}
            </time>
            <div>
              <span>{item.app} {text.eventLabel}</span>
              <p>{item.summary}</p>
            </div>
          </li>
        ))}
      </ol>
      <p class="closing-line">{text.closing}</p>
    </section>
  </main>
</BaseLayout>

<style>
  .page-shell {
    width: min(900px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 44px;
    line-height: 1.65;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .brand,
  .language,
  .contact-link {
    text-decoration: none;
  }

  .brand {
    color: #737067;
    font-size: 14px;
    font-weight: 560;
  }

  .language,
  .contact-link {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    border: 1px solid #ded6ca;
    border-radius: 999px;
    padding: 6px 12px;
    background: rgba(255, 253, 248, 0.72);
    color: #5f5a50;
    font-size: 13px;
    font-weight: 650;
    line-height: 1.35;
  }

  .language:hover,
  .language:focus-visible,
  .contact-link:hover,
  .contact-link:focus-visible {
    border-color: #cfc5b7;
    background: #fffdf8;
  }

  .language:focus-visible,
  .contact-link:focus-visible,
  .brand:focus-visible {
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }

  .about-hero {
    padding: 56px 0 42px;
    border-bottom: 1px solid #e0d8cb;
  }

  .studio-label {
    margin: 0 0 12px;
    color: #827d72;
    font-size: 12px;
    font-weight: 680;
    line-height: 1.4;
  }

  h1 {
    margin: 0;
    color: #36332f;
    font-size: clamp(40px, 7vw, 72px);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .intro-lines {
    max-width: 620px;
    margin-top: 24px;
    color: #514d46;
    font-size: clamp(18px, 2.5vw, 22px);
    line-height: 1.56;
  }

  .intro-lines p {
    margin: 0;
  }

  .intro-lines p + p {
    margin-top: 6px;
  }

  .contact-block {
    margin-top: 28px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .contact-block p {
    margin: 0;
    color: #81786b;
    font-size: 14px;
    line-height: 1.5;
  }

  .timeline-section {
    position: relative;
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr);
    gap: 48px;
    padding-top: 42px;
  }

  .principles-section {
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr);
    gap: 48px;
    padding: 38px 0;
    border-bottom: 1px solid #e0d8cb;
  }

  .principles-list {
    display: grid;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .principles-list li {
    position: relative;
    padding-left: 18px;
    color: #514d46;
    font-size: 16px;
    line-height: 1.62;
  }

  .principles-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 11px;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: #c8b99e;
  }

  .timeline-section::before {
    content: "";
    position: absolute;
    top: 42px;
    left: 180px;
    bottom: 0;
    width: 1px;
    background: linear-gradient(180deg, rgba(185, 173, 157, 0.28), rgba(250, 248, 245, 0));
  }

  h2 {
    margin: 0;
    color: #6b655b;
    font-size: 14px;
    font-weight: 720;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .timeline {
    display: grid;
    gap: 17px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .timeline li {
    display: grid;
    grid-template-columns: 116px minmax(0, 1fr);
    gap: 20px;
    align-items: baseline;
    padding-bottom: 17px;
    border-bottom: 1px solid rgba(232, 224, 212, 0.58);
  }

  .timeline time {
    color: #8f8679;
    font-size: 13px;
    font-variant-numeric: tabular-nums;
  }

  .timeline time.is-repeated {
    color: #aaa196;
  }

  .timeline span {
    color: #37332f;
    font-size: 20px;
    font-weight: 600;
  }

  .timeline p {
    margin: 2px 0 0;
    color: #81786b;
    font-size: 14px;
    line-height: 1.45;
  }

  .closing-line {
    grid-column: 2;
    margin: 14px 0 0;
    color: #5f5a50;
    font-size: 16px;
    line-height: 1.65;
  }

  @media (max-width: 680px) {
    .page-shell {
      width: min(100% - 28px, 900px);
      padding-top: 18px;
    }

    .about-hero {
      padding: 42px 0 34px;
    }

    h1[data-locale='ko'] {
      font-size: clamp(30px, 9vw, 40px);
      line-height: 1.06;
      white-space: nowrap;
    }

    .timeline-section {
      grid-template-columns: 1fr;
      gap: 18px;
      padding-top: 32px;
    }

    .principles-section {
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 30px 0;
    }

    .timeline-section::before {
      display: none;
    }

    .timeline li {
      grid-template-columns: 1fr;
      gap: 3px;
      padding-bottom: 16px;
    }

    .timeline span {
      font-size: 18px;
      line-height: 1.32;
    }

    .timeline time {
      font-size: 12px;
      line-height: 1.4;
    }

    .closing-line {
      grid-column: 1;
      margin-top: 10px;
      font-size: 15px;
    }

    .contact-block {
      align-items: flex-start;
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
