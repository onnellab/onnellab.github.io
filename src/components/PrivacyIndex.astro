---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProductIndexItems, type Locale } from '../lib/products';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const privacyUpdatedAtByTitle: Record<string, string> = {
  Quivra: '2026-02-10',
  TagWeaver: '2026-02-14',
  VaultXT: '2026-03-11',
  Segra: '2026-06-12',
  ClipNest: '2026-06-13',
  Aligna: '2026-06-24',
  Melivra: '2026-07-09'
};
const contentApps = getProductIndexItems(locale);
const contentAppTitles = new Set(contentApps.map((app) => app.title));
const staticPrivacyApps = [
  { title: 'Quivra', href: 'https://onnellab.github.io/quivra-privacy-policy/' },
  { title: 'TagWeaver', href: 'https://onnellab.github.io/tagweaver-privacy-policy/' },
  { title: 'VaultXT', href: 'https://onnellab.github.io/vaultxt-privacy-policy/' },
  { title: 'Segra', href: 'https://onnellab.github.io/segra-privacy-policy/' },
  { title: 'ClipNest', href: 'https://onnellab.github.io/clipnest-privacy-policy/' },
  { title: 'Melivra', href: 'https://onnellab.github.io/melivra-privacy-policy/' }
].filter((app) => !contentAppTitles.has(app.title));
const privacyDate = (title: string) => privacyUpdatedAtByTitle[title] ?? '9999-12-31';
const localizedPolicyHref = (href: string) => {
  if (locale !== 'ko') return href;
  return href.replace(/\/?$/, '/ko/');
};
const policies = [
  ...contentApps
    .filter((app) => app.privacy)
    .map((app) => ({
      title: app.title,
      href: localizedPolicyHref(app.privacy),
      date: privacyDate(app.title),
      platforms: app.platforms
    })),
  ...staticPrivacyApps.map((app) => ({
    title: app.title,
    href: localizedPolicyHref(app.href),
    date: privacyDate(app.title),
    platforms: [] as string[]
  }))
].sort((a, b) => a.title.localeCompare(b.title));

const text =
  locale === 'ko'
    ? {
        title: 'ONNELLAB 개인정보 처리방침',
        description: 'ONNELLAB 앱별 개인정보 처리방침 링크를 정리한 페이지입니다.',
        heading: '개인정보 처리방침',
        searchLabel: '앱 찾기',
        searchPlaceholder: '앱 이름 검색',
        empty: '일치하는 앱이 없습니다.',
        updated: '작성 날짜',
        home: 'ONNELLAB',
        noticeTitle: '사이트 이용 분석',
        noticeBody: 'ONNELLAB 웹사이트는 서비스 개선을 위해 Google Analytics가 설정된 경우에만 페이지 방문, 언어 전환, 스토어 이동, 스크린샷 열람 같은 집계 이벤트를 측정할 수 있습니다. 앱 안의 파일 내용, 태그 값, 계정 정보는 수집하지 않습니다.',
        sitePrivacyTitle: 'ONNELLAB 웹사이트 개인정보',
        sitePrivacyBody: 'ONNELLAB 웹사이트는 자체 콘텐츠와 앱 정보를 제공하기 위해 운영됩니다. X, Bluesky, Dev.to 같은 외부 게시 API는 ONNELLAB 계정의 승인된 콘텐츠 게시와 기본 인증 확인에만 사용하며, 타인의 소셜 데이터, 타임라인, 팔로워, 다이렉트 메시지를 수집하거나 판매하지 않습니다.',
        contactTitle: '문의',
        contactBody: '개인정보 관련 문의는 onnellab.app@gmail.com 으로 연락할 수 있습니다.',
        switchLabel: 'English',
        switchHref: '/privacy/',
        homeHref: '/ko/'
      }
    : {
        title: 'ONNELLAB Privacy Policies',
        description: 'Privacy policy links for ONNELLAB apps.',
        heading: 'Privacy Policies',
        searchLabel: 'Find app',
        searchPlaceholder: 'Search app name',
        empty: 'No matching apps.',
        updated: 'Policy date',
        home: 'ONNELLAB',
        noticeTitle: 'Website analytics',
        noticeBody: 'When Google Analytics is configured, the ONNELLAB website may measure aggregate events such as page visits, language switches, store clicks, and screenshot opens to improve the site. It does not collect app file contents, tag values, or account information.',
        sitePrivacyTitle: 'ONNELLAB website privacy',
        sitePrivacyBody: 'The ONNELLAB website provides original content and product information. External publishing APIs such as X, Bluesky, and Dev.to are used only to publish approved ONNELLAB-owned content and verify credentials for ONNELLAB-controlled accounts. ONNELLAB does not collect, sell, or analyze other users’ social data, timelines, followers, or direct messages.',
        contactTitle: 'Contact',
        contactBody: 'For privacy questions, contact onnellab.app@gmail.com.',
        switchLabel: '한국어',
        switchHref: '/privacy/ko/',
        homeHref: '/'
      };
const canonicalPath = locale === 'ko' ? '/privacy/ko/' : '/privacy/';
const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': new URL(`${canonicalPath}#privacy-policies`, Astro.site).toString(),
  name: text.title,
  description: text.description,
  url: new URL(canonicalPath, Astro.site).toString(),
  inLanguage: locale,
  isPartOf: {
    '@id': new URL('/#website', Astro.site).toString()
  },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: policies.map((policy, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: `${policy.title} Privacy Policy`,
      url: policy.href
    }))
  }
};
---

<BaseLayout
  title={text.title}
  description={text.description}
  canonicalPath={canonicalPath}
  lang={locale}
  jsonLd={collectionJsonLd}
  alternates={[
    { lang: 'en', path: '/privacy/' },
    { lang: 'ko', path: '/privacy/ko/' },
    { lang: 'x-default', path: '/privacy/' }
  ]}
>
  <main class="page-shell">
    <nav aria-label="Navigation">
      <a class="brand" href={text.homeHref}>{text.home}</a>
      <a class="language" href={text.switchHref} data-locale-choice={locale === 'ko' ? 'en' : 'ko'} aria-label={locale === 'ko' ? 'Switch to English' : '한국어로 보기'} title={locale === 'ko' ? 'English' : '한국어'}>{text.switchLabel}</a>
    </nav>

    <header>
      <h1>{text.heading}</h1>
      <div class="header-rule" aria-hidden="true"></div>
    </header>

    <label class="policy-search">
      <span>{text.searchLabel}</span>
      <input type="search" placeholder={text.searchPlaceholder} data-policy-search />
    </label>

    <p class="empty-state" data-policy-empty hidden>{text.empty}</p>

    <section class="privacy-notice" aria-labelledby="privacy-analytics-title">
      <h2 id="privacy-analytics-title">{text.noticeTitle}</h2>
      <p>{text.noticeBody}</p>
    </section>

    <section class="privacy-notice" aria-labelledby="privacy-site-title">
      <h2 id="privacy-site-title">{text.sitePrivacyTitle}</h2>
      <p>{text.sitePrivacyBody}</p>
      <p>{text.contactBody}</p>
    </section>

    <section class="policy-list" aria-label={text.heading}>
      {policies.map((policy) => (
        <a class="policy-row" href={policy.href} data-policy-row data-policy-title={policy.title.toLowerCase()}>
          <div>
            <h2>{policy.title}</h2>
            <p>
              <span>{text.updated}</span>
              {' '}
              <time datetime={policy.date}>{policy.date}</time>
            </p>
          </div>
          {policy.platforms.length > 0 && (
            <div class="platform-badges" aria-label="Platforms">
              {policy.platforms.map((platform) => <span>{platform}</span>)}
            </div>
          )}
        </a>
      ))}
    </section>
    <script is:inline>
      (() => {
        const policySearch = document.querySelector('[data-policy-search]');
        const policyRows = Array.from(document.querySelectorAll('[data-policy-row]'));
        if (!(policySearch instanceof HTMLInputElement)) return;

        policySearch.addEventListener('input', () => {
          const query = policySearch.value.trim().toLowerCase();
          let visibleCount = 0;
          policyRows.forEach((row) => {
            const title = row.getAttribute('data-policy-title') ?? '';
            const isHidden = query.length > 0 && !title.includes(query);
            row.hidden = isHidden;
            if (!isHidden) visibleCount += 1;
          });
          const emptyState = document.querySelector('[data-policy-empty]');
          if (emptyState instanceof HTMLElement) emptyState.hidden = visibleCount > 0;
        });
      })();
    </script>
  </main>
</BaseLayout>

<style>
  .page-shell {
    width: min(900px, calc(100% - 36px));
    margin: 0 auto;
    padding: 28px 0 44px;
    line-height: 1.7;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .brand,
  .language,
  .policy-row {
    text-decoration: none;
  }

  .brand {
    color: #737067;
    font-size: 14px;
    font-weight: 560;
  }

  .language {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    border: 1px solid #ded6ca;
    border-radius: 999px;
    padding: 6px 12px;
    background: rgba(255, 253, 248, 0.72);
    color: #5f5a50;
    font-size: 13px;
    font-weight: 650;
    line-height: 1.35;
    text-decoration: none;
  }

  .language:hover,
  .language:focus-visible {
    border-color: #cfc5b7;
    background: #fffdf8;
  }

  .language:focus-visible {
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }

  header {
    padding-top: 34px;
  }

  h1 {
    margin: 0;
    color: #383631;
    font-size: clamp(40px, 6.4vw, 66px);
    line-height: 1;
    letter-spacing: 0;
    word-break: keep-all;
  }

  .header-rule {
    width: 62px;
    height: 2px;
    margin-top: 18px;
    background: linear-gradient(90deg, #b9ad9d, rgba(207, 197, 183, 0));
  }

  .policy-list {
    display: grid;
    gap: 0;
    width: min(100%, 820px);
    border-top: 1px solid #e0d8cb;
    border-bottom: 1px solid #e0d8cb;
    margin-top: 18px;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.78), rgba(255, 253, 248, 0.2)),
      transparent;
  }

  .privacy-notice {
    width: min(100%, 820px);
    border-top: 1px solid #e0d8cb;
    border-bottom: 1px solid #e0d8cb;
    margin-top: 18px;
    padding: 18px 0;
    color: #5f5a50;
  }

  .privacy-notice h2 {
    margin: 0 0 8px;
    color: #383631;
    font-size: 17px;
    line-height: 1.35;
  }

  .privacy-notice p {
    margin: 0;
    font-size: 14px;
    line-height: 1.7;
  }

  .policy-search {
    display: grid;
    gap: 8px;
    max-width: 320px;
    margin-top: 28px;
    color: #6f695f;
    font-size: 13px;
    font-weight: 620;
  }

  .policy-search input {
    min-height: 42px;
    border: 1px solid #ded6ca;
    border-radius: 8px;
    padding: 9px 12px;
    background: rgba(255, 253, 248, 0.74);
    color: #3f3b35;
    font: inherit;
    font-weight: 500;
  }

  .policy-search input:focus {
    border-color: #cfc5b7;
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }

  .empty-state {
    border-top: 1px solid #e0d8cb;
    border-bottom: 1px solid #e0d8cb;
    margin: 18px 0 0;
    padding: 18px 0;
    color: #827d72;
    font-size: 14px;
    line-height: 1.5;
  }

  .policy-row {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(120px, auto);
    align-items: center;
    gap: 20px;
    border-bottom: 1px solid #e9e1d5;
    padding: 19px 18px;
    color: inherit;
    transition: background 140ms ease, border-color 140ms ease, color 140ms ease, box-shadow 140ms ease;
  }

  .policy-row::after {
    content: "";
    width: 14px;
    height: 1px;
    position: absolute;
    right: 16px;
    bottom: 14px;
    background: linear-gradient(90deg, rgba(207, 197, 183, 0), rgba(185, 173, 157, 0.58));
    opacity: 0;
    transition: opacity 140ms ease;
  }

  .policy-row[hidden] {
    display: none;
  }

  .policy-row:last-child {
    border-bottom: 0;
  }

  .policy-row:hover,
  .policy-row:focus-visible {
    border-bottom-color: #d4c7b6;
    background:
      linear-gradient(90deg, #fffdf8, rgba(250, 248, 245, 0.74)),
      #fffdf8;
    box-shadow:
      inset 0 1px 0 rgba(255, 253, 248, 0.78),
      inset 0 -1px 0 rgba(210, 199, 184, 0.62),
      0 8px 18px rgba(58, 49, 38, 0.04);
  }

  .policy-row:hover h2,
  .policy-row:focus-visible h2 {
    color: #2f2d29;
  }

  .policy-row:hover::after,
  .policy-row:focus-visible::after {
    opacity: 0.9;
  }

  .policy-row:focus-visible {
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }

  h2 {
    margin: 0 0 6px;
    color: #3f3b35;
    font-size: 21px;
    font-weight: 650;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .policy-row p {
    margin: 0;
    color: #746d62;
    font-size: 13px;
    line-height: 1.45;
  }

  .policy-row p span {
    color: #6f695f;
    font-weight: 620;
  }

  .policy-row time {
    color: #746d62;
    font-variant-numeric: tabular-nums;
  }

  .platform-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 5px;
    min-width: 0;
  }

  .platform-badges span {
    border: 1px solid #ddd5c8;
    border-radius: 999px;
    padding: 2px 7px;
    background: #fffdf8;
    color: #737067;
    font-size: 12px;
    line-height: 1.4;
  }

  @media (max-width: 680px) {
    .page-shell {
      width: min(100% - 28px, 900px);
      padding-top: 24px;
    }

    header {
      padding-top: 34px;
    }

    h1 {
      max-width: 7.5em;
      font-size: clamp(36px, 10.5vw, 42px);
      line-height: 1.08;
    }

    .header-rule {
      width: 54px;
      margin-top: 18px;
    }

    .policy-list {
      width: 100%;
      margin-top: 15px;
    }

    .policy-search {
      max-width: none;
      margin-top: 28px;
    }

    .policy-row {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 9px;
      padding: 16px 14px;
    }

    .policy-row::after {
      right: 12px;
      bottom: 12px;
    }

    .platform-badges {
      justify-content: flex-start;
    }
  }
</style>
