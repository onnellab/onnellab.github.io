---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProductIndexItems, type Locale } from '../lib/products';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const privacyUpdatedAtByTitle: Record<string, string> = {
  Quivra: '2026-02-10',
  TagWeaver: '2026-02-14',
  VaultXT: '2026-03-11',
  Segra: '2026-06-12',
  ClipNest: '2026-06-13',
  Aligna: '2026-06-24',
  Melivra: '2026-06-24'
};
const contentApps = getProductIndexItems(locale);
const contentAppTitles = new Set(contentApps.map((app) => app.title));
const staticPrivacyApps = [
  { title: 'Quivra', href: 'https://onnelakin.github.io/quivra-privacy-policy/' },
  { title: 'TagWeaver', href: 'https://onnelakin.github.io/tagweaver-privacy-policy/' },
  { title: 'VaultXT', href: 'https://onnelakin.github.io/vaultxt-privacy-policy/' },
  { title: 'Segra', href: 'https://onnelakin.github.io/segra-privacy-policy/' },
  { title: 'ClipNest', href: 'https://onnelakin.github.io/clipnest-privacy-policy/' },
  { title: 'Melivra', href: 'https://onnelakin.github.io/melivra-privacy-policy/' }
].filter((app) => !contentAppTitles.has(app.title));
const privacyDate = (title: string) => privacyUpdatedAtByTitle[title] ?? '9999-12-31';
const policies = [
  ...contentApps
    .filter((app) => app.privacy)
    .map((app) => ({
      title: app.title,
      href: app.privacy,
      date: privacyDate(app.title),
      platforms: app.platforms
    })),
  ...staticPrivacyApps.map((app) => ({
    title: app.title,
    href: app.href,
    date: privacyDate(app.title),
    platforms: [] as string[]
  }))
].sort((a, b) => a.title.localeCompare(b.title));

const text =
  locale === 'ko'
    ? {
        title: 'ONNELLAB 개인정보처리방침',
        description: 'ONNELLAB 앱별 개인정보처리방침 링크를 정리한 페이지입니다.',
        heading: '개인정보 처리방침',
        searchLabel: '앱 찾기',
        searchPlaceholder: '앱 이름 검색',
        updated: '작성 날짜',
        home: 'ONNELLAB',
        switchLabel: 'English',
        switchHref: '/privacy/',
        homeHref: '/ko/'
      }
    : {
        title: 'ONNELLAB Privacy Policies',
        description: 'Privacy policy links for ONNELLAB apps.',
        heading: 'Privacy Policies',
        searchLabel: 'Find app',
        searchPlaceholder: 'Search app name',
        updated: 'Policy date',
        home: 'ONNELLAB',
        switchLabel: '한국어',
        switchHref: '/privacy/ko/',
        homeHref: '/'
      };
---

<BaseLayout
  title={text.title}
  description={text.description}
  canonicalPath={locale === 'ko' ? '/privacy/ko/' : '/privacy/'}
  lang={locale}
  alternates={[
    { lang: 'en', path: '/privacy/' },
    { lang: 'ko', path: '/privacy/ko/' },
    { lang: 'x-default', path: '/privacy/' }
  ]}
>
  <main class="page-shell">
    <nav aria-label="Navigation">
      <a class="brand" href={text.homeHref}>{text.home}</a>
      <a class="language" href={text.switchHref} data-locale-choice={locale === 'ko' ? 'en' : 'ko'}>{text.switchLabel}</a>
    </nav>

    <header>
      <h1>{text.heading}</h1>
      <div class="header-rule" aria-hidden="true"></div>
    </header>

    <label class="policy-search">
      <span>{text.searchLabel}</span>
      <input type="search" placeholder={text.searchPlaceholder} data-policy-search />
    </label>

    <section class="policy-list" aria-label={text.heading}>
      {policies.map((policy) => (
        <a class="policy-row" href={policy.href} data-policy-row data-policy-title={policy.title.toLowerCase()}>
          <div>
            <h2>{policy.title}</h2>
            <p>
              <span>{text.updated}</span>
              {' '}
              <time datetime={policy.date}>{policy.date}</time>
            </p>
          </div>
          {policy.platforms.length > 0 && (
            <div class="platform-badges" aria-label="Platforms">
              {policy.platforms.map((platform) => <span>{platform}</span>)}
            </div>
          )}
        </a>
      ))}
    </section>
    <script is:inline>
      (() => {
        const policySearch = document.querySelector('[data-policy-search]');
        const policyRows = Array.from(document.querySelectorAll('[data-policy-row]'));
        if (!(policySearch instanceof HTMLInputElement)) return;

        policySearch.addEventListener('input', () => {
          const query = policySearch.value.trim().toLowerCase();
          policyRows.forEach((row) => {
            const title = row.getAttribute('data-policy-title') ?? '';
            row.hidden = query.length > 0 && !title.includes(query);
          });
        });
      })();
    </script>
  </main>
</BaseLayout>

<style>
  .page-shell {
    width: min(900px, calc(100% - 36px));
    margin: 0 auto;
    padding: 28px 0 44px;
    line-height: 1.7;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .brand,
  .language,
  .policy-row {
    text-decoration: none;
  }

  .brand {
    color: #737067;
    font-size: 14px;
    font-weight: 650;
  }

  .language {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    border: 1px solid #ded6ca;
    border-radius: 999px;
    padding: 6px 12px;
    background: rgba(255, 253, 248, 0.72);
    color: #5f5a50;
    font-size: 13px;
    font-weight: 650;
    line-height: 1.35;
  }

  .language:hover,
  .language:focus-visible {
    border-color: #cfc5b7;
    background: #fffdf8;
  }

  .language:focus-visible {
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }

  header {
    padding-top: 58px;
  }

  h1 {
    margin: 0;
    color: #383631;
    font-size: clamp(44px, 7vw, 70px);
    line-height: 1;
    letter-spacing: 0;
    word-break: keep-all;
  }

  .header-rule {
    width: 62px;
    height: 2px;
    margin-top: 24px;
    background: linear-gradient(90deg, #b9ad9d, rgba(207, 197, 183, 0));
  }

  .policy-list {
    display: grid;
    gap: 0;
    border-top: 1px solid #e0d8cb;
    border-bottom: 1px solid #e0d8cb;
    margin-top: 18px;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.7), rgba(255, 253, 248, 0)),
      transparent;
  }

  .policy-search {
    display: grid;
    gap: 8px;
    max-width: 320px;
    margin-top: 36px;
    color: #6f695f;
    font-size: 13px;
    font-weight: 620;
  }

  .policy-search input {
    min-height: 40px;
    border: 1px solid #ded6ca;
    border-radius: 8px;
    padding: 8px 11px;
    background: rgba(255, 253, 248, 0.74);
    color: #3f3b35;
    font: inherit;
    font-weight: 500;
  }

  .policy-search input:focus {
    border-color: #cfc5b7;
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }

  .policy-row {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 24px;
    border-bottom: 1px solid #e9e1d5;
    padding: 19px 16px;
    color: inherit;
    transition: background 140ms ease, border-color 140ms ease;
  }

  .policy-row[hidden] {
    display: none;
  }

  .policy-row:last-child {
    border-bottom: 0;
  }

  .policy-row:hover,
  .policy-row:focus-visible {
    border-bottom-color: #ddd2c3;
    background: linear-gradient(90deg, rgba(255, 253, 248, 0.94), rgba(255, 253, 248, 0.36));
  }

  .policy-row::before {
    content: "";
    position: absolute;
    inset: 19px auto 19px 0;
    width: 2px;
    background: #cfc5b7;
    opacity: 0;
    transition: opacity 140ms ease;
  }

  .policy-row:hover::before,
  .policy-row:focus-visible::before {
    opacity: 1;
  }

  .policy-row:focus-visible {
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }

  h2 {
    margin: 0 0 6px;
    color: #3f3b35;
    font-size: 21px;
    font-weight: 650;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .policy-row p {
    margin: 0;
    color: #827d72;
    font-size: 13px;
    line-height: 1.45;
  }

  .policy-row p span {
    color: #6f695f;
    font-weight: 620;
  }

  .policy-row time {
    color: #827d72;
    font-variant-numeric: tabular-nums;
  }

  .platform-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 5px;
  }

  .platform-badges span {
    border: 1px solid #ddd5c8;
    border-radius: 999px;
    padding: 2px 7px;
    background: #fffdf8;
    color: #737067;
    font-size: 12px;
    line-height: 1.4;
  }

  @media (max-width: 680px) {
    .page-shell {
      width: min(100% - 28px, 900px);
      padding-top: 24px;
    }

    header {
      padding-top: 42px;
    }

    h1 {
      max-width: 7.5em;
      font-size: clamp(38px, 11vw, 44px);
      line-height: 1.08;
    }

    .header-rule {
      width: 54px;
      margin-top: 18px;
    }

    .policy-list {
      margin-top: 16px;
    }

    .policy-search {
      max-width: none;
      margin-top: 30px;
    }

    .policy-row {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 8px;
      padding: 15px 12px;
    }

    .platform-badges {
      justify-content: flex-start;
    }
  }
</style>
