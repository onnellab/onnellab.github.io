---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProductIndexItems, type Locale, type ProductIndexItem } from '../lib/products';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const contentApps = getProductIndexItems(locale);
const contentAppTitles = new Set(contentApps.map((app) => app.title));
const privacyUpdatedAtByTitle: Record<string, string> = {
  Quivra: '2026-02-10',
  TagWeaver: '2026-02-14',
  VaultXT: '2026-03-11',
  Segra: '2026-06-12',
  ClipNest: '2026-06-13',
  Aligna: '2026-06-24',
  Melivra: '2026-06-24'
};
const privacyDate = (title: string) => privacyUpdatedAtByTitle[title] ?? '9999-12-31';
const comparePrivacyDate = (a: string, b: string) =>
  privacyDate(a).localeCompare(privacyDate(b)) || a.localeCompare(b);
const compareAppPrivacyDate = (a: ProductIndexItem, b: ProductIndexItem) =>
  comparePrivacyDate(a.title, b.title);
const privacyApps = contentApps.filter((app) => app.privacy).sort(compareAppPrivacyDate);
const releasedApps = ['Quivra', 'TagWeaver', 'VaultXT', 'Segra', 'ClipNest', 'Aligna'].sort(
  comparePrivacyDate
);
const releasedAppCards = releasedApps
  .map((name) => contentApps.find((app) => app.title === name))
  .filter((app): app is ProductIndexItem => app !== undefined);
const featuredApp = releasedAppCards.find((app) => app.title === 'TagWeaver') ?? releasedAppCards[0];
const listedAppCards = releasedAppCards.filter((app) => app.title !== featuredApp?.title);
const appCardStyle = (app: ProductIndexItem) =>
  `--accent-border: ${app.accent.border}; --accent-bg: ${app.accent.background}; --accent-text: ${app.accent.text};`;
const staticPrivacyApps = [
  { title: 'Quivra', href: 'https://onnelakin.github.io/quivra-privacy-policy/' },
  { title: 'TagWeaver', href: 'https://onnelakin.github.io/tagweaver-privacy-policy/' },
  { title: 'VaultXT', href: 'https://onnelakin.github.io/vaultxt-privacy-policy/' },
  { title: 'Segra', href: 'https://onnelakin.github.io/segra-privacy-policy/' },
  { title: 'ClipNest', href: 'https://onnelakin.github.io/clipnest-privacy-policy/' },
  { title: 'Melivra', href: 'https://onnelakin.github.io/melivra-privacy-policy/' }
]
  .filter((app) => !contentAppTitles.has(app.title))
  .sort((a, b) => comparePrivacyDate(a.title, b.title));

const text =
  locale === 'ko'
    ? {
        title: 'ONNELLAB - 조용하고 구조적인 디지털 도구',
        description:
          'ONNELLAB은 음악, 텍스트, 오디오, 파일, 생산성을 위한 조용하고 구조적인 앱을 만드는 독립 소프트웨어 스튜디오입니다.',
        intro:
          '파일, 텍스트, 오디오, 음악 작업을 위한 작고 집중된 도구를 만듭니다.',
        focus:
          '빠르게 열리고, 조용히 머물며, 한 가지 일을 정확히 끝내는 앱에 집중합니다.',
        studioLabel: 'Independent App Studio',
        metaItems: ['iOS / Android', 'Privacy-conscious', 'Utility apps'],
        released: '출시된 앱',
        featured: '대표 앱',
        allApps: '전체 앱 페이지',
        allAppsHref: '/apps/ko/',
        openApp: '열기',
        upcoming: '예정 프로젝트',
        upcomingItems: ['Papira', 'FloMo', 'Nunote', 'Textoria', 'Heara'],
        privacy: '개인정보처리방침',
        contact: '문의',
        inquiry: '문의:',
        soon: '출시 예정',
        switchLabel: 'English',
        switchHref: '/'
      }
    : {
        title: 'ONNELLAB - Calm, Structured Digital Tools',
        description:
          'ONNELLAB is an independent software studio creating calm, structured apps for music, text, audio, files, and productivity.',
        intro:
          'Small, focused apps for file, text, audio, and music work.',
        focus:
          'Built to open quickly, stay quiet, and finish one task clearly.',
        studioLabel: 'Independent App Studio',
        metaItems: ['iOS / Android', 'Privacy-conscious', 'Utility apps'],
        released: 'Released Apps',
        featured: 'Featured App',
        allApps: 'All app pages',
        allAppsHref: '/apps/',
        openApp: 'Open',
        upcoming: 'Upcoming Projects',
        upcomingItems: ['Papira', 'FloMo', 'Nunote', 'Textoria', 'Heara'],
        privacy: 'Privacy Policy',
        contact: 'Contact',
        inquiry: 'For inquiries:',
        soon: 'Coming Soon',
        switchLabel: '한국어',
        switchHref: '/ko/'
      };
---

<BaseLayout
  title={text.title}
  description={text.description}
  canonicalPath={locale === 'ko' ? '/ko/' : '/'}
  lang={locale}
  alternates={[
    { lang: 'en', path: '/' },
    { lang: 'ko', path: '/ko/' },
    { lang: 'x-default', path: '/' }
  ]}
>
  <main class="page-shell">
    <nav aria-label="Language">
      <a href={text.switchHref}>{text.switchLabel}</a>
    </nav>

    <section class="home-hero" aria-label="ONNELLAB">
      <p class="studio-label">{text.studioLabel}</p>
      <h1>ONNELLAB</h1>
      <div class="intro-block">
        <p>{text.intro}</p>
        <p>{text.focus}</p>
      </div>
      <div class="home-meta" aria-label="ONNELLAB focus">
        {text.metaItems.map((item) => <span>{item}</span>)}
      </div>
    </section>

    {featuredApp && (
      <section
        class="featured"
        aria-label={text.featured}
        style={appCardStyle(featuredApp)}
      >
        <div class="featured-icon">
          <img src={featuredApp.iconPath} alt={`${featuredApp.title} icon`} width="72" height="72" />
        </div>
        <div class="featured-copy">
          <span class="featured-label">{text.featured}</span>
          <h2>{featuredApp.title}</h2>
          <p>{featuredApp.description}</p>
          <div class="featured-meta app-meta">
            <span>{featuredApp.status}</span>
            <div class="platform-badges" aria-label="Platforms">
              {featuredApp.platforms.map((platform) => <span>{platform}</span>)}
            </div>
          </div>
        </div>
        <a class="featured-link" href={featuredApp.href}>{text.openApp}</a>
      </section>
    )}

    <h2>{text.released}</h2>

    <section class="tool-list" aria-label={text.released}>
      {listedAppCards.map((app) => (
        <article class="tool-row" style={appCardStyle(app)}>
          <img src={app.iconPath} alt="" width="38" height="38" />
          <div>
            <h3>{app.title}</h3>
            <p>{app.description}</p>
            <div class="app-meta">
              <span>{app.status}</span>
              <div class="platform-badges" aria-label="Platforms">
                {app.platforms.map((platform) => <span>{platform}</span>)}
              </div>
            </div>
          </div>
          <a href={app.href}>{text.openApp}</a>
        </article>
      ))}
    </section>

    <p><a href={text.allAppsHref}>{text.allApps}</a></p>

    <h2>{text.upcoming}</h2>

    <p class="inline-list">
      <span>Melivra</span>
      <span aria-hidden="true">/</span>
      {text.upcomingItems.map((item, index) => (
        <>
          <span>{item}</span>
          {index < text.upcomingItems.length - 1 && <span aria-hidden="true">/</span>}
        </>
      ))}
    </p>

    <h2>{text.privacy}</h2>

    <ul>
      {privacyApps.map((app) => <li><a href={app.privacy}>{app.title}</a></li>)}
      {staticPrivacyApps.map((app) => <li><a href={app.href}>{app.title}</a></li>)}
    </ul>

    <h2>{text.contact}</h2>

    <p>
      {text.inquiry}
      {' '}
      <a href="mailto:onnellab.app@gmail.com">onnellab.app@gmail.com</a>
    </p>
  </main>
</BaseLayout>

<style>
  .page-shell {
    max-width: 820px;
    margin: 80px auto;
    padding: 0 24px;
    line-height: 1.75;
  }

  nav {
    text-align: right;
    font-size: 14px;
  }

  nav a {
    text-decoration: none;
  }

  .home-hero {
    margin-top: 54px;
    padding-bottom: 4px;
  }

  .studio-label {
    margin: 0 0 10px;
    color: #827d72;
    font-size: 13px;
    font-weight: 650;
    line-height: 1.4;
  }

  h1 {
    margin: 0;
    font-size: clamp(48px, 11vw, 86px);
    font-weight: 680;
    line-height: 0.96;
    letter-spacing: 0;
  }

  h2 {
    margin-top: 48px;
    font-weight: 600;
    letter-spacing: 0;
  }

  p {
    margin: 12px 0;
  }

  .intro-block {
    max-width: 660px;
    border-left: 2px solid #d8d0c5;
    margin: 26px 0 0;
    padding-left: 20px;
    word-break: keep-all;
    overflow-wrap: break-word;
  }

  .intro-block p {
    max-width: 600px;
    color: #4f4b43;
    font-size: 18px;
    line-height: 1.62;
  }

  .home-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 18px;
  }

  .home-meta span {
    border: 1px solid #ded6c9;
    border-radius: 999px;
    padding: 3px 8px;
    background: #fffdf8;
    color: #737067;
    font-size: 12px;
    line-height: 1.4;
  }

  ul {
    padding-left: 20px;
  }

  .featured {
    display: grid;
    grid-template-columns: 84px minmax(0, 1fr) auto;
    align-items: center;
    column-gap: 22px;
    row-gap: 14px;
    border: 1px solid var(--accent-border);
    border-radius: 8px;
    margin: 38px 0 14px;
    padding: 20px 22px;
    background: linear-gradient(90deg, var(--accent-bg), #fffdf8 76%);
  }

  .featured-icon img {
    width: 84px;
    height: 84px;
    border-radius: 20px;
  }

  .featured-icon,
  .featured-link {
    align-self: center;
  }

  .featured h2 {
    margin: 3px 0 8px;
    font-size: 28px;
    line-height: 1.12;
  }

  .featured-copy {
    max-width: 460px;
  }

  .featured-label {
    color: var(--accent-text);
    font-size: 13px;
    font-weight: 650;
  }

  .featured p {
    margin: 0;
    color: #4f4b43;
    font-size: 16px;
    line-height: 1.55;
  }

  .featured-link {
    display: inline-flex;
    align-items: center;
    justify-self: end;
    border: 1px solid var(--accent-border);
    border-radius: 8px;
    padding: 8px 11px;
    background: #fffdf8;
    color: #37342f;
    text-decoration: none;
    font-weight: 620;
    line-height: 1.2;
  }

  .tool-list {
    display: grid;
    gap: 0;
    border-top: 1px solid #e0d8cb;
    border-bottom: 1px solid #e0d8cb;
    margin: 18px 0 12px;
  }

  .tool-row {
    display: grid;
    grid-template-columns: 38px 1fr auto;
    align-items: center;
    gap: 18px;
    border-bottom: 1px solid #e9e1d5;
    padding: 15px 0;
  }

  .tool-row > img {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    box-shadow: 0 0 0 1px var(--accent-border, #ddd5c8);
  }

  h3 {
    margin: 0 0 4px;
    font-size: 18px;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .tool-row p {
    margin: 0;
    color: #4f4b43;
    font-size: 15px;
    line-height: 1.5;
  }

  .app-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 7px;
  }

  .app-meta > span {
    color: #827d72;
    font-size: 13px;
    line-height: 1.4;
  }

  .featured-meta.app-meta {
    margin: 9px 0 0;
  }

  .platform-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .platform-badges span {
    border: 1px solid var(--accent-border, #ddd5c8);
    border-radius: 999px;
    padding: 2px 7px;
    background: var(--accent-bg, #faf8f5);
    color: var(--accent-text, #827d72);
    font-size: 12px;
    line-height: 1.4;
  }

  .tool-row a {
    border: 1px solid var(--accent-border, #d6cec0);
    border-radius: 8px;
    padding: 8px 11px;
    background: #faf8f5;
    text-decoration: none;
    font-weight: 620;
    line-height: 1.2;
  }

  .inline-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    color: #737067;
  }

  small {
    color: #777;
  }

  @media (max-width: 680px) {
    .page-shell {
      margin: 48px auto;
      padding: 0 18px;
    }

    .home-hero {
      margin-top: 40px;
    }

    .intro-block {
      margin-top: 22px;
      padding-left: 16px;
    }

    .intro-block p {
      font-size: 16px;
    }

    .featured {
      width: 100%;
      grid-template-columns: 72px 1fr;
      gap: 18px;
    }

    .featured-icon img {
      width: 72px;
      height: 72px;
      border-radius: 18px;
    }

    .featured-copy {
      max-width: none;
    }

    .tool-row {
      grid-template-columns: 38px 1fr;
      gap: 10px;
    }

    .tool-row a,
    .featured-link {
      grid-column: 1 / -1;
      text-align: center;
    }
  }
</style>
