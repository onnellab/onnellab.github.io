---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProductIndexItems, type Locale, type ProductIndexItem } from '../lib/products';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const contentApps = getProductIndexItems(locale);
const homeReleasedAppOrder = ['Aligna', 'ClipNest', 'Quivra', 'Segra', 'TagWeaver', 'VaultXT'];
const homeReleasedAppNames = new Set(homeReleasedAppOrder);
const releasedAppCards = contentApps
  .filter(
    (app): app is ProductIndexItem =>
      app.status === 'Released' && app.hasStoreListing && homeReleasedAppNames.has(app.title)
  )
  .sort((a, b) => homeReleasedAppOrder.indexOf(a.title) - homeReleasedAppOrder.indexOf(b.title));
const featuredApp = releasedAppCards.find((app) => app.title === 'TagWeaver') ?? releasedAppCards[0];
const listedAppCards = releasedAppCards.slice(0, 4);
const appCardStyle = (app: ProductIndexItem) =>
  `--accent-border: ${app.accent.border}; --accent-bg: ${app.accent.background}; --accent-text: ${app.accent.text};`;
const siteUrl = new URL('/', Astro.site).toString();

const text =
  locale === 'ko'
    ? {
        title: 'ONNELLAB - 조용하고 구조적인 디지털 도구',
        description:
          'ONNELLAB은 음악, 텍스트, 오디오, 파일, 생산성을 위한 조용하고 구조적인 앱을 만드는 독립 소프트웨어 스튜디오입니다.',
        intro: '파일, 텍스트, 오디오 작업을 위한 조용한 도구.',
        focus: '빠르게 열리고, 조용히 머물며, 한 가지 일을 정확히 끝내는 앱을 만듭니다.',
        studioLabel: 'Independent App Studio',
        metaLine: 'iOS / Android · 개인정보를 존중하는 유틸리티 앱',
        released: '출시된 앱',
        featured: '대표 앱',
        allApps: '전체 앱 페이지',
        allAppsHref: '/apps/ko/',
        blogLink: '블로그',
        blogHref: '/blog/ko/',
        upcoming: '예정 프로젝트',
        upcomingItems: ['Papira', 'FloMo', 'Nunote', 'Textoria', 'Heara'],
        privacy: '개인정보 처리방침',
        aboutLink: 'About',
        aboutHref: '/about/ko/',
        privacyLink: '앱별 개인정보 처리방침',
        privacyHref: '/privacy/ko/',
        contact: '문의',
        contactLink: '문의',
        soon: '출시 예정',
        switchLabel: 'English',
        switchHref: '/'
      }
    : {
        title: 'ONNELLAB - Calm, Structured Digital Tools',
        description:
          'ONNELLAB is an independent software studio creating calm, structured apps for music, text, audio, files, and productivity.',
        intro: 'Quiet utility apps for focused work.',
        focus: 'Small tools for files, text, audio, and music.',
        studioLabel: 'Independent App Studio',
        metaLine: 'iOS / Android · Privacy-conscious utility apps',
        released: 'Released Apps',
        featured: 'Featured App',
        allApps: 'All app pages',
        allAppsHref: '/apps/',
        blogLink: 'Blog',
        blogHref: '/blog/',
        upcoming: 'Upcoming Projects',
        upcomingItems: ['Papira', 'FloMo', 'Nunote', 'Textoria', 'Heara'],
        privacy: 'Privacy Policy',
        aboutLink: 'About',
        aboutHref: '/about/',
        privacyLink: 'View app privacy policies',
        privacyHref: '/privacy/',
        contact: 'Contact',
        contactLink: 'Contact',
        soon: 'Coming Soon',
        switchLabel: '한국어',
        switchHref: '/ko/'
      };
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': new URL('/#organization', Astro.site).toString(),
  name: 'ONNELLAB',
  url: siteUrl,
  description: text.description,
  email: 'onnellab.app@gmail.com',
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'onnellab.app@gmail.com',
    contactType: 'customer support',
    availableLanguage: ['en', 'ko']
  }
};
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': new URL('/#website', Astro.site).toString(),
  name: 'ONNELLAB',
  url: siteUrl,
  description: text.description,
  inLanguage: locale,
  publisher: {
    '@id': new URL('/#organization', Astro.site).toString()
  }
};
---

<BaseLayout
  title={text.title}
  description={text.description}
  canonicalPath={locale === 'ko' ? '/ko/' : '/'}
  lang={locale}
  jsonLd={[organizationJsonLd, websiteJsonLd]}
  alternates={[
    { lang: 'en', path: '/' },
    { lang: 'ko', path: '/ko/' },
    { lang: 'x-default', path: '/' }
  ]}
>
  <main class="page-shell">
    <nav class="top-nav" aria-label="Primary">
      <a class="nav-link" href={text.blogHref}>{text.blogLink}</a>
      <a class="language" href={text.switchHref} data-locale-choice={locale === 'ko' ? 'en' : 'ko'}>{text.switchLabel}</a>
    </nav>

    <section class="home-showcase" aria-label="ONNELLAB">
      <div class="brand-block">
        <p class="studio-label">{text.studioLabel}</p>
        <h1 class="wordmark">ONNELLAB</h1>
        <div class="brand-rule" aria-hidden="true"></div>
        <div class="intro-block">
          <p>{text.intro}</p>
          <p>{text.focus}</p>
        </div>
        <p class="home-meta">{text.metaLine}</p>
      </div>

      {featuredApp && (
        <a
          class="featured"
          href={featuredApp.href}
          aria-label={text.featured}
          style={appCardStyle(featuredApp)}
        >
          <div class="featured-topline">
            <span class="featured-label">{text.featured}</span>
            <div class="platform-badges" aria-label="Platforms">
              {featuredApp.platforms.map((platform) => <span>{platform}</span>)}
            </div>
          </div>
          <div class="featured-body">
            <img src={featuredApp.iconPath} alt={`${featuredApp.title} icon`} width="82" height="82" />
            <div>
              <h2>{featuredApp.title}</h2>
              <p>{featuredApp.description}</p>
            </div>
          </div>
        </a>
      )}
    </section>

    <section class="apps-section" aria-label={text.released}>
      <div class="section-head">
        <p class="section-label">{text.released}</p>
        <a href={text.allAppsHref}>{text.allApps}</a>
      </div>
      <div class="product-grid">
        {listedAppCards.map((app) => (
          <a
            class:list={['product-card', app.title === featuredApp?.title && 'is-featured-list']}
            href={app.href}
            style={appCardStyle(app)}
          >
            <img src={app.iconPath} alt="" width="44" height="44" />
            <div>
              <h3>{app.title}</h3>
              <p>{app.description}</p>
              <div class="platform-badges" aria-label="Platforms">
                {app.platforms.map((platform) => <span>{platform}</span>)}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <footer class="home-footer">
      <div class="upcoming-line">
        <span>{text.upcoming}</span>
        <p>
          <span>Melivra</span>
          <span aria-hidden="true">/</span>
          {text.upcomingItems.map((item, index) => (
            <>
              <span>{item}</span>
              {index < text.upcomingItems.length - 1 && <span aria-hidden="true">/</span>}
            </>
          ))}
        </p>
      </div>
      <div class="footer-links">
        <a href={text.aboutHref}>{text.aboutLink}</a>
        <a href={text.blogHref}>{text.blogLink}</a>
        <a href={text.privacyHref}>{text.privacyLink}</a>
        <a href="mailto:onnellab.app@gmail.com">{text.contactLink}</a>
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
  .page-shell {
    width: min(1040px, calc(100% - 40px));
    margin: 0 auto;
    padding: 18px 0 16px;
    line-height: 1.65;
  }

  .top-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    font-size: 14px;
  }

  .nav-link {
    color: #5f5a50;
    font-size: 13px;
    font-weight: 650;
    text-decoration: none;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .language {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    border: 1px solid #ded6ca;
    border-radius: 999px;
    padding: 6px 12px;
    background: rgba(255, 253, 248, 0.72);
    color: #5f5a50;
    font-size: 13px;
    font-weight: 650;
    line-height: 1.35;
    text-decoration: none;
  }

  .language:hover,
  .language:focus-visible {
    border-color: #cfc5b7;
    background: #fffdf8;
  }

  .language:focus-visible {
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }

  .home-showcase {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(352px, 0.92fr);
    align-items: center;
    gap: 58px;
    min-height: 328px;
    padding: 42px 0 35px;
    border-bottom: 1px solid #e0d8cb;
  }

  .brand-block {
    position: relative;
    max-width: 640px;
  }

  .studio-label {
    margin: 0 0 12px;
    color: #827d72;
    font-size: 12px;
    font-weight: 680;
    line-height: 1.4;
  }

  h1 {
    margin: 0;
    color: #2f2f2f;
    font-size: clamp(54px, 7.6vw, 86px);
    font-weight: 650;
    line-height: 0.98;
    letter-spacing: 0;
  }

  .brand-rule {
    width: 96px;
    height: 2px;
    margin-top: 21px;
    background: linear-gradient(90deg, #aa9d8a, rgba(207, 197, 183, 0));
  }

  h2 {
    margin: 0;
    font-weight: 600;
    letter-spacing: 0;
  }

  p {
    margin: 12px 0;
  }

  .intro-block {
    max-width: 540px;
    margin: 23px 0 0;
    word-break: keep-all;
    overflow-wrap: break-word;
  }

  .intro-block p {
    max-width: 486px;
    color: #4f4b43;
    font-size: 17px;
    line-height: 1.68;
  }

  .home-meta {
    margin: 16px 0 0;
    color: #737067;
    font-size: 12px;
    line-height: 1.5;
  }

  .featured {
    position: relative;
    display: grid;
    gap: 19px;
    border: 1px solid var(--accent-border);
    border-radius: 8px;
    padding: 22px 23px 24px;
    background:
      linear-gradient(135deg, var(--accent-bg), rgba(255, 253, 248, 0.95) 54%, #fffdf8 88%),
      #fffdf8;
    color: inherit;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 140ms ease, background 140ms ease, box-shadow 140ms ease;
  }

  .featured::after {
    content: "";
    position: absolute;
    inset: 0;
    border-top: 1px solid rgba(255, 253, 248, 0.9);
    box-shadow: inset 0 0 0 1px rgba(255, 253, 248, 0.34);
    pointer-events: none;
  }

  .featured:hover,
  .featured:focus-visible {
    border-color: var(--accent-border);
    background:
      linear-gradient(135deg, var(--accent-bg), rgba(255, 253, 248, 0.88) 48%, #fffdf8 86%),
      #fffdf8;
    box-shadow:
      inset 0 0 0 1px rgba(255, 253, 248, 0.52),
      0 12px 26px rgba(58, 49, 38, 0.052);
  }

  .featured:focus-visible {
    outline: 2px solid #b8ad9f;
    outline-offset: 3px;
  }

  .featured-topline {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .featured-body {
    position: relative;
    display: grid;
    grid-template-columns: 84px minmax(0, 1fr);
    align-items: center;
    gap: 24px;
  }

  .featured-body img {
    width: 84px;
    height: 84px;
    border-radius: 19px;
    box-shadow:
      0 0 0 1px var(--accent-border),
      0 10px 24px rgba(58, 49, 38, 0.06);
  }

  .featured-label {
    color: var(--accent-text);
    font-size: 13px;
    font-weight: 650;
  }

  .featured h2 {
    font-size: 29px;
    line-height: 1.1;
  }

  .featured p {
    margin: 8px 0 0;
    color: #4f4b43;
    font-size: 16px;
    line-height: 1.58;
  }

  .apps-section {
    padding: 20px 0 0;
  }

  .section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 12px;
  }

  .section-head a {
    color: #737067;
    font-size: 14px;
    font-weight: 560;
    text-decoration: none;
  }

  .section-label {
    margin: 0;
    color: #514d45;
    font-size: 13px;
    font-weight: 680;
    line-height: 1.4;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 15px;
  }

  .product-card {
    position: relative;
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr);
    align-items: start;
    gap: 15px;
    border: 1px solid var(--accent-border, #e0d8cb);
    border-radius: 8px;
    min-height: 108px;
    padding: 17px;
    background:
      linear-gradient(135deg, rgba(255, 253, 248, 0.94), var(--accent-bg, #fffdf8)),
      #fffdf8;
    color: inherit;
    text-decoration: none;
    transition: border-color 140ms ease, background 140ms ease, color 140ms ease, box-shadow 140ms ease;
  }

  .product-card.is-featured-list {
    border-color: rgba(199, 184, 160, 0.74);
    background:
      linear-gradient(135deg, rgba(255, 253, 248, 0.99), rgba(255, 253, 248, 0.88) 54%, var(--accent-bg, #fffdf8)),
      #fffdf8;
  }

  .product-card.is-featured-list::after {
    display: none;
  }

  .product-card:hover,
  .product-card:focus-visible {
    border-color: var(--accent-border, #d8cec0);
    background:
      linear-gradient(135deg, #fffdf8 10%, var(--accent-bg, #fffdf8) 92%),
      #fffdf8;
    box-shadow:
      inset 0 0 0 1px rgba(255, 253, 248, 0.54),
      0 10px 22px rgba(58, 49, 38, 0.055);
  }

  .product-card:focus-visible {
    outline: 2px solid #b8ad9f;
    outline-offset: 3px;
  }

  .product-card > img {
    width: 42px;
    height: 42px;
    border-radius: 11px;
    box-shadow: 0 0 0 1px var(--accent-border, #ddd5c8);
    transition: box-shadow 140ms ease;
  }

  h3 {
    margin: 0 0 5px;
    font-size: 18px;
    line-height: 1.25;
    letter-spacing: 0;
    transition: color 140ms ease;
  }

  .product-card:hover h3,
  .product-card:focus-visible h3 {
    color: var(--accent-text, #5f5a50);
  }

  .product-card:hover > img,
  .product-card:focus-visible > img {
    box-shadow:
      0 0 0 1px var(--accent-border, #ddd5c8),
      0 8px 18px rgba(58, 49, 38, 0.06);
  }

  .product-card p {
    margin: 0;
    color: #4f4b43;
    font-size: 15px;
    line-height: 1.5;
  }

  .platform-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 8px;
  }

  .featured-topline .platform-badges {
    margin-top: 0;
  }

  .platform-badges span {
    border: 1px solid var(--accent-border, #ddd5c8);
    border-radius: 999px;
    padding: 2px 7px;
    background: var(--accent-bg, #faf8f5);
    color: var(--accent-text, #827d72);
    font-size: 12px;
    line-height: 1.4;
  }

  .home-footer {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 32px;
    border-top: 1px solid #e0d8cb;
    margin-top: 16px;
    padding-top: 16px;
    color: #737067;
  }

  .upcoming-line > span {
    color: #514d45;
    font-size: 13px;
    font-weight: 680;
  }

  .upcoming-line p {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 5px 0 0;
    font-size: 13px;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 12px;
    font-size: 13px;
  }

  .footer-links a {
    text-decoration: none;
  }

  small {
    color: #777;
  }

  @media (max-width: 680px) {
    .page-shell {
      width: min(100% - 28px, 1040px);
      padding: 18px 0 26px;
    }

    .home-showcase {
      grid-template-columns: 1fr;
      gap: 20px;
      min-height: 0;
      padding: 30px 0 24px;
    }

    h1 {
      font-size: clamp(42px, 14vw, 58px);
    }

    .brand-rule {
      width: 72px;
      margin-top: 16px;
    }

    .intro-block {
      margin-top: 16px;
    }

    .intro-block p {
      font-size: 16px;
      line-height: 1.66;
    }

    .featured {
      width: 100%;
      gap: 15px;
      padding: 15px;
    }

    .featured-topline {
      align-items: flex-start;
      flex-direction: column;
      gap: 8px;
    }

    .featured-body {
      grid-template-columns: 66px minmax(0, 1fr);
      gap: 15px;
    }

    .featured-body img {
      width: 66px;
      height: 66px;
      border-radius: 17px;
      box-shadow: 0 0 0 1px var(--accent-border);
    }

    .product-grid {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .product-card {
      min-height: auto;
      grid-template-columns: 42px minmax(0, 1fr);
      gap: 12px;
      padding: 14px;
      background:
        linear-gradient(135deg, #fffdf8 24%, var(--accent-bg, #fffdf8)),
        #fffdf8;
    }

    .product-card > img {
      width: 40px;
      height: 40px;
      border-radius: 11px;
    }

    h3 {
      font-size: 17px;
    }

    .product-card p {
      font-size: 14px;
      line-height: 1.42;
    }

    .product-card .platform-badges {
      margin-top: 6px;
    }

    .section-head a {
      color: #514d45;
      font-size: 13px;
      font-weight: 680;
      text-decoration: underline;
      text-decoration-color: #cfc5b7;
      text-underline-offset: 4px;
    }

    .home-footer {
      display: grid;
      gap: 12px;
      margin-top: 12px;
      padding-top: 13px;
    }

    .footer-links {
      justify-content: flex-start;
      gap: 10px;
    }
  }
</style>
