---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProductIndexItems, type Locale, type ProductIndexItem } from '../lib/products';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const contentApps = getProductIndexItems(locale);
const privacyUpdatedAtByTitle: Record<string, string> = {
  Quivra: '2026-02-10',
  TagWeaver: '2026-02-14',
  VaultXT: '2026-03-11',
  Segra: '2026-06-12',
  ClipNest: '2026-06-13',
  Aligna: '2026-06-24',
  Melivra: '2026-06-24'
};
const privacyDate = (title: string) => privacyUpdatedAtByTitle[title] ?? '9999-12-31';
const comparePrivacyDate = (a: string, b: string) =>
  privacyDate(a).localeCompare(privacyDate(b)) || a.localeCompare(b);
const releasedApps = ['Quivra', 'TagWeaver', 'VaultXT', 'Segra', 'ClipNest', 'Aligna'].sort(
  comparePrivacyDate
);
const releasedAppCards = releasedApps
  .map((name) => contentApps.find((app) => app.title === name))
  .filter((app): app is ProductIndexItem => app !== undefined);
const featuredApp = releasedAppCards.find((app) => app.title === 'TagWeaver') ?? releasedAppCards[0];
const listedAppCards = releasedAppCards.filter((app) => app.title !== featuredApp?.title);
const appCardStyle = (app: ProductIndexItem) =>
  `--accent-border: ${app.accent.border}; --accent-bg: ${app.accent.background}; --accent-text: ${app.accent.text};`;

const text =
  locale === 'ko'
    ? {
        title: 'ONNELLAB - 조용하고 구조적인 디지털 도구',
        description:
          'ONNELLAB은 음악, 텍스트, 오디오, 파일, 생산성을 위한 조용하고 구조적인 앱을 만드는 독립 소프트웨어 스튜디오입니다.',
        intro: '파일, 텍스트, 오디오 작업을 위한 조용한 도구.',
        focus: '빠르게 열리고, 조용히 머물며, 한 가지 일을 정확히 끝내는 앱을 만듭니다.',
        studioLabel: 'Independent App Studio',
        metaLine: 'iOS / Android · 개인정보를 존중하는 유틸리티 앱',
        released: '출시된 앱',
        featured: '대표 앱',
        allApps: '전체 앱 페이지',
        allAppsHref: '/apps/ko/',
        upcoming: '예정 프로젝트',
        upcomingItems: ['Papira', 'FloMo', 'Nunote', 'Textoria', 'Heara'],
        privacy: '개인정보처리방침',
        privacyLink: '앱별 개인정보처리방침 보기',
        privacyHref: '/privacy/ko/',
        contact: '문의',
        contactLink: '문의하기',
        soon: '출시 예정',
        switchLabel: 'English',
        switchHref: '/'
      }
    : {
        title: 'ONNELLAB - Calm, Structured Digital Tools',
        description:
          'ONNELLAB is an independent software studio creating calm, structured apps for music, text, audio, files, and productivity.',
        intro: 'Quiet utility apps for focused work.',
        focus: 'Small tools for files, text, audio, and music.',
        studioLabel: 'Independent App Studio',
        metaLine: 'iOS / Android · Privacy-conscious utility apps',
        released: 'Released Apps',
        featured: 'Featured App',
        allApps: 'All app pages',
        allAppsHref: '/apps/',
        upcoming: 'Upcoming Projects',
        upcomingItems: ['Papira', 'FloMo', 'Nunote', 'Textoria', 'Heara'],
        privacy: 'Privacy Policy',
        privacyLink: 'View app privacy policies',
        privacyHref: '/privacy/',
        contact: 'Contact',
        contactLink: 'Contact',
        soon: 'Coming Soon',
        switchLabel: '한국어',
        switchHref: '/ko/'
      };
---

<BaseLayout
  title={text.title}
  description={text.description}
  canonicalPath={locale === 'ko' ? '/ko/' : '/'}
  lang={locale}
  alternates={[
    { lang: 'en', path: '/' },
    { lang: 'ko', path: '/ko/' },
    { lang: 'x-default', path: '/' }
  ]}
>
  <main class="page-shell">
    <nav class="top-nav" aria-label="Language">
      <a class="language" href={text.switchHref}>{text.switchLabel}</a>
    </nav>

    <section class="home-showcase" aria-label="ONNELLAB">
      <div class="brand-block">
        <p class="studio-label">{text.studioLabel}</p>
        <h1>ONNELLAB</h1>
        <div class="brand-rule" aria-hidden="true"></div>
        <div class="intro-block">
          <p>{text.intro}</p>
          <p>{text.focus}</p>
        </div>
        <p class="home-meta">{text.metaLine}</p>
      </div>

      {featuredApp && (
        <a
          class="featured"
          href={featuredApp.href}
          aria-label={text.featured}
          style={appCardStyle(featuredApp)}
        >
          <div class="featured-topline">
            <span class="featured-label">{text.featured}</span>
            <div class="platform-badges" aria-label="Platforms">
              {featuredApp.platforms.map((platform) => <span>{platform}</span>)}
            </div>
          </div>
          <div class="featured-body">
            <img src={featuredApp.iconPath} alt={`${featuredApp.title} icon`} width="82" height="82" />
            <div>
              <h2>{featuredApp.title}</h2>
              <p>{featuredApp.description}</p>
            </div>
          </div>
        </a>
      )}
    </section>

    <section class="apps-section" aria-label={text.released}>
      <div class="section-head">
        <p class="section-label">{text.released}</p>
        <a href={text.allAppsHref}>{text.allApps}</a>
      </div>
      <div class="product-grid">
        {listedAppCards.map((app) => (
          <a class="product-card" href={app.href} style={appCardStyle(app)}>
            <img src={app.iconPath} alt="" width="44" height="44" />
            <div>
              <h3>{app.title}</h3>
              <p>{app.description}</p>
              <div class="platform-badges" aria-label="Platforms">
                {app.platforms.map((platform) => <span>{platform}</span>)}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <footer class="home-footer">
      <div class="upcoming-line">
        <span>{text.upcoming}</span>
        <p>
          <span>Melivra</span>
          <span aria-hidden="true">/</span>
          {text.upcomingItems.map((item, index) => (
            <>
              <span>{item}</span>
              {index < text.upcomingItems.length - 1 && <span aria-hidden="true">/</span>}
            </>
          ))}
        </p>
      </div>
      <div class="footer-links">
        <a href={text.privacyHref}>{text.privacyLink}</a>
        <a href="mailto:onnellab.app@gmail.com">{text.contactLink}</a>
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
  .page-shell {
    width: min(1040px, calc(100% - 40px));
    margin: 0 auto;
    padding: 30px 0 38px;
    line-height: 1.65;
  }

  .top-nav {
    display: flex;
    justify-content: flex-end;
    font-size: 14px;
  }

  .language {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    border: 1px solid #ded6ca;
    border-radius: 999px;
    padding: 6px 12px;
    background: rgba(255, 253, 248, 0.72);
    color: #5f5a50;
    font-size: 13px;
    font-weight: 650;
    line-height: 1.35;
    text-decoration: none;
  }

  .language:hover,
  .language:focus-visible {
    border-color: #cfc5b7;
    background: #fffdf8;
  }

  .language:focus-visible {
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }

  .home-showcase {
    display: grid;
    grid-template-columns: minmax(0, 1.22fr) minmax(320px, 0.78fr);
    align-items: center;
    gap: 48px;
    min-height: 390px;
    padding: 52px 0 38px;
    border-bottom: 1px solid #e0d8cb;
  }

  .brand-block {
    max-width: 640px;
  }

  .studio-label {
    margin: 0 0 14px;
    color: #827d72;
    font-size: 12px;
    font-weight: 680;
    line-height: 1.4;
  }

  h1 {
    margin: 0;
    color: #383631;
    font-size: clamp(54px, 8vw, 88px);
    font-weight: 720;
    line-height: 0.98;
    letter-spacing: 0;
  }

  .brand-rule {
    width: 54px;
    height: 2px;
    margin-top: 20px;
    background: #cfc5b7;
  }

  h2 {
    margin: 0;
    font-weight: 600;
    letter-spacing: 0;
  }

  p {
    margin: 12px 0;
  }

  .intro-block {
    max-width: 560px;
    margin: 22px 0 0;
    word-break: keep-all;
    overflow-wrap: break-word;
  }

  .intro-block p {
    max-width: 520px;
    color: #4f4b43;
    font-size: 18px;
    line-height: 1.64;
  }

  .home-meta {
    margin: 17px 0 0;
    color: #737067;
    font-size: 12px;
    line-height: 1.5;
  }

  .featured {
    position: relative;
    display: grid;
    gap: 24px;
    border: 1px solid var(--accent-border);
    border-radius: 8px;
    padding: 22px 22px 24px;
    background:
      linear-gradient(135deg, var(--accent-bg), #fffdf8 68%),
      #fffdf8;
    color: inherit;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 140ms ease, background 140ms ease;
  }

  .featured:hover,
  .featured:focus-visible {
    border-color: var(--accent-border);
    background:
      linear-gradient(135deg, var(--accent-bg), #fffdf8 58%),
      #fffdf8;
  }

  .featured:focus-visible {
    outline: 2px solid #b8ad9f;
    outline-offset: 3px;
  }

  .featured-topline {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .featured-body {
    position: relative;
    display: grid;
    grid-template-columns: 82px minmax(0, 1fr);
    align-items: center;
    gap: 20px;
  }

  .featured-body img {
    width: 82px;
    height: 82px;
    border-radius: 19px;
    box-shadow: 0 0 0 1px var(--accent-border);
  }

  .featured-label {
    color: var(--accent-text);
    font-size: 13px;
    font-weight: 650;
  }

  .featured h2 {
    font-size: 29px;
    line-height: 1.1;
  }

  .featured p {
    margin: 8px 0 0;
    color: #4f4b43;
    font-size: 16px;
    line-height: 1.55;
  }

  .apps-section {
    padding: 32px 0 10px;
  }

  .section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 14px;
  }

  .section-head a {
    color: #737067;
    font-size: 14px;
    text-decoration: none;
  }

  .section-label {
    margin: 0;
    color: #514d45;
    font-size: 13px;
    font-weight: 680;
    line-height: 1.4;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .product-card {
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr);
    align-items: start;
    gap: 15px;
    border: 1px solid var(--accent-border, #e0d8cb);
    border-radius: 8px;
    min-height: 116px;
    padding: 17px;
    background: #fffdf8;
    color: inherit;
    text-decoration: none;
    transition: border-color 140ms ease, background 140ms ease;
  }

  .product-card:hover,
  .product-card:focus-visible {
    border-color: var(--accent-border, #d8cec0);
    background: var(--accent-bg, #fffdf8);
  }

  .product-card:focus-visible {
    outline: 2px solid #b8ad9f;
    outline-offset: 3px;
  }

  .product-card:last-child:nth-child(odd) {
    grid-column: 1 / -1;
  }

  .product-card > img {
    width: 42px;
    height: 42px;
    border-radius: 11px;
    box-shadow: 0 0 0 1px var(--accent-border, #ddd5c8);
  }

  h3 {
    margin: 0 0 5px;
    font-size: 18px;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .product-card p {
    margin: 0;
    color: #4f4b43;
    font-size: 15px;
    line-height: 1.5;
  }

  .platform-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 10px;
  }

  .featured-topline .platform-badges {
    margin-top: 0;
  }

  .platform-badges span {
    border: 1px solid var(--accent-border, #ddd5c8);
    border-radius: 999px;
    padding: 2px 7px;
    background: var(--accent-bg, #faf8f5);
    color: var(--accent-text, #827d72);
    font-size: 12px;
    line-height: 1.4;
  }

  .home-footer {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 28px;
    border-top: 1px solid #e0d8cb;
    margin-top: 24px;
    padding-top: 15px;
    color: #737067;
  }

  .upcoming-line > span {
    color: #514d45;
    font-size: 13px;
    font-weight: 680;
  }

  .upcoming-line p {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 5px 0 0;
    font-size: 13px;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 12px;
    font-size: 13px;
  }

  .footer-links a {
    text-decoration: none;
  }

  small {
    color: #777;
  }

  @media (max-width: 680px) {
    .page-shell {
      width: min(100% - 28px, 1040px);
      padding: 24px 0 32px;
    }

    .home-showcase {
      grid-template-columns: 1fr;
      gap: 30px;
      min-height: 0;
      padding: 38px 0 28px;
    }

    h1 {
      font-size: clamp(42px, 14vw, 58px);
    }

    .brand-rule {
      margin-top: 18px;
    }

    .intro-block {
      margin-top: 20px;
    }

    .intro-block p {
      font-size: 16px;
      line-height: 1.62;
    }

    .featured {
      width: 100%;
      gap: 20px;
      padding: 17px;
    }

    .featured-topline {
      align-items: flex-start;
      flex-direction: column;
      gap: 8px;
    }

    .featured-body {
      grid-template-columns: 72px minmax(0, 1fr);
      gap: 16px;
    }

    .featured-body img {
      width: 72px;
      height: 72px;
      border-radius: 18px;
    }

    .product-grid {
      grid-template-columns: 1fr;
    }

    .product-card:last-child:nth-child(odd) {
      grid-column: auto;
    }

    .product-card {
      min-height: auto;
      padding: 15px;
    }

    .home-footer {
      display: grid;
      gap: 14px;
    }

    .footer-links {
      justify-content: flex-start;
    }
  }
</style>
