---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getBlogPosts, type BlogPost } from '../lib/blog';
import type { Locale } from '../lib/products';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const posts: BlogPost[] = getBlogPosts(locale);
const isKo = locale === 'ko';
const copy = isKo
  ? {
      title: 'ONNELLAB 블로그 - 차분한 디지털 워크플로 가이드',
      description: '읽기, 음악, 생산성, 미디어, 창작, 게임, 리서치 워크플로를 다루는 ONNELLAB 교육형 글입니다.',
      canonicalPath: '/blog/ko/',
      switchHref: '/blog/',
      switchLabel: 'English',
      appsHref: '/apps/ko/',
      appsLabel: 'Apps',
      eyebrow: 'ONNELLAB Blog',
      heading: '워크플로 가이드',
      intro: '읽기, 음악, 생산성, 미디어 작업을 차분하게 정리하는 실전 글입니다.',
      emptyTitle: '첫 글을 준비하고 있습니다',
      emptyText: '읽기, 음악, 생산성, 미디어 작업을 더 차분하게 정리하는 실전 가이드를 곧 게시합니다.',
      categoriesLabel: '다룰 주제',
      emptyLabel: '상태',
      postsLabel: '게시된 글',
      allCategories: '전체'
    }
  : {
      title: 'ONNELLAB Blog - Practical guides for calm digital workflows',
      description: 'Educational ONNELLAB articles about reading, music, productivity, media, craft, games, and research workflows.',
      canonicalPath: '/blog/',
      switchHref: '/blog/ko/',
      switchLabel: '한국어',
      appsHref: '/apps/',
      appsLabel: 'Apps',
      eyebrow: 'ONNELLAB Blog',
      heading: 'Practical Workflow Guides',
      intro: 'Focused articles for calmer reading, music, productivity, and media workflows.',
      emptyTitle: 'Articles are being prepared',
      emptyText: 'Practical guides for reading, music, productivity, and media workflows will appear here as they are published.',
      categoriesLabel: 'Planned topics',
      emptyLabel: 'Status',
      postsLabel: 'Published articles',
      allCategories: 'All'
    };
const categories = isKo
  ? [
      ['Reading', '큰 텍스트와 긴 문서를 읽기 쉽게 다루는 방법'],
      ['Music', '오디오 파일과 음악 메타데이터를 정리하는 방법'],
      ['Productivity', '반복 작업을 줄이고 파일 흐름을 정돈하는 방법'],
      ['Media', '스크린샷, 클립, 자료를 잃어버리지 않게 관리하는 방법']
    ]
  : [
      ['Reading', 'Ways to handle large text and long-form documents calmly'],
      ['Music', 'Workflows for audio files and music metadata'],
      ['Productivity', 'Methods for reducing repeated file and text work'],
      ['Media', 'Practical organization for screenshots, clips, and references']
    ];
const postCategories = Array.from(new Set(posts.map((post) => post.meta.category))).sort((a, b) => a.localeCompare(b));
const categoryLabels: Record<string, string> = isKo
  ? {
      reading: '읽기',
      music: '음악',
      productivity: '생산성',
      media: '미디어',
      craft: '창작',
      games: '게임',
      research: '리서치'
    }
  : {
      reading: 'Reading',
      music: 'Music',
      productivity: 'Productivity',
      media: 'Media',
      craft: 'Craft',
      games: 'Games',
      research: 'Research'
    };
const categoryLabel = (category: string) => categoryLabels[category] || category;
const absoluteUrl = (path: string) => new URL(path, Astro.site).toString();
const blogJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: 'ONNELLAB Blog',
    description: copy.description,
    inLanguage: locale,
    url: absoluteUrl(copy.canonicalPath),
    publisher: {
      '@type': 'Organization',
      name: 'ONNELLAB',
      url: absoluteUrl('/')
    },
    blogPost: posts.map((post) => ({
      '@type': 'BlogPosting',
      headline: post.meta.cardTitle,
      description: post.meta.description,
      url: absoluteUrl(post.href),
      datePublished: post.meta.publishedAt,
      dateModified: post.meta.updatedAt || post.meta.publishedAt,
      articleSection: post.meta.category,
      inLanguage: post.meta.language
    }))
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: copy.title,
    description: copy.description,
    inLanguage: locale,
    url: absoluteUrl(copy.canonicalPath),
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: posts.map((post, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: post.meta.cardTitle,
        url: absoluteUrl(post.href)
      }))
    }
  }
];
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  canonicalPath={copy.canonicalPath}
  lang={locale}
  jsonLd={blogJsonLd}
  alternates={[
    { lang: 'en', path: '/blog/' },
    { lang: 'ko', path: '/blog/ko/' },
    { lang: 'x-default', path: '/blog/' }
  ]}
>
  <main class="blog-shell">
    <nav class="top-nav" aria-label="Blog navigation">
      <a class="brand" href={isKo ? '/ko/' : '/'}>ONNELLAB</a>
      <div class="nav-actions">
        <a href={copy.appsHref}>{copy.appsLabel}</a>
        <a class="language" href={copy.switchHref} data-locale-choice={isKo ? 'en' : 'ko'} aria-label={isKo ? 'Switch to English' : '한국어로 보기'} title={isKo ? 'English' : '한국어'}>{copy.switchLabel}</a>
      </div>
    </nav>

    <header class="blog-header">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1>{copy.heading}</h1>
      <p>{copy.intro}</p>
    </header>

    {posts.length === 0 && (
      <section class="empty-state" aria-label={copy.emptyLabel}>
        <h2>{copy.emptyTitle}</h2>
        <p>{copy.emptyText}</p>
      </section>
    )}

    <section class="category-preview" aria-label={copy.categoriesLabel}>
      {categories.map(([name, description]) => (
        <article>
          <h2>{name}</h2>
          <p>{description}</p>
        </article>
      ))}
    </section>

    {posts.length > 0 && (
      <>
        <div class="filter-row" role="group" aria-label={copy.categoriesLabel}>
          <button type="button" class="filter-chip is-active" data-blog-filter="all">{copy.allCategories}</button>
          {postCategories.map((category) => (
            <button type="button" class="filter-chip" data-blog-filter={category}>{categoryLabel(category)}</button>
          ))}
        </div>

        <section class="post-list" aria-label={copy.postsLabel}>
          {posts.map((post) => (
            <a class="post-card" href={post.href} aria-label={post.meta.cardTitle} data-post-category={post.meta.category}>
              <article>
                <p>{categoryLabel(post.meta.category)}</p>
                <h2>{post.meta.cardTitle}</h2>
                <span>{post.meta.description}</span>
              </article>
            </a>
          ))}
        </section>
      </>
    )}
  </main>
  <script is:inline>
    (() => {
      const filters = Array.from(document.querySelectorAll('[data-blog-filter]'));
      const cards = Array.from(document.querySelectorAll('[data-post-category]'));
      if (!filters.length || !cards.length) return;

      const selectFilter = (value) => {
        filters.forEach((filter) => {
          const selected = filter.getAttribute('data-blog-filter') === value;
          filter.classList.toggle('is-active', selected);
          filter.setAttribute('aria-pressed', String(selected));
        });
        cards.forEach((card) => {
          const category = card.getAttribute('data-post-category');
          card.hidden = value !== 'all' && category !== value;
        });
      };

      filters.forEach((filter) => {
        filter.setAttribute('aria-pressed', String(filter.classList.contains('is-active')));
        filter.addEventListener('click', () => selectFilter(filter.getAttribute('data-blog-filter') || 'all'));
      });
    })();
  </script>
</BaseLayout>

<style>
  .blog-shell {
    width: min(920px, calc(100% - 40px));
    display: flex;
    flex-direction: column;
    margin: 0 auto;
    padding: 22px 0 56px;
    line-height: 1.65;
  }
  .top-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-size: 14px;
  }
  .top-nav a {
    color: #5f5a50;
    text-decoration: none;
    font-weight: 650;
  }
  .top-nav .brand {
    color: #737067;
    font-size: 14px;
    font-weight: 560;
  }
  .nav-actions {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .nav-actions > a:not(.language):hover,
  .nav-actions > a:not(.language):focus-visible {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .language {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    border: 1px solid #ded6ca;
    border-radius: 999px;
    padding: 6px 12px;
    background: rgba(255, 253, 248, 0.72);
    color: #5f5a50;
    font-size: 13px;
    font-weight: 650;
    line-height: 1.35;
  }
  .language:hover,
  .language:focus-visible {
    border-color: #cfc5b7;
    background: #fffdf8;
  }
  .language:focus-visible {
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }
  .blog-header {
    padding: 64px 0 36px;
    border-bottom: 1px solid #e0d8cb;
  }
  .eyebrow,
  .post-card p {
    margin: 0 0 10px;
    color: #716a5f;
    font-size: 13px;
    font-weight: 720;
    text-transform: uppercase;
  }
  h1 {
    max-width: 760px;
    margin: 0;
    color: #2f2f2f;
    font-size: clamp(36px, 7vw, 68px);
    line-height: 1.02;
    letter-spacing: 0;
  }
  .blog-header > p:last-child {
    max-width: 680px;
    margin: 22px 0 0;
    color: #5b574f;
    font-size: 18px;
  }
  .empty-state {
    margin-top: 24px;
    border: 1px solid #ded6ca;
    border-radius: 8px;
    padding: 22px;
    background: #fffdf8;
  }
  .category-preview {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    padding: 22px 0 0;
  }
  .category-preview article {
    border: 1px solid #ded6ca;
    border-radius: 8px;
    padding: 12px 14px;
    background: rgba(255, 253, 248, 0.74);
  }
  .category-preview h2 {
    margin: 0 0 4px;
    color: #343331;
    font-size: 14px;
    line-height: 1.2;
  }
  .category-preview p {
    margin: 0;
    color: #6c675f;
    font-size: 13px;
    line-height: 1.45;
  }
  .post-list {
    display: grid;
    gap: 14px;
    padding-top: 26px;
  }
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding-top: 24px;
  }
  .filter-chip {
    min-height: 34px;
    border: 1px solid #ded6ca;
    border-radius: 999px;
    padding: 6px 12px;
    background: rgba(255, 253, 248, 0.72);
    color: #5f5a50;
    font: inherit;
    font-size: 13px;
    font-weight: 650;
    line-height: 1.35;
    cursor: pointer;
  }
  .filter-chip:hover,
  .filter-chip:focus-visible,
  .filter-chip.is-active {
    border-color: #c9d7d2;
    background: #f6fbf9;
    color: #3f625a;
  }
  .filter-chip:focus-visible {
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }
  .post-card {
    position: relative;
    display: block;
    border: 1px solid #ded6ca;
    border-radius: 8px;
    padding: 22px;
    background: #fffdf8;
    color: inherit;
    text-decoration: none;
    transition: background 140ms ease, border-color 140ms ease, box-shadow 140ms ease;
  }
  .post-card::after {
    content: "";
    width: 18px;
    height: 1px;
    position: absolute;
    right: 18px;
    bottom: 16px;
    background: linear-gradient(90deg, rgba(207, 197, 183, 0), rgba(185, 173, 157, 0.58));
    opacity: 0;
    transition: opacity 140ms ease;
  }
  .post-card:hover,
  .post-card:focus-visible {
    border-color: #d4c7b6;
    background:
      linear-gradient(90deg, #fffdf8, rgba(250, 248, 245, 0.74)),
      #fffdf8;
    box-shadow:
      inset 0 1px 0 rgba(255, 253, 248, 0.78),
      inset 0 -1px 0 rgba(210, 199, 184, 0.62),
      0 8px 18px rgba(58, 49, 38, 0.04);
  }
  .post-card:hover h2,
  .post-card:focus-visible h2 {
    color: #2f2d29;
  }
  .post-card:hover::after,
  .post-card:focus-visible::after {
    opacity: 0.9;
  }
  .post-card:focus-visible {
    outline: 2px solid #827d72;
    outline-offset: 3px;
  }
  .post-card h2,
  .empty-state h2 {
    margin: 0 0 8px;
    color: #343331;
    font-size: 22px;
    line-height: 1.25;
  }
  .post-card span,
  .empty-state p {
    color: #5d5850;
  }
  @media (max-width: 640px) {
    .blog-shell {
      width: min(100% - 32px, 920px);
      padding-top: 18px;
    }
    .blog-header {
      padding: 46px 0 30px;
    }
    .category-preview {
      grid-template-columns: 1fr;
      order: 4;
      padding-top: 26px;
    }
    .filter-row {
      order: 2;
    }
    .post-list {
      order: 3;
    }
  }
</style>
