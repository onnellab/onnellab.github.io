---
type Props = {
  title: string;
  description: string;
  canonicalPath: string;
  lang?: string;
  image?: string;
  jsonLd?: unknown;
  alternates?: Array<{ lang: string; path: string }>;
};

const {
  title,
  description,
  canonicalPath,
  lang = 'en',
  image,
  jsonLd,
  alternates = []
} = Astro.props;
const canonicalUrl = new URL(canonicalPath, Astro.site);
const imageUrl = image ? new URL(image, Astro.site) : undefined;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="google-site-verification" content="0IUOtlQTLbMO9gWiDi4TqtQpMCKZVsGRLEchK8A6IzE" />
    <link rel="icon" type="image/png" href={new URL('/app-assets/quivra/assets/icon/quivra.png', Astro.site)} />
    <link rel="apple-touch-icon" href={new URL('/app-assets/quivra/assets/icon/quivra.png', Astro.site)} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="ONNELLAB Apps" href={new URL('/rss.xml', Astro.site)} />
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.lang} href={new URL(alternate.path, Astro.site)} />
    ))}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    <slot name="head" />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <slot />
    <script is:inline>
      (() => {
        const preferenceKey = 'onnellab.locale';
        document.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;
          const link = target.closest('a[data-locale-choice]');
          const locale = link?.getAttribute('data-locale-choice');
          if (!locale) return;
          try {
            window.localStorage.setItem(preferenceKey, locale);
          } catch {
          }
        });

        let savedLocale = null;
        try {
          savedLocale = window.localStorage.getItem(preferenceKey);
        } catch {
        }
        if (savedLocale) return;

        const languages = navigator.languages?.length ? navigator.languages : [navigator.language];
        const prefersKorean = languages.some((language) => language?.toLowerCase().startsWith('ko'));
        if (!prefersKorean) return;

        const { pathname, search, hash } = window.location;
        let targetPath = '';
        if (pathname === '/') {
          targetPath = '/ko/';
        } else if (pathname === '/apps/') {
          targetPath = '/apps/ko/';
        } else if (pathname === '/privacy/') {
          targetPath = '/privacy/ko/';
        } else {
          const appMatch = pathname.match(/^\/apps\/([^/]+)\/$/);
          if (appMatch) targetPath = `/apps/${appMatch[1]}/ko/`;
        }

        if (targetPath) window.location.replace(`${targetPath}${search}${hash}`);
      })();
    </script>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: "SUIT Variable";
    font-weight: 45 920;
    font-style: normal;
    font-display: swap;
    src: url("https://cdn.jsdelivr.net/gh/sunn-us/SUIT/fonts/variable/woff2/SUIT-Variable.woff2")
      format("woff2-variations");
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: #faf8f5;
    color: #3e3e3e;
    font-family:
      "SUIT Variable", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Apple SD Gothic Neo", "Segoe UI", sans-serif;
  }

  a {
    color: inherit;
  }
</style>
