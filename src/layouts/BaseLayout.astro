---
type Props = {
  title: string;
  description: string;
  canonicalPath: string;
  lang?: string;
  image?: string;
  socialImage?: string;
  ogType?: string;
  articleMeta?: {
    publishedTime?: string;
    modifiedTime?: string;
    section?: string;
    tags?: string[];
  };
  jsonLd?: unknown | unknown[];
  alternates?: Array<{ lang: string; path: string }>;
};

const {
  title,
  description,
  canonicalPath,
  lang = 'en',
  image,
  socialImage,
  ogType = 'website',
  articleMeta,
  jsonLd,
  alternates = []
} = Astro.props;
const canonicalUrl = new URL(canonicalPath, Astro.site);
const imageUrl = socialImage || image ? new URL(socialImage || image || '', Astro.site) : undefined;
const twitterCard = imageUrl ? 'summary_large_image' : 'summary';
const faviconVersion = '20260713-ol-classic-v2';
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim();
const gaScript = gaMeasurementId
  ? `
    window.dataLayer = window.dataLayer || [];
    function gtag(){window.dataLayer.push(arguments);}
    window.gtag = window.gtag || gtag;
    gtag('js', new Date());
    gtag('config', ${JSON.stringify(gaMeasurementId)}, {
      anonymize_ip: true,
      send_page_view: true
    });
    window.onnelTrack = (eventName, params = {}) => {
      if (!eventName || typeof window.gtag !== 'function') return;
      window.gtag('event', eventName, {
        transport_type: 'beacon',
        ...params
      });
    };
  `
  : '';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="google-site-verification" content="0IUOtlQTLbMO9gWiDi4TqtQpMCKZVsGRLEchK8A6IzE" />
    <link rel="icon" href={new URL(`/favicon.svg?v=${faviconVersion}`, Astro.site)} type="image/svg+xml" />
    <link rel="icon" href={new URL(`/favicon-32x32.png?v=${faviconVersion}`, Astro.site)} sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href={new URL(`/apple-touch-icon.png?v=${faviconVersion}`, Astro.site)} />
    <link rel="manifest" href={new URL(`/site.webmanifest?v=${faviconVersion}`, Astro.site)} />
    <meta name="theme-color" content="#f8f4ec" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="ONNELLAB RSS" href={new URL('/rss.xml', Astro.site)} />
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.lang} href={new URL(alternate.path, Astro.site)} />
    ))}
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    {ogType === 'article' && articleMeta?.publishedTime && <meta property="article:published_time" content={articleMeta.publishedTime} />}
    {ogType === 'article' && articleMeta?.modifiedTime && <meta property="article:modified_time" content={articleMeta.modifiedTime} />}
    {ogType === 'article' && articleMeta?.section && <meta property="article:section" content={articleMeta.section} />}
    {ogType === 'article' && articleMeta?.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    <slot name="head" />
    {jsonLdItems.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
    {gaMeasurementId && <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>}
    {gaMeasurementId && <script is:inline set:html={gaScript}></script>}
  </head>
  <body>
    <slot />
    <script is:inline>
      (() => {
        const preferenceKey = 'onnellab.locale';
        document.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;
          const link = target.closest('a[data-locale-choice]');
          const locale = link?.getAttribute('data-locale-choice');
          if (!locale) return;
          window.onnelTrack?.('language_switch', {
            from_locale: document.documentElement.lang || '',
            to_locale: locale,
            page_path: window.location.pathname
          });
          try {
            window.localStorage.setItem(preferenceKey, locale);
          } catch {
          }
        });

        let savedLocale = null;
        try {
          savedLocale = window.localStorage.getItem(preferenceKey);
        } catch {
        }
        if (savedLocale) return;

        const languages = navigator.languages?.length ? navigator.languages : [navigator.language];
        const prefersKorean = languages.some((language) => language?.toLowerCase().startsWith('ko'));
        if (!prefersKorean) return;

        const { pathname, search, hash } = window.location;
        let targetPath = '';
        if (pathname === '/') {
          targetPath = '/ko/';
        } else if (pathname === '/apps/') {
          targetPath = '/apps/ko/';
        } else if (pathname === '/privacy/') {
          targetPath = '/privacy/ko/';
        } else if (pathname === '/about/') {
          targetPath = '/about/ko/';
        } else if (pathname === '/blog/' || pathname === '/blog/en/') {
          targetPath = '/blog/ko/';
        } else {
          const appMatch = pathname.match(/^\/apps\/([^/]+)\/$/);
          const blogMatch = pathname.match(/^\/blog\/en\/([^/]+)\/$/);
          if (appMatch && appMatch[1] !== 'ko') targetPath = `/apps/${appMatch[1]}/ko/`;
          if (blogMatch) targetPath = `/blog/ko/${blogMatch[1]}/`;
        }

        if (targetPath) window.location.replace(`${targetPath}${search}${hash}`);
      })();
    </script>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: "SUIT Variable";
    font-weight: 45 920;
    font-style: normal;
    font-display: swap;
    src: url("https://cdn.jsdelivr.net/gh/sunn-us/SUIT/fonts/variable/woff2/SUIT-Variable.woff2")
      format("woff2-variations");
  }

  * {
    box-sizing: border-box;
  }

  :root {
    --onnellab-wordmark-font: "Avenir Next", Avenir, "Helvetica Neue", Arial, sans-serif;
  }

  body {
    margin: 0;
    background: #faf8f5;
    color: #3e3e3e;
    font-family:
      "SUIT Variable", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Apple SD Gothic Neo", "Segoe UI", sans-serif;
    word-break: keep-all;
    overflow-wrap: normal;
    line-break: strict;
  }

  a {
    color: inherit;
  }

  code,
  pre,
  kbd,
  samp,
  input,
  textarea,
  table,
  .word-break-anywhere {
    word-break: normal;
    overflow-wrap: anywhere;
    line-break: auto;
  }

  .wordmark,
  .brand {
    font-family: var(--onnellab-wordmark-font);
    letter-spacing: 0;
  }
</style>
