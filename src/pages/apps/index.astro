---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProductIndexItems } from '../../lib/products';

const apps = getProductIndexItems('en');
const title = 'ONNELLAB Apps';
const description = 'ONNELLAB app pages generated from app docs.';
---

<BaseLayout title={title} description={description} canonicalPath="/apps/">
  <main class="page-shell">
    <header>
      <a class="brand" href="/">ONNELLAB</a>
      <h1>Apps</h1>
      <p>{description}</p>
    </header>

    <section class="grid" aria-label="Apps">
      {apps.map((app) => (
        <article>
          <img src={app.iconPath} alt={`${app.title} icon`} width="64" height="64" />
          <div>
            <h2>{app.title}</h2>
            <p>{app.description}</p>
            <span>{app.status} · {app.platforms.join(' · ')}</span>
          </div>
          <a href={app.href}>Open</a>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  .page-shell {
    width: min(980px, calc(100% - 32px));
    margin: 0 auto;
    padding: 70px 0 36px;
  }

  .brand {
    color: #737067;
    font-size: 14px;
    font-weight: 650;
    text-decoration: none;
  }

  h1 {
    margin: 12px 0 10px;
    font-size: clamp(42px, 7vw, 72px);
    line-height: 1;
    letter-spacing: 0;
  }

  header p {
    max-width: 560px;
    color: #5b574f;
    font-size: 18px;
    line-height: 1.6;
  }

  .grid {
    display: grid;
    gap: 14px;
    margin-top: 36px;
  }

  article {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    align-items: center;
    gap: 18px;
    border: 1px solid #e0d8cb;
    border-radius: 8px;
    padding: 16px;
    background: #fffdf8;
  }

  img {
    border-radius: 16px;
    background: #eee8dd;
  }

  h2 {
    margin: 0 0 6px;
    font-size: 20px;
    letter-spacing: 0;
  }

  p {
    margin: 0;
    color: #4f4b43;
    font-size: 16px;
    line-height: 1.6;
  }

  span {
    display: block;
    margin-top: 8px;
    color: #827d72;
    font-size: 13px;
  }

  article a {
    border: 1px solid #d6cec0;
    border-radius: 8px;
    padding: 9px 12px;
    background: #faf8f5;
    text-decoration: none;
    font-weight: 620;
  }

  @media (max-width: 680px) {
    article {
      grid-template-columns: 56px 1fr;
    }

    img {
      width: 56px;
      height: 56px;
      border-radius: 14px;
    }

    article a {
      grid-column: 1 / -1;
      text-align: center;
    }
  }
</style>
