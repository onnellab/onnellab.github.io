---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProductIndexItems } from '../lib/products';

const contentApps = getProductIndexItems('en');
const privacyApps = contentApps.filter((app) => app.privacy);
const title = 'ONNELLAB - Calm, Structured Digital Tools';
const description =
  'ONNELLAB is an independent software studio creating calm, structured apps for music, text, audio, files, and productivity.';
---

<BaseLayout title={title} description={description} canonicalPath="/">
  <main class="page-shell">
    <h1>ONNELLAB</h1>

    <p>
      Independent software studio creating calm, structured tools for everyday digital work.
    </p>

    <p>
      ONNELLAB focuses on lightweight, privacy-conscious applications designed to do one job well.
    </p>

    <h2>Released Apps</h2>

    <ul>
      <li><a href="/apps/aligna/">Aligna</a></li>
      <li>Quivra</li>
      <li>TagWeaver</li>
      <li>VaultXT</li>
      <li>Segra</li>
      <li>ClipNest</li>
      <li>Melivra <small>(Coming Soon)</small></li>
    </ul>

    <p><a href="/apps/">All app pages</a></p>

    <h2>Upcoming Projects</h2>

    <ul>
      <li>FloMo</li>
      <li>Nunote</li>
      <li>Textoria</li>
      <li>Heara</li>
    </ul>

    <h2>Privacy Policy</h2>

    <ul>
      {privacyApps.map((app) => <li><a href={app.privacy}>{app.title}</a></li>)}
      <li><a href="https://onnelakin.github.io/quivra-privacy-policy/">Quivra</a></li>
      <li><a href="https://onnelakin.github.io/tagweaver-privacy-policy/">TagWeaver</a></li>
      <li><a href="https://onnelakin.github.io/vaultxt-privacy-policy/">VaultXT</a></li>
      <li><a href="https://onnelakin.github.io/segra-privacy-policy/">Segra</a></li>
      <li><a href="https://onnelakin.github.io/clipnest-privacy-policy/">ClipNest</a></li>
      <li><a href="https://onnelakin.github.io/melivra-privacy-policy/">Melivra</a></li>
    </ul>

    <h2>Contact</h2>

    <p>
      For inquiries:
      <a href="mailto:onnellab.app@gmail.com">onnellab.app@gmail.com</a>
    </p>
  </main>
</BaseLayout>

<style>
  .page-shell {
    max-width: 820px;
    margin: 80px auto;
    padding: 0 24px;
    line-height: 1.75;
  }

  h1 {
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: 0;
  }

  h2 {
    margin-top: 48px;
    font-weight: 600;
    letter-spacing: 0;
  }

  p {
    margin: 12px 0;
  }

  ul {
    padding-left: 20px;
  }

  small {
    color: #777;
  }
</style>
